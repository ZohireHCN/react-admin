private void writeRejectFile(
        Path inputFile,
        List<String> lines) throws IOException {

    if (lines.size() <= 1) {
        return;
    }

    String fileName =
            removeExtension(inputFile.getFileName().toString())
                    + "_reject.csv";

    Files.write(
            getRejectDirectoryPath().resolve(fileName),
            lines,
            StandardCharsets.UTF_8,
            StandardOpenOption.CREATE,
            StandardOpenOption.TRUNCATE_EXISTING
    );
}


