    private Invoice findInvoiceById(Long invoiceId) {
        return this.invoiceService
                .getEntityManager()
                .createQuery(QUERY_FIND_INVOICE_BY_ID, Invoice.class)
                .setParameter("id", invoiceId)
                .getSingleResult();
    }

    private boolean isInvoiceAttachedToBordereau(Long invoiceId) {
        int nbrInATB= Integer.parseInt(customTableService.getEntityManager()
                .createNativeQuery(QUERY_IS_IN_BR_BY_ID).setParameter("id",invoiceId).getSingleResult().toString());
        return nbrInATB>0;
    }
    private boolean hasAlreadyInternalCreditNote(Long invoiceId) {
        int nbrAICN= Integer.parseInt(customTableService.getEntityManager()
                .createNativeQuery(QUERY_IS_IN_AI_BY_ID).setParameter("id",invoiceId).getSingleResult().toString());
        return nbrAICN>0;
    }

    private BordereauDto findBordereauById(Long bordereauId) {
        try {
            Object[] obj= (Object[]) customTableService.getEntityManager()
                    .createNativeQuery(QUERY_FIND_BRD_BY_BRD_ID).setParameter("id",bordereauId).getSingleResult();
            return new BordereauDto(Long.valueOf(obj[0].toString()) ,(Boolean)  obj[1]);
        } catch (Exception e) {
            throw new BusinessException("Error findBordereauById");
        }
    }



    private void updateInitialInvoiceAsCancelled(
            Invoice invoice,
            Long motifId) {
        CustomFieldValues invoiceCfValues = invoice.getCfValues();
        invoiceCfValues.setValue(INVOICE_CF_CANCELLED_KEY, true);
        invoiceCfValues.setValue(INVOICE_CF_MOTIF_REJET_KEY, motifId);
        invoiceService.update(invoice);
    }

    private void createInvoiceCreditNoteMatching(Long billingAccountId,Long initialInvoiceId,Long creditNoteId,Long motifId) {
        customTableService.getEntityManager()
                .createNativeQuery(QUERY_INSERT_MATCHING)
                .setParameter("accountId",billingAccountId)
                .setParameter("invoiceId",initialInvoiceId)
                .setParameter("avoireId",creditNoteId)
                .setParameter("motifId",motifId).executeUpdate();
    }
    private void updateBordereauAsCancelled(Long bordereauId,Long motifId) {
        customTableService.getEntityManager()
                .createNativeQuery(QUERY_CANCELLED_BR_BY_ID)
                .setParameter("motif",motifId)
                .setParameter("id",bordereauId).executeUpdate();
    }

    private List<Long> findInvoiceIdsByBordereauId(Long bordereauId) {
        List<?> idbrdStr = this.customTableService.getEntityManager().createNativeQuery(QUERY_FIND_INVOICE_BY_BRD_ID)
                .setParameter("id", bordereauId).getResultList();
        return idbrdStr.stream().map(inv ->((Number) inv).longValue()).collect(Collectors.toList());
    }

