3. Traitement d’un fichier

private void processSingleInputFile(
        Path inputFile,
        ReportDto report,
        MeveoUser currentUser) throws Exception {

    List<String> outputLines = new ArrayList<>();
    List<String> rejectLines = new ArrayList<>();

    List<String> lines = Files.readAllLines(
            inputFile,
            StandardCharsets.UTF_8
    );

    if (lines.size() <= 1) {
        moveFileToArchive(inputFile);
        return;
    }

    outputLines.add("factures;BORDEREAU;RESULT");
    rejectLines.add("factures;BORDEREAU;ERROR");

    for (int i = 1; i < lines.size(); i++) {

        String line = lines.get(i);

        if (isEmpty(line)) {
            continue;
        }

        try {
            processInputLine(line, report, currentUser);

            outputLines.add(line + ";OK");

        } catch (Exception e) {

            rejectLines.add(
                    line
                            + ";"
                            + e.getMessage()
            );
        }
    }

    writeOutputFile(inputFile, outputLines);

    writeRejectFile(inputFile, rejectLines);

    moveFileToArchive(inputFile);
}


