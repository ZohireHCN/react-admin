    // ---------------------------------------------------------------------
    // Utils
    // ---------------------------------------------------------------------

    private String getStringParam(Map<String, Object> context, String key) {
        Object value = context.get(key);
        return value != null ? value.toString().trim() : "";
    }

    private boolean isEmpty(String value) {
        return value == null || value.trim().isEmpty();
    }

    private List<Long> parseIds(String value) {
        return Arrays.stream(value.split(","))
                .map(String::trim)
                .filter(v -> !v.isEmpty())
                .map(Long::valueOf)
                .collect(Collectors.toList());
    }

    private void flushReportInContext(
            Map<String, Object> context,
            ReportDto report) {

        context.put(Script.JOB_RESULT_NB_OK, report.getNbOk());
        context.put(Script.JOB_RESULT_NB_KO, report.getNbKo());
        context.put("JOB_RESULT_NB_WARNING", report.getNbWarning());

        if (!report.getMessage().isEmpty()) {
            context.put(Script.JOB_RESULT_REPORT, report.getMessage());
        }
    }

