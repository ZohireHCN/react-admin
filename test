        if (line.length() < 4) {
            continue;
        }

        String path = line.substring(3).trim();

        if (!path.endsWith(".java")) {
            continue;
        }

        changedFiles.add(path);
    }

    relativePaths = new ArrayList<>(changedFiles);

    log.info("Git filter enabled: files changed in the last "
            + modifiedLastDays + " day(s) + local modifications.");
