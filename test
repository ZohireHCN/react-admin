/**
 * Initialise l'arborescence technique du job si elle n'existe pas encore.
 */
private void initializeDirectoriesIfNeeded(ReportDto report) throws IOException {

    Path inputDirectory = getInputDirectoryPath();

    if (Files.notExists(inputDirectory)) {
        initDirectories();

        report.registerOk("Initialisation des dossiers effectuée");
    } else {
        report.registerOk("Les dossiers existent déjà");
    }
}
