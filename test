public class InvoiceCreditNoteScript extends Script {

    private static final String INVOICES_ID_JOB_PARAM = "factures";
    private static final String BORDEREAUX_ID_JOB_PARAM = "bordereaux";
    private static final String MOTIF_ID_JOB_PARAM = "motif";

    private static final String IMPORTS_DIR = "imports";
    private static final String INVOICES_DIR = "invoices";
    private static final String AVOIRS_DIR = "avoir_interne";

    private static final String INPUT_SUBDIR = "input";
    private static final String OUTPUT_SUBDIR = "output";
    private static final String REJECT_SUBDIR = "reject";
    private static final String ARCHIVE_SUBDIR = "archive";

    private static final String INIT_DIRECTORIES = "Initializing directories";
    private static final String DIRECTORIES_ALREADY_EXIST = "Directories already exist";
    private static final String ERROR_INIT_DIRECTORIES = "Error initializing directories";

    private final ProviderService providerService =
            (ProviderService) getServiceInterface(ProviderService.class.getSimpleName());

    @Inject
    private ParamBeanFactory paramBeanFactory;

    @Override
    public void execute(Map<String, Object> context) throws BusinessException {

        ReportDto reportDto = new ReportDto();

        String invoicesIdJobParam = getStringParam(context, INVOICES_ID_JOB_PARAM);
        String bordereauxIdJobParam = getStringParam(context, BORDEREAUX_ID_JOB_PARAM);

        if (isEmpty(invoicesIdJobParam) && isEmpty(bordereauxIdJobParam)) {
            try {
                Path inputDirectory = getInputDirectoryPath();

                if (Files.notExists(inputDirectory)) {
                    initDirectories();
                    reportDto.addReport(INIT_DIRECTORIES);
                    reportDto.addNbOK();
                } else {
                    reportDto.addReport(DIRECTORIES_ALREADY_EXIST);
                    reportDto.addNbOK();
                }

            } catch (IOException e) {
                reportDto.registerError(ERROR_INIT_DIRECTORIES);
                throw new BusinessException(ERROR_INIT_DIRECTORIES, e);
            }
        }

        flushReportInContext(context, reportDto);
    }

    private void initDirectories() throws IOException {
        Path baseDirectory = getBaseDirectoryPath();

        List<Path> directories = List.of(
                baseDirectory.resolve(INPUT_SUBDIR),
                baseDirectory.resolve(OUTPUT_SUBDIR),
                baseDirectory.resolve(REJECT_SUBDIR),
                baseDirectory.resolve(ARCHIVE_SUBDIR)
        );

        for (Path directory : directories) {
            Files.createDirectories(directory);
        }
    }

    private Path getInputDirectoryPath() {
        return getBaseDirectoryPath().resolve(INPUT_SUBDIR);
    }

    private Path getBaseDirectoryPath() {
        return Path.of(
                getProviderDir(),
                IMPORTS_DIR,
                INVOICES_DIR,
                AVOIRS_DIR
        );
    }

    private String getProviderDir() {
        String providerDir = ParamBean.getInstance()
                .getChrootDir(providerService.getProvider().getCode());

        File directory = new File(providerDir);
        if (!directory.exists()) {
            directory.mkdirs();
        }

        return providerDir;
    }

    private String getStringParam(Map<String, Object> context, String key) {
        Object value = context.get(key);
        return value != null ? value.toString().trim() : "";
    }

    private boolean isEmpty(String value) {
        return value == null || value.trim().isEmpty();
    }

    private void flushReportInContext(Map<String, Object> context, ReportDto reportDto) {
        context.put(Script.JOB_RESULT_NB_OK, reportDto.getNbOK());
        context.put(Script.JOB_RESULT_NB_KO, reportDto.getNbKO());

        if (!reportDto.getReportMessage().isEmpty()) {
            context.put(Script.JOB_RESULT_REPORT, reportDto.getReportMessage());
        }
    }

    private static class ReportDto {

        private int nbOK;
        private int nbKO;
        private final StringBuilder reportBuilder = new StringBuilder();

        public int getNbOK() {
            return nbOK;
        }

        public int getNbKO() {
            return nbKO;
        }

        public String getReportMessage() {
            return reportBuilder.toString();
        }

        public void addNbOK() {
            this.nbOK++;
        }

        public void addNbKO() {
            this.nbKO++;
        }

        public void registerError(String message) {
            addNbKO();
            addReport(message);
        }

        public void addReport(String message) {
            if (reportBuilder.length() > 0) {
                reportBuilder.append(System.lineSeparator());
            }
            reportBuilder.append(message);
        }
    }
}
