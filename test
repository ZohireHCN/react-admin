    private static class ReportDto {

        private int nbOk;
        private int nbKo;
        private int nbWarning;

        private final StringBuilder reportBuilder = new StringBuilder();

        public int getNbOk() {
            return nbOk;
        }

        public int getNbKo() {
            return nbKo;
        }

        public int getNbWarning() {
            return nbWarning;
        }

        public String getMessage() {
            return reportBuilder.toString();
        }

        public void registerOk(String message) {
            nbOk++;
            addMessage("[OK] " + message);
        }

        public void registerKo(String message) {
            nbKo++;
            addMessage("[KO] " + message);
        }

        public void registerWarning(String message) {
            nbWarning++;
            addMessage("[WARNING] " + message);
        }

        private void addMessage(String message) {
            if (reportBuilder.length() > 0) {
                reportBuilder.append(System.lineSeparator());
            }
            reportBuilder.append(message);
        }
    }
