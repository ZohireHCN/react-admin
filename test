@Override
public void execute(Map<String, Object> context) throws BusinessException {

    ReportDto report = new ReportDto();

    String invoicesParam = getStringParam(context, INVOICES_ID_JOB_PARAM);
    String bordereauxParam = getStringParam(context, BORDEREAUX_ID_JOB_PARAM);
    String motifCode = getStringParam(context, MOTIF_ID_JOB_PARAM);

    try {

        /*
         * Mode initialisation :
         * Si aucune facture et aucun bordereau ne sont fournis,
         * le job vérifie l'existence du dossier input.
         * Si input n'existe pas, toute l'arborescence est créée.
         */
        if (isEmpty(invoicesParam) && isEmpty(bordereauxParam)) {
            initializeDirectoriesIfNeeded(report);
            return;
        }

        /*
         * Mode traitement :
         * Si des factures ou des bordereaux sont fournis,
         * le job lance le traitement d'avoirisation.
         */
        Long motifId = findMotifIdByCode(motifCode);

        if (!isEmpty(invoicesParam)) {
            processInvoices(parseIds(invoicesParam), motifId, report);
        }

        if (!isEmpty(bordereauxParam)) {
            processBordereaux(parseIds(bordereauxParam), motifId, report);
        }

    } catch (Exception e) {
        report.registerKo("Erreur globale du job : " + e.getMessage());
        throw new BusinessException("Erreur traitement avoir interne", e);

    } finally {
        flushReportInContext(context, report);
    }
}
