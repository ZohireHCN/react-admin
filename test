public class InvoiceCreditNoteScript extends Script {

    private static final String INVOICES_ID_JOB_PARAM = "factures";
    private static final String BORDEREAUX_ID_JOB_PARAM = "bordereaux";
    private static final String MOTIF_ID_JOB_PARAM = "motif";

    private static final String INVOICE_TYPE_CREDIT_NOTE = "MS-AV";

    @Override
    public void execute(Map<String, Object> context) throws BusinessException {

        ReportDto report = new ReportDto();

        String invoicesParam = getStringParam(context, INVOICES_ID_JOB_PARAM);
        String bordereauxParam = getStringParam(context, BORDEREAUX_ID_JOB_PARAM);
        String motifCode = getStringParam(context, MOTIF_ID_JOB_PARAM);

        try {
            Long motifId = findMotifIdByCode(motifCode);

            if (!isEmpty(invoicesParam)) {
                processInvoices(parseIds(invoicesParam), motifId, report);
            }

            if (!isEmpty(bordereauxParam)) {
                processBordereaux(parseIds(bordereauxParam), motifId, report);
            }

        } catch (Exception e) {
            report.registerKo("Erreur globale du job : " + e.getMessage());
            throw new BusinessException("Erreur traitement avoir interne", e);

        } finally {
            flushReportInContext(context, report);
        }
    }

    /**
     * Traitement unitaire ou multiple des factures.
     */
    private void processInvoices(List<Long> invoiceIds, Long motifId, ReportDto report) {

        for (Long invoiceId : invoiceIds) {
            try {
                processSingleInvoice(invoiceId, motifId, report, false);
            } catch (Exception e) {
                report.registerKo("Facture ID " + invoiceId + " : " + e.getMessage());
            }
        }
    }

    /**
     * Traitement d’une facture :
     * 1. Vérification éligibilité
     * 2. Création avoir interne MS-AV
     * 3. Duplication lignes avec montants négatifs
     * 4. Mise à jour facture initiale
     * 5. Création matching facture / avoir
     */
    private void processSingleInvoice(
            Long invoiceId,
            Long motifId,
            ReportDto report,
            boolean fromBordereau) throws BusinessException {

        BillingInvoiceDto invoice = findInvoiceById(invoiceId);

        if (invoice == null) {
            throw new BusinessException("Facture introuvable");
        }

        if (!fromBordereau && isInvoiceAttachedToBordereau(invoiceId)) {
            throw new BusinessException("Facture déjà rattachée à un bordereau");
        }

        if (hasAlreadyInternalCreditNote(invoiceId)) {
            throw new BusinessException("Facture déjà avoirisée");
        }

        BillingInvoiceDto creditNote = createInternalCreditNote(invoice, motifId);

        duplicateRatedTransactionsWithNegativeAmounts(invoice.getId(), creditNote.getId());

        duplicateInvoiceAggregatesWithNegativeAmounts(invoice.getId(), creditNote.getId());

        updateInitialInvoiceAsCancelled(invoice.getId(), motifId);

        createInvoiceCreditNoteMatching(
                invoice.getBillingAccountId(),
                invoice.getId(),
                creditNote.getId(),
                motifId
        );

        if (fromBordereau) {
            report.registerWarning(
                    "Facture " + invoice.getInvoiceNumber()
                            + " avoirisée via bordereau"
            );
        } else {
            report.registerOk(
                    "Facture " + invoice.getInvoiceNumber()
                            + " avoirisée avec succès"
            );
        }
    }

    /**
     * Traitement des bordereaux :
     * 1. Vérification éligibilité
     * 2. Mise à jour bordereau cancelled = true
     * 3. Traitement de toutes les factures du bordereau
     */
    private void processBordereaux(List<Long> bordereauIds, Long motifId, ReportDto report) {

        for (Long bordereauId : bordereauIds) {
            try {
                processSingleBordereau(bordereauId, motifId, report);
            } catch (Exception e) {
                report.registerKo("Bordereau ID " + bordereauId + " : " + e.getMessage());
            }
        }
    }

    private void processSingleBordereau(
            Long bordereauId,
            Long motifId,
            ReportDto report) throws BusinessException {

        BordereauDto bordereau = findBordereauById(bordereauId);

        if (bordereau == null) {
            throw new BusinessException("Bordereau introuvable");
        }

        if (Boolean.TRUE.equals(bordereau.getCancelled())) {
            throw new BusinessException("Bordereau déjà avoirisé");
        }

        updateBordereauAsCancelled(bordereauId, motifId);

        List<Long> invoiceIds = findInvoiceIdsByBordereauId(bordereauId);

        for (Long invoiceId : invoiceIds) {
            processSingleInvoice(invoiceId, motifId, report, true);
        }

        report.registerOk(
                "Bordereau " + bordereau.getCode()
                        + " avoirisé avec succès"
        );
    }

