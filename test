Voici une version corrigée qui supprime vraiment les doublons, normalise les chemins Windows/Linux, et utilise git diff au lieu de git log.

package com.alpiq.maven.plugin.git;

import org.apache.maven.plugin.logging.Log;

import java.io.BufferedReader;
import java.io.File;
import java.io.InputStreamReader;
import java.nio.file.Files;
import java.nio.file.Path;
import java.util.ArrayList;
import java.util.LinkedHashMap;
import java.util.List;
import java.util.Map;

public class GitChangedFilesService {

    private final Log log;

    public GitChangedFilesService(Log log) {
        this.log = log;
    }

    public List<Path> findModifiedJavaFiles(File repoDir, int modifiedLastDays, File inputDir) {
        try {
            Path repositoryPath = repoDir.toPath().toAbsolutePath().normalize();
            Path inputPath = inputDir.toPath().toAbsolutePath().normalize();

            String relativeInputPath = repositoryPath.relativize(inputPath)
                    .toString()
                    .replace("\\", "/");

            ProcessBuilder processBuilder = new ProcessBuilder(
                    "git",
                    "diff",
                    "--name-only",
                    "HEAD@{" + modifiedLastDays + ".days.ago}",
                    "HEAD",
                    "--",
                    relativeInputPath
            );

            processBuilder.directory(repositoryPath.toFile());
            processBuilder.redirectErrorStream(true);

            Process process = processBuilder.start();

            Map<String, Path> uniqueFiles = new LinkedHashMap<>();

            try (BufferedReader reader = new BufferedReader(
                    new InputStreamReader(process.getInputStream()))) {

                String line;
                while ((line = reader.readLine()) != null) {
                    String gitPath = line.trim();

                    if (gitPath.isEmpty()) {
                        continue;
                    }

                    if (!gitPath.endsWith(".java")) {
                        continue;
                    }

                    Path absoluteFile = repositoryPath.resolve(gitPath)
                            .toAbsolutePath()
                            .normalize();

                    if (!Files.exists(absoluteFile)) {
                        continue;
                    }

                    String uniqueKey = absoluteFile.toString()
                            .replace("\\", "/")
                            .toLowerCase();

                    uniqueFiles.putIfAbsent(uniqueKey, absoluteFile);
                }
            }

            int exitCode = process.waitFor();

            if (exitCode != 0) {
                throw new IllegalStateException(
                        "Git command failed with exit code " + exitCode
                );
            }

            log.info("Modified Java files found by Git: " + uniqueFiles.size());

            return new ArrayList<>(uniqueFiles.values());

        } catch (Exception e) {
            throw new IllegalStateException(
                    "Unable to detect modified Java files using Git", e
            );
        }
    }
}

Appel côté CreatePostmanMojo :

List<Path> javaFiles = gitChangedFilesService.findModifiedJavaFiles(
        scriptsModulePath,
        modifiedLastDays,
        inputDir
);

Commande attendue :

