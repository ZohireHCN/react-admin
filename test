private void processInputLine(
        String line,
        ReportDto report,
        MeveoUser currentUser) throws BusinessException {

    String[] values = line.split(";", -1);

    if (values.length < 3) {
        throw new BusinessException(
                "Format invalide"
        );
    }

    String invoiceValue = values[0].trim();
    String bordereauValue = values[1].trim();
    String motifValue = values[2].trim();

    Long motifId = validateMotif(motifValue);

    if (!isEmpty(invoiceValue)) {

        processSingleInvoice(
                Long.valueOf(invoiceValue),
                motifId,
                report,
                false,
                currentUser
        );

        report.addNbOK();
        return;
    }

    if (!isEmpty(bordereauValue)) {

        processSingleBordereau(
                Long.valueOf(bordereauValue),
                motifId,
                report,
                currentUser
        );

        report.addNbOK();
        return;
    }

    throw new BusinessException(
            "Aucune facture ou bordereau renseigné"
    );
}


