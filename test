lib/screens/invoices_screen.dart

import 'package:flutter/material.dart';

class InvoicesScreen extends StatelessWidget {
  const InvoicesScreen({super.key});

  @override
  Widget build(BuildContext context) {
    final invoices = [
      {'month': 'Juin 2026', 'amount': '78,50 €', 'status': 'Payée'},
      {'month': 'Mai 2026', 'amount': '82,10 €', 'status': 'Payée'},
      {'month': 'Avril 2026', 'amount': '75,30 €', 'status': 'Payée'},
    ];

    return Scaffold(
      appBar: AppBar(title: const Text('Factures')),
      body: ListView.builder(
        padding: const EdgeInsets.all(16),
        itemCount: invoices.length,
        itemBuilder: (context, index) {
          final invoice = invoices[index];

          return Card(
            child: ListTile(
              leading: const Icon(Icons.receipt_long, color: Colors.green),
              title: Text(invoice['month']!),
              subtitle: Text(invoice['status']!),
              trailing: Text(invoice['amount']!),
            ),
          );
        },
      ),
    );
  }
}

