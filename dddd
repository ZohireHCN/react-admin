Le fichier est bien en UTF-8, mais Excel ouvre souvent les CSV UTF-8 sans BOM et affiche :

é => Ã©
à => Ã

Solution 1 (recommandée)

Ajouter le BOM UTF-8 :

private void writeCsvFile(Path file, List<String> lines) throws IOException {

    try (BufferedWriter writer = Files.newBufferedWriter(
            file,
            StandardCharsets.UTF_8,
            StandardOpenOption.CREATE,
            StandardOpenOption.TRUNCATE_EXISTING)) {

        writer.write('\uFEFF'); // UTF-8 BOM

        for (String line : lines) {
            writer.write(line);
            writer.newLine();
        }
    }
}

Puis :

private void writeOutputFile(Path inputFile, List<String> lines) throws IOException {

    String fileName =
            removeExtension(inputFile.getFileName().toString()) + "_output.csv";

    writeCsvFile(
            getOutputDirectoryPath().resolve(fileName),
            lines
    );
}

private void writeRejectFile(Path inputFile, List<String> lines) throws IOException {

    if (lines.size() <= 1) {
        return;
    }

    String fileName =
            removeExtension(inputFile.getFileName().toString()) + "_reject.csv";

    writeCsvFile(
            getRejectDirectoryPath().resolve(fileName),
            lines
    );
}

