private void processInputFiles(
        Long motifId,
        ReportDto report,
        MeveoUser currentUser) throws IOException {

    try (Stream<Path> files = Files.list(getInputDirectoryPath())) {
        files.filter(Files::isRegularFile)
                .forEach(file -> {
                    try {
                        processSingleInputFile(file, motifId, report, currentUser);
                    } catch (Exception e) {
                        report.addReport("Erreur traitement fichier " + file.getFileName() + " : " + e.getMessage());
                        report.addNbKO();
                    }
                });
    }
}
