    /**
     * Entry point of the profiling script.
     * <p>
     * Recognized parameters in {@code context}:
     * <ul>
     *   <li>{@code prmRefs}: semicolon-separated PRM references list (PRM mode)</li>
     *   <li>{@code rfpIds}: semicolon-separated RFP IDs list (RFP mode)</li>
     *   <li>{@code threadCount}: optional custom parallelism level</li>
     *   <li>{@code memoryLimit}: optional memory limit ratio</li>
     * </ul>
     * </p>
     * @param context Job execution context and parameters.
     * @throws BusinessException If configuration or processing fails.
     */
    @Override
    public void execute(Map<String, Object> context) throws BusinessException {
        log.info("Executing CurveProfilingScript with method {}", context);
        jobUser = ((MeveoUser) context.getOrDefault(CONTEXT_CURRENT_USER, "")).getUserName();
        automaticJobLaunch = isJobLaunchAutomatic(context);

        try {
            validateParams(context);
            retrieveConfiguration();
        } catch (BusinessException e) {
            koCounter.incrementAndGet();
            report.rep(e.getMessage());
            setJobReportData(context);
            return;
        }

        try {
            switch (profilingType) {
                case PRM:
                    prmProfiling();
                    break;
                case RFP:
                    rfpProfiling();
                    break;
                case DEFAULT:
                    defaultProfiling();
            }

            if(!prmIdsList.isEmpty()){
                prmService.selectPrmsAndupdateLoadCurveIntegration(prmIdsList, "rfd_reconstitution_status_id", RfpStatusEnum.TREATED.getId().intValue(), jobUser);
                prmService.selectPrmsAndupdateLoadCurveIntegration(prmIdsList, "rfd_average_reconstitution_status_id", RfpStatusEnum.TO_TREAT.getId().intValue(), jobUser);
            }

            updatePrmPostes();
        } catch (Exception e) {
            log.info("Error while processing curves", e);
            throw e;
        } finally {
            // Libérer le cache en fin de job pour ne pas retenir les tableaux en mémoire
            templateCache.clear();
            templateMetaCache.clear();
        }

        setJobReportData(context);
        curveService.getEntityManager().flush();
    }

