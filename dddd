        public Double getPeakAverage(boolean ignoreNulls) {
            double s=0; long cnt=0;
            for (int i=0; i<puissances.length; i++) { double v=puissances[i]; if ((!ignoreNulls||!isMissing(v))&&isPeakHour(cdcDates.get(i))) { if (!isMissing(v)) { s+=v; cnt++; } } }
