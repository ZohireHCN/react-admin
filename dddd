/**
 * Builds consumption load curves (profiling) at PRM and RFP levels.
 * <p>
 * Depending on parameters, this script can:
 * <ul>
 *   <li>Profile a list of PRMs (PRM mode)</li>
 *   <li>Profile all PRMs of one or more RFPs (RFP mode)</li>
 *   <li>Run a default profiling selection for PRMs matching eligibility criteria (DEFAULT mode)</li>
 * </ul>
 * The script reads billed meter readings, correlates profile coefficients, distributes
 * energy across temporal classes and persists computed curves. It also updates PRM
 * processing statuses and derived attributes (e.g., poste).
 * </p>
 */
public class CurveProfilingScript extends Script {
