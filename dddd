    /**
     * Loads a PRM by reference and processes it.
     *
     * @param prmRef PRM reference.
     * @throws BusinessException On processing errors.
     * @throws ObjectNotFoundException If the PRM cannot be found.
     * @throws NoMeasuresFoundException If no eligible measures are found for the PRM.
     */
    private void processPrm(String prmRef) throws BusinessException, ObjectNotFoundException, NoMeasuresFoundException {
        Prm prm;

        try {
            prm = prmService.getEntityManager().createQuery("select prm from Prm prm where reference = :reference", Prm.class)
                    .setParameter("reference", prmRef)
                    .getSingleResult();
        } catch (Exception e) {
            throw new ObjectNotFoundException("PRM non trouvé : " + prmRef);
        }

        processPrm(prm);
    }


