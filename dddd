                .forEach(m -> handleUnitMR(prm, cdcMap, m, targetClasses, profileMap));
    }

    private void handleUnitMR(Prm prm, Map<String, Cdc> cdcMap, MeterReading mr, List<String> targetClasses, Map<String, Cdc> profileMap) {
        if (!validateMeterReading(mr)) {
            warnCounter.incrementAndGet();
            report.rep(String.format("Classes temporelles manquantes pour le prm %s sur la période %s - %s : %s",
                    prm.getReference(),
                    mr.getStartDate().format(DATE_FORMATTER),
                    mr.getEndDate().format(DATE_FORMATTER),
                    getMissingTempClasses(mr, targetClasses)));
            return;
        }
        targetClasses.stream().parallel().forEach(tempClassTarget -> {
            try {
                handleMeterReading(prm, mr, cdcMap, tempClassTarget, profileMap);
            } catch (ProfileCoeffNotFound e) {
                log.info("Profile not found for PRM {}, temporal class {} and period {} to {}",
                        prm.getReference(), tempClassTarget,
                        mr.getStartDate().format(DATE_FORMATTER), mr.getEndDate().format(DATE_FORMATTER));
            } catch (Exception e) {
                throw e;
            }
        });
    }

    private String getMissingTempClasses(MeterReading mr, List<String> targetClasses) {
        List<String> missingClasses = new ArrayList<>();
        for (String targetClass : targetClasses) {
            if (!mr.getBmrList().containsKey(targetClass)) {
                missingClasses.add(targetClass);
            }
        }
        return String.join(", ", missingClasses);

    }

    private boolean validateMeterReading(MeterReading mr) {
        String classCat = mr.getTemporalCat();

        switch (classCat) {
            case "HPHC":
                return mr.getBmrList().size() == 2;
            case "SAISON":
                return mr.getBmrList().size() == 4;
            default:
                return true;
        }
    }

    private void saveCurves(Prm prm, Map<String, Cdc> cdcMap, String targetClassCat) {
        Map<String, BilledCurve> bcMap = billedCurveService.getEntityManager().createQuery("select bc from BilledCurve bc " +
                        "where bc.prm = :prm and bc.curve.curveTypeId = :getC5lisse", BilledCurve.class)
                .setParameter("prm", prm)
                .setParameter("getC5lisse", getCurveTypeEnum().getId())
                .getResultList().stream()
                .collect(Collectors.toMap(BilledCurve::getTemporalClass, bc -> bc));
        for (Map.Entry<String, Cdc> entryCdc : cdcMap.entrySet()) {
            if (bcMap.get(entryCdc.getKey()) != null && getTemporalCat(entryCdc.getKey()).equals(targetClassCat)) {
                Cdc bcCdc = new Cdc(bcMap.get(entryCdc.getKey()).getCurve());
                bcCdc.mergeCdcAndIgnoreDiscontinuity(entryCdc.getValue());
                bcCdc.getCurve().getBinaryCurve().setData(Cdc.convertDoublesToBytes(bcCdc.getCdcPuissances()));
                bcMap.get(entryCdc.getKey()).setHistoricalAnnualEnergyVolume(bcCdc.calculateHistoricalAnnualEnergyVolume());

                curveService.update(bcCdc.getCurve(), jobUser);
                billedCurveService.update(bcMap.get(entryCdc.getKey()), jobUser);
            } else {
                if (bcMap.get(entryCdc.getKey()) != null) {
                    billedCurveService.deletePrmCurveByTC(prm, entryCdc.getKey());
                }
                BilledCurve bc = new BilledCurve();
                bc.setPrm(prm);
                bc.setTemporalClass(entryCdc.getKey());
                entryCdc.getValue().getCurve().getBinaryCurve().setData(Cdc.convertDoublesToBytes(entryCdc.getValue().getCdcPuissances()));
                bc.setHistoricalAnnualEnergyVolume(entryCdc.getValue().calculateHistoricalAnnualEnergyVolume());
                // Grouper les 2 opérations de création dans une seule transaction
                curveService.create(entryCdc.getValue().getCurve(), jobUser);
                bc.setCurve(entryCdc.getValue().getCurve());
                billedCurveService.create(bc, jobUser);
            }
        }
        bcMap.forEach((k, v) -> {
            if (!cdcMap.containsKey(k)) {
                billedCurveService.deletePrmCurveByTC(prm, k);
            }
        });
        bcMap.clear();
    }

    private void handleMeterReading(Prm prm, MeterReading mr, Map<String, Cdc> cdcMap, String tempClassTarget, Map<String, Cdc> profileMap) throws ProfileCoeffNotFound {
        String subProfile = getSubProfile(prm, tempClassTarget);
        Cdc cdc = cdcMap.getOrDefault(tempClassTarget, null);

        Cdc profileCdc = loadProfileData(subProfile, profileMap);
        Cdc profileData;
        try {
            ZonedDateTime startDate = mr.getStartDate();
            ZonedDateTime endDate = mr.getStartDate().isEqual(mr.getEndDate()) ?
                    mr.getEndDate().plusDays(1).minusMinutes(StepEnum.Horaire.getDurationInMinutes()) :
                    mr.getEndDate().minusMinutes(StepEnum.Horaire.getDurationInMinutes());
            if (startDate.isBefore(profileCdc.getCdcDateDebut()) || endDate.isAfter(profileCdc.getCdcDateFin())) {
                throw new ProfileCoeffNotFound("Date de début ou de fin non trouvée dans le profil");
            }

            profileData = profileCdc.getReducedCdc(startDate, endDate);

            if(profileData.countIf(null) > 0) {
                throw new ProfileCoeffNotFound("Le sous-profil contient des valeurs nulles");
            }
        } catch (Exception e) {
            log.error("Profile coeff not found for sub-profile {}", subProfile, e);
            throw new ProfileCoeffNotFound(e.getMessage());
        }

        CurveTypeEnum curveTypeEnum = getCurveTypeEnum();
        profileData.getCurve().setCurveType(curveTypeEnum);
        profileData.getCurve().setDescription(curveTypeEnum.name());

        Double eP = mr.getEp(tempClassTarget, subProfileCoefficients);
        Double coeffSum = profileData.getSum();
        Double fu = coeffSum == 0 ? 0D : eP / coeffSum;
 //       if(mr.getStartDate().toLocalDateTime().isAfter(LocalDateTime.of(2024, 7,30, 0, 0, 0))){
      //      report.rep(prm.getReference() + " | " + subProfile + " | " + eP + " | " + coeffSum + " | " + fu + " | " + mr.getStartDate().toLocalDate() + " | " + mr.getEndDate().toLocalDate());
  //      }
        log.debug("{} | {} | {} | {} | {} | {}", prm.getReference(), subProfile, fu, coeffSum, mr.getStartDate(), mr.getEndDate());
        // report.rep("valeur de la courbe AVANT multiplication, de l'heure : " + profileData.getCdcDates().get(3).toLocalDateTime() + " est " + profileData.getCdcPuissances().get(3));
        profileData.multiplyBy(fu);
        // report.rep("valeur de la courbe APRES multiplication, de l'heure : " + profileData.getCdcDates().get(3).toLocalDateTime() + " est " + profileData.getCdcPuissances().get(3));
        if (cdc == null) {
            cdcMap.put(tempClassTarget, profileData);
        } else {
            cdcMap.get(tempClassTarget).mergeCdcAndIgnoreDiscontinuity(profileData);
            cdcMap.get(tempClassTarget).getCurve().getBinaryCurve().setData(
                    Cdc.convertDoublesToBytes(cdcMap.get(tempClassTarget).getCdcPuissances()));
        }
    }

    @NotNull
    private CurveTypeEnum getCurveTypeEnum() {
        return C5_LISSE_DISABLED.equals(getC5Lisse) ? CurveTypeEnum.CDC_PROFILE : CurveTypeEnum.CDC_PROFILE_LISSE;
    }

    private Cdc loadProfileData(String subProfile, Map<String, Cdc> profileMap) {
        if (profileMap.containsKey(subProfile)) {
            return profileMap.get(subProfile);
        }

        try {
            final List<Curve>[] curves = new List[]{curveService.getEntityManager().createQuery("select c from Curve c " +
                            "where c.description = :descriptionAjuste or c.description = :descriptionDynamique", Curve.class)
                    .setParameter("descriptionAjuste", subProfile.toUpperCase() + "_COEFF_AJUSTE")
                    .setParameter("descriptionDynamique", subProfile.toUpperCase() + "_COEFF_DYNAMIQUE")
                    .setMaxResults(2)
                    .getResultList()};

            final Cdc[] adjustedCdc = new Cdc[1];
            final Cdc[] dynamicCdc = new Cdc[1];

            curves[0].forEach(curve -> {
                curveService.getEntityManager().detach(curve);
                if (curve.getDescription().endsWith("_AJUSTE")) {
                    adjustedCdc[0] = new Cdc(curve.getStep(), curve.getStartDate(), curve.getEndDate(), null);
                    adjustedCdc[0].setCdcPuissances(Cdc.convertBytesToDoubles(curve.getBinaryCurve().getData()));
                    adjustedCdc[0] = Cdc.changerPas(adjustedCdc[0], StepEnum.Horaire);
                } else if (curve.getDescription().endsWith("_DYNAMIQUE")) {
                    dynamicCdc[0] = new Cdc(curve.getStep(), curve.getStartDate(), curve.getEndDate(), null);
                    dynamicCdc[0].setCdcPuissances(Cdc.convertBytesToDoubles(curve.getBinaryCurve().getData()));
                    dynamicCdc[0] = Cdc.changerPas(dynamicCdc[0], StepEnum.Horaire);
                }
            });

            adjustedCdc[0].mergeCdcAndIgnoreDiscontinuity(dynamicCdc[0]);

            profileMap.put(subProfile, adjustedCdc[0]);
            return adjustedCdc[0];
        } catch (Exception e) {
            log.error("Profile coeff not found for sub-profile {}", subProfile, e);
            throw new ProfileCoeffNotFound("Profile coeff not found for sub-profile " + subProfile);
        }
    }

