    public Long countIf(Double value, ZonedDateTime start, ZonedDateTime end) {
        int startIndex = getReducedStartDateIndex(start);
        int endIndex = getReducedEndDateIndex(end);
        double expected = toPrimitive(value);
        long count = 0L;
        for (int i = startIndex; i <= endIndex; i++) {
            if ((isMissing(expected) && isMissing(cdcPuissances[i])) || Double.compare(cdcPuissances[i], expected) == 0) {
                count++;
            }
        }
        return count;
    }

    public Long count(ZonedDateTime start, ZonedDateTime end, boolean ignoreNulls) {
        int startIndex = getReducedStartDateIndex(start);
        int endIndex = getReducedEndDateIndex(end);
        long count = 0L;
        for (int i = startIndex; i <= endIndex; i++) {
            if (!ignoreNulls || !isMissing(cdcPuissances[i])) {
                count++;
            }
        }
        return count;
    }

