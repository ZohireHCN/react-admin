    /**
     * Adds a PRM ID to the internal map keyed by poste in a thread-safe manner.
     * @param prmId PRM identifier.
     * @param poste Poste value resolved for the PRM.
     */
    private synchronized void addPrmToPosteMap(Long prmId, String poste){
        prmIdsByPoste.computeIfAbsent(poste, k -> new ArrayList<>()).add(prmId);
    }

    private void updatePrmPostes() {
        for (Map.Entry<String, List<Long>> entry : prmIdsByPoste.entrySet()) {
            try {
                prmService.getEntityManager()
                        .createQuery("update Prm prm set prm.poste = :poste where prm.id in :prmIds")
                        .setParameter("poste",  entry.getKey())
                        .setParameter("prmIds", entry.getValue())
                        .executeUpdate();
            } catch (Exception e) {
                throw new BusinessException("Error while updating prm postes {}" + e.getMessage(), e);
            }
        }
    }

    /**
     * Resolves the poste for a PRM, using its sub-profile or deducing it from the latest
     * temporal class and the mapping rules.
     * @param prm PRM entity.
     * @return Poste value.
     * @throws BusinessException If poste cannot be determined.
     */
    private String getPrmPoste(Prm prm) {
        String subProfile;

        if(prm.getSubProfile() == null || prm.getSubProfile().isBlank()) {
            String tempClass = getPosteTemporalClass(prm);
            if("PRO5_BASE_TEMPORAL_CLASS".equals(tempClass)) {
                subProfile = "PRO5_BASE";
            }else {
                subProfile = getSubProfileMapping(tempClass);
            }
        } else {
            subProfile = prm.getSubProfile();
        }

        int underscoreIndex = subProfile.indexOf('_');
        if(underscoreIndex == -1) {
            throw new BusinessException("Unable to identify poste for prm "+ prm.getReference());
        }
        return subProfile.substring(0, underscoreIndex);
    }

    /**
     * Retrieves the most recent temporal class observed for a PRM, across calendars,
     * with precedence rules :
     * 1) (Fournisseur && temporalClass = BASE && usageContext in ('UPIN', 'ECPU')
     * 2) (Fournisseur over Distributeur, Réel over Estimé).
     * @param prm PRM entity.
     * @return Temporal class string or empty when unavailable.
     */
    private String getPosteTemporalClass(Prm prm) {
        try {
            String temporalClass = bmrService.getEntityManager().createQuery("select temporalClass from BilledMeterReading " +
                            "where calendar = 'Fournisseur' and prm.id = :prmId order by endDate desc", String.class)
                    .setParameter("prmId", prm.getId())
                    .setMaxResults(1)
                    .getSingleResult();

            if("BASE".equals(temporalClass)){
                ContractualSituation contractualSituation = contractualSituationService.getEntityManager()
                        .createQuery("select cs from ContractualSituation cs " +
                                "where cs.enedisContractualData.prm.id = :prmId " +
                                "and cs.usageContext in ('UPIN', 'ECPU')", ContractualSituation.class)
                        .setParameter("prmId", prm.getId())
                        .setMaxResults(1)
                        .getSingleResult();

                if(contractualSituation != null){
                    return "PRO5_BASE_TEMPORAL_CLASS";
                }
                return getTemporalClassOfLastBilledMeterReading(prm);
            }
            return getTemporalClassOfLastBilledMeterReading(prm);

        } catch (Exception e) {
            return getTemporalClassOfLastBilledMeterReading(prm);
        }
    }


    private String getTemporalClassOfLastBilledMeterReading(Prm prm) {
        try {
            return bmrService.getEntityManager().createQuery("select temporalClass from BilledMeterReading " +
                            "where prm.id = :prmId order by endDate desc, case when calendar = 'Fournisseur' then 1 " +
                            "when calendar = 'Distributeur' then 2 else 3 end, " +
                            "case when measureName = 'Réel' then 1 when measureName = 'Estimé' then 2 else 3 end", String.class)
                    .setParameter("prmId", prm.getId())
                    .setMaxResults(1)
                    .getSingleResult();
        } catch (Exception e) {
            log.info("Unable to find temporal class for PRM {} : {}", prm.getReference(), e.getMessage(), e);
            return EMPTY_STRING;
        }
    }

    /**
     * Retrieves the temporal class of the latest Fournisseur measure for a PRM.
     * @param prm PRM entity.
     * @return Temporal class string.
     * @throws BusinessException If no Fournisseur measure is available.
     */
    private String getLastFournisseurMeasureTemporalClass(Prm prm) {
        String result = bmrService.getEntityManager().createQuery("select bmr.temporalClass from BilledMeterReading bmr " +
                        "where bmr.prm.id = :prmId and bmr.calendar = :calendar and bmr.measureName != :estimated " +
                        "order by bmr.endDate desc", String.class)
                .setParameter("prmId", prm.getId())
                .setParameter("calendar", "Fournisseur")
                .setParameter("estimated", "Estimé")
                .getResultStream().findFirst().orElse(null);

        if(result == null) {
            throw new BusinessException("Unable to find last measure for prm "+ prm.getReference());
        }

        if(result.equals("HCB") || result.equals("HCE") || result.equals("HPB") || result.equals("HPE")) {
            result = result.replace("B", "E");
        }

        return result;
    }

    private String getPrmTargetClass(Prm prm, String defaultTemporalClass) {
        if(prm.getSubProfile() == null || prm.getSubProfile().isBlank()) {
            return MeterReading.getTemporalCat(defaultTemporalClass);
        } else if(prm.getSubProfile().endsWith("BASE")){
            return "BASE";
        } else if (prm.getSubProfile().endsWith("HP") || prm.getSubProfile().endsWith("HC")) {
            return "HPHC";
        } else if (prm.getSubProfile().contains("HP") || prm.getSubProfile().contains("HC")) {
            return "SAISON";
        } else {
            throw new BusinessException("Not-supported sub-profile "+prm.getSubProfile()+" for "+prm.getReference());
        }
    }

    private Double getPrmPS(Prm prm) {
