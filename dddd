    private static double toPrimitive(Double value) {
        return value == null ? Double.NaN : value;
    }

    private static Double toWrapper(double value) {
        return Double.isNaN(value) ? null : value;
    }

    private static double[] toPrimitiveArray(List<Double> values) {
        if (values == null) {
            return new double[0];
        }
        double[] result = new double[values.length];
        for (int i = 0; i < values.length; i++) {
            result[i] = toPrimitive(values.get(i));
        }
        return result;
    }

    private static List<Double> toWrapperList(double[] values) {
        List<Double> result = new ArrayList<>(values == null ? 0 : values.length);
        if (values != null) {
            for (double value : values) {
                result.add(toWrapper(value));
            }
        }
        return result;
    }

    private static double[] slice(double[] source, int fromInclusive, int toInclusive) {
        return Arrays.copyOfRange(source, fromInclusive, toInclusive + 1);
    }


    public CdcOpti(List<ZonedDateTime> dates, List<Double> puissances) {
        this(dates, toPrimitiveArray(puissances));
    }

    public CdcOpti(List<ZonedDateTime> dates, double[] puissances) {
        checkDiscontinuity(dates);

        if(dates.size() != puissances.length) {
            throw new BusinessException("Dates and puissances arrays should have the same size");
        }

        remplirCdc(cdcPas, dates.get(0), dates.get(dates.size() - 1));
        cdcDates = dates;
        cdcPuissances = Arrays.copyOf(puissances, puissances.length);
        if(curve != null && curve.getBinaryCurve() != null) {
            curve.getBinaryCurve().setData(convertDoublesToBytes(cdcPuissances));
        }
    }

    private void checkDiscontinuity(List<ZonedDateTime> dates) {
        if(dates.size() < 2) {
            throw new BusinessException("Not enough dates to determine step");
        }
        cdcPas = getStepEnum(dates.get(1), dates.get(0));

        if(cdcPas == StepEnum.Journalier) {
            for(int i = 1 ; i < dates.size() ; i++){
                if(!dates.get(i-1).plusDays(1).isEqual(dates.get(i))) {
                    StringBuilder message = new StringBuilder("Discontinuity in dates for the period ")
                            .append(dates.get(0).toLocalDate())
                            .append(" to ")
                            .append(dates.get(dates.size()-1).toLocalDate());
                    if (curve != null && curve.getCurveType() != null) message.append(" for ").append(curve.getCurveType());
                    throw new BusinessException(message.toString());
                }
            }
            return;
        }

        int n = calculerNbPtsParHeure(cdcPas);
        // check if there is a discontinuity in the dates
        for (int i = 1; i < dates.size(); i++) {
            if (ChronoUnit.MINUTES.between(dates.get(i - 1), dates.get(i)) != 60 / n) {
                StringBuilder message = new StringBuilder("Discontinuity in dates for the period ")
                        .append(dates.get(0).toLocalDate())
                        .append(" to ")
                        .append(dates.get(dates.size()-1).toLocalDate());
                if (curve != null && curve.getCurveType() != null) message.append(" for ").append(curve.getCurveType());
                throw new BusinessException(message.toString());
            }
        }
    }

