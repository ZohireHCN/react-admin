    public static void calculateCurveTotals(Curve inpCurve){
        if(inpCurve == null || inpCurve.getCurveType() != CurveTypeEnum.CDC) {
            return;
        }

        Cdc cdc = new Cdc(inpCurve);

        inpCurve.setTotalVolume(cdc.getSum()/calculerNbPtsParHeure(cdc.getCdcPas()));
        inpCurve.setAnnualVolume(cdc.getSumLastYear()/calculerNbPtsParHeure(cdc.getCdcPas()));
    }

    public void calculateCurveTotals() {
        if(curve != null && curve.getCurveType() == CurveTypeEnum.CDC) {
            curve.setTotalVolume(getSum()/calculerNbPtsParHeure(cdcPas));
            curve.setAnnualVolume(getSumLastYear()/calculerNbPtsParHeure(cdcPas));
        }
    }

    public Double calculateHistoricalAnnualEnergyVolume(){
        boolean hasEnoughHistory = cdcDateFin.isAfter(cdcDateDebut.plusDays(395));
        if(hasEnoughHistory){
            return getSum(cdcDateFin.minusDays(395).withHour(0).withMinute(0), cdcDateFin.minusDays(30)) / calculerNbPtsParHeure(cdcPas);
        } else {
            double ratio = (double) 365 / ChronoUnit.DAYS.between(cdcDateDebut, cdcDateFin);
            return getSum() / calculerNbPtsParHeure(cdcPas) * ratio;
        }
    }

