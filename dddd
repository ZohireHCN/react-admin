    public void mergeCdc(CdcOpti cdcOpti, boolean overwrite) {
        double[] newCoeffs = cdcOpti.getCdcPuissances();
        double[] existingCoeffs = this.cdcPuissances;
        List<ZonedDateTime> newDates = cdcOpti.getCdcDates();
        List<ZonedDateTime> existingDates = this.cdcDates;

        if (!Objects.equals(cdcPas.getId(), cdcOpti.getCdcPas().getId())) {
            unifyStep(this, cdcOpti);
            newCoeffs = cdcOpti.getCdcPuissances();
            existingCoeffs = this.cdcPuissances;
            newDates = cdcOpti.getCdcDates();
            existingDates = this.cdcDates;
        }

        if (!datesAreContinuous(cdcOpti)) {
            throw new BusinessException("Discontinuous dates detected.");
        }

        List<Double> mergedCoeffsList = new ArrayList<>();
        List<ZonedDateTime> mergedDates = new ArrayList<>();
        int newIndex = 0;
        int existingIndex = 0;

        while (newIndex < newDates.size() && existingIndex < existingDates.size()) {
            ZonedDateTime newDate = newDates.get(newIndex);
            ZonedDateTime existingDate = existingDates.get(existingIndex);

            if (newDate.isBefore(existingDate)) {
                mergedDates.add(newDate);
                mergedCoeffsList.add(toWrapper(newCoeffs[newIndex]));
                newIndex++;
            } else if (newDate.isAfter(existingDate)) {
                mergedDates.add(existingDate);
                mergedCoeffsList.add(toWrapper(existingCoeffs[existingIndex]));
                existingIndex++;
            } else {
                mergedDates.add(newDate);
                if((overwrite && !isMissing(newCoeffs[newIndex])) || isMissing(existingCoeffs[existingIndex])) {
                    mergedCoeffsList.add(toWrapper(newCoeffs[newIndex]));
                } else {
                    mergedCoeffsList.add(toWrapper(existingCoeffs[existingIndex]));
                }
                newIndex++;
                existingIndex++;
            }
        }

        while (newIndex < newDates.size()) {
            mergedDates.add(newDates.get(newIndex));
            mergedCoeffsList.add(toWrapper(newCoeffs[newIndex]));
            newIndex++;
        }

        while (existingIndex < existingDates.size()) {
            mergedDates.add(existingDates.get(existingIndex));
            mergedCoeffsList.add(toWrapper(existingCoeffs[existingIndex]));
            existingIndex++;
        }

        double[] mergedCoeffs = toPrimitiveArray(mergedCoeffsList);
        this.cdcDates = mergedDates;
        this.cdcPuissances = mergedCoeffs;
        this.curve.getBinaryCurve().setData(convertDoublesToBytes(mergedCoeffs));
        setStartEndDates();
        reconstruireDates();
        this.cdcPuissances = mergedCoeffs;
        calculateCurveTotals();
    }

