        public static boolean isPeakHour(ZonedDateTime date) {
            int h=date.withZoneSameInstant(currentZoneId).getHour(), dw=date.withZoneSameInstant(currentZoneId).getDayOfWeek().getValue();
            return h>=8 && h<20 && dw>=1 && dw<=5;
        }

