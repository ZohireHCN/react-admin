    /**
     * Étape 5 : lettrage AO facture initiale avec AO avoir interne.
     */
    private void matchCreditNoteWithInitialInvoice(
            Long creditNoteAccountOperationId,
            Long initialInvoiceAccountOperationId) throws BusinessException {

        /*
         * TODO :
         * Brancher ici le service réel :
         *
         * POST /accountOperation/matchOperations
         *
         * avec les deux AO :
         * - creditNoteAccountOperationId
         * - initialInvoiceAccountOperationId
         */

        throw new BusinessException(
                "TODO lettrage AO avoir interne "
                        + creditNoteAccountOperationId
                        + " avec AO facture initiale "
                        + initialInvoiceAccountOperationId
        );
    }

    private Long toLong(Object value) {
        if (value == null) {
            return null;
        }

        if (value instanceof Number) {
            return ((Number) value).longValue();
        }

        return Long.valueOf(value.toString());
    }

    private BigDecimal toBigDecimal(Object value) {
        if (value == null) {
            return BigDecimal.ZERO;
        }

        if (value instanceof BigDecimal) {
            return (BigDecimal) value;
        }

        if (value instanceof Number) {
            return BigDecimal.valueOf(((Number) value).doubleValue());
        }

        return new BigDecimal(value.toString());
    }

    private String getString(Object value) {
        return value != null ? value.toString() : null;
    }

    private void flushReportInContext(
            Map<String, Object> context,
            ReportDto reportDto) {

        context.put(Script.JOB_RESULT_NB_OK, reportDto.getNbOK());
        context.put(Script.JOB_RESULT_NB_KO, reportDto.getNbKO());
        context.put(Script.JOB_RESULT_NB_WARN, reportDto.getNbWARN());

        if (!reportDto.getReportMessage().isEmpty()) {
            context.put(
                    Script.JOB_RESULT_REPORT,
                    reportDto.getReportMessage()
            );
        }
    }

    private static class CreditNoteAoDto {

        private final Long accountOperationId;
        private final Long invoiceId;

        CreditNoteAoDto(
                Long accountOperationId,
                Long invoiceId) {

            this.accountOperationId = accountOperationId;
            this.invoiceId = invoiceId;
        }

        public Long getAccountOperationId() {
            return accountOperationId;
        }

        public Long getInvoiceId() {
            return invoiceId;
        }
    }

    private static class AccountOperationDto {

        private final Long accountOperationId;
        private final String matchingStatus;
        private final BigDecimal matchingAmount;

        AccountOperationDto(
                Long accountOperationId,
                String matchingStatus,
                BigDecimal matchingAmount) {

            this.accountOperationId = accountOperationId;
            this.matchingStatus = matchingStatus;
            this.matchingAmount = matchingAmount;
        }

        public Long getAccountOperationId() {
            return accountOperationId;
        }

        public String getMatchingStatus() {
            return matchingStatus;
        }

        public BigDecimal getMatchingAmount() {
            return matchingAmount;
        }
    }

    private static class ReportDto {

        private int nbOK;
        private int nbKO;
        private int nbWARN;

        private final StringBuilder reportBuilder = new StringBuilder();

        public int getNbOK() {
            return nbOK;
        }

        public int getNbKO() {
            return nbKO;
        }

        public int getNbWARN() {
            return nbWARN;
        }

        public String getReportMessage() {
            return reportBuilder.toString();
        }

        public void addNbOK() {
            this.nbOK++;
        }

        public void addNbKO() {
            this.nbKO++;
        }

        public void addNbWARN() {
            this.nbWARN++;
        }

        public void addReport(String message) {
            if (reportBuilder.length() > 0) {
                reportBuilder.append(System.lineSeparator());
            }

            reportBuilder.append(message);
        }
    }
}
