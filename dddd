    // ── Cache des templates de sous-profils ──────────────────────────────────

    /**
     * Clé de cache : identifie un template de sous-profil de façon unique.
     *
     * <p>On combine le nom du sous-profil et le pas horaire cible (toujours
     * {@link StepEnum#Horaire} après normalisation) pour éviter de stocker
     * plusieurs versions d'un même template à des pas différents.</p>
     */
    private static final class TemplateKey {
        final String   subProfile;
        final StepEnum step;

        TemplateKey(String subProfile, StepEnum step) {
            this.subProfile = subProfile;
            this.step       = step;
        }

        @Override
        public boolean equals(Object o) {
            if (this == o) return true;
            if (!(o instanceof TemplateKey)) return false;
            TemplateKey k = (TemplateKey) o;
            return subProfile.equals(k.subProfile) && step == k.step;
        }

        @Override
        public int hashCode() {
            return 31 * subProfile.hashCode() + step.hashCode();
        }
    }

    /**
     * Cache de templates au niveau du job (partagé entre tous les threads).
     *
     * <p>Valeur : tableau primitif {@code double[]} <strong>en lecture seule</strong>.
     * Toute modification doit passer par {@link Arrays#copyOf} ou
     * {@link CdcOptimized#getReducedCdc} qui produit déjà une copie indépendante.</p>
     *
     * <p>Cycle de vie : créé au démarrage du job, vidé après {@link #execute}.</p>
     */
    private final transient ConcurrentHashMap<TemplateKey, double[]> templateCache = new ConcurrentHashMap<>();

    /**
     * Métadonnées du template (pas, dates de début/fin) associées à chaque clé.
     * Nécessaires pour construire le {@link CdcOptimized} à partir du {@code double[]} mis en cache.
     */
    private final transient ConcurrentHashMap<TemplateKey, TemplateMeta> templateMetaCache = new ConcurrentHashMap<>();

    /** Métadonnées du template stockées séparément du tableau de données. */
    private static final class TemplateMeta {
        final StepEnum       step;
        final ZonedDateTime  startDate;
        final ZonedDateTime  endDate;

        TemplateMeta(StepEnum step, ZonedDateTime startDate, ZonedDateTime endDate) {
            this.step      = step;
            this.startDate = startDate;
            this.endDate   = endDate;
        }
    }
