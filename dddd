private void executeUpdate(EntityManager em, String query, Long operationTraitementId) {
    em.createNativeQuery(query)
            .setParameter("operationTraitementId", operationTraitementId)
            .executeUpdate();
    em.flush();
}

private void executeUpdate(EntityManager em, String query) {
    em.createNativeQuery(query).executeUpdate();
    em.flush();
}
