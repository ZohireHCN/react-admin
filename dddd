     * Port de IsPic(Cdc, Cdc, DateTime, Dictionary, bool) C#.
     */
    public static boolean isPic(CdcOpti cible, CdcOpti source, LocalDate jourCible, Map<LocalDate, LocalDate> ciblesource, boolean jPlus7Avant) {
        try {
            LocalDate joursource = ciblesource.get(jourCible);
            LocalDateTime js1 = joursource.minusDays(1).atStartOfDay();
            LocalDateTime js2 = joursource.plusDays(1).atStartOfDay();
            LocalDateTime js3 = source.trouverJourDeRemplacement(ZonedDateTime.of(joursource.atStartOfDay(), currentZoneId), jPlus7Avant).toLocalDateTime();
            return isPic(source, ZonedDateTime.of(js1, currentZoneId), ZonedDateTime.of(js2, currentZoneId), ZonedDateTime.of(js3, currentZoneId));
        } catch (Exception e) {
            return false;
        }
    }

    // ── TrouverJourDeRemplacement ─────────────────────────────────────────────
    /**
     * Cherche le premier jour de remplacement valide (ni férié, ni manquant)
     * en s'écartant progressivement de {@code jour} par semaines de 7 jours.
     * Port de TrouverJourDeRemplacement() C#.
     */
    public ZonedDateTime trouverJourDeRemplacement(ZonedDateTime jour, boolean jPlus7Avant) {
        ZonedDateTime retour = jour;
        boolean ok = false, stop = false;
        ZonedDateTime d1 = jour, d2 = jour;

        while (!ok && !stop) {
            d1 = d1.minusDays(7);
            d2 = d2.plusDays(7);

            int ind1 = testIndex(d1);
            int ind2 = testIndex(d2);

            if (jPlus7Avant) {
                if (isValide(ind2) && !isMqt(ind2, false) && !isFerie(d2.toLocalDateTime().minus(this.calculerIntervalle(this.cdcPas)))) {
                    retour = this.cdcDates.get(ind2); ok = true;
                } else if (isValide(ind1) && !isMqt(ind1, false) && !isFerie(d1.toLocalDateTime().minus(this.calculerIntervalle(this.cdcPas)))) {
                    retour = this.cdcDates.get(ind1); ok = true;
                }
            } else {
                if (isValide(ind1) && !isMqt(ind1, false) && !isFerie(d1.toLocalDateTime().minus(this.calculerIntervalle(this.cdcPas)))) {
                    retour = this.cdcDates.get(ind1); ok = true;
                } else if (isValide(ind2) && !isMqt(ind2, false) && !isFerie(d2.toLocalDateTime().minus(this.calculerIntervalle(this.cdcPas)))) {
                    retour = this.cdcDates.get(ind2); ok = true;
                }
            }
            stop = !(isValide(ind1) || isValide(ind2));
        }
        return retour;
    }

    public boolean isValide(int idx) {
        return idx >= 0 && idx < this.cdcPuissances.length;
    }

    public boolean isMqt(int idx, boolean inclureZero) {
        if (!isValide(idx)) return true;
        if (inclureZero) return isMissing(this.cdcPuissances[idx]) || this.cdcPuissances[idx] == 0.0;
        return isMissing(this.cdcPuissances[idx]);
    }

    private static double maxJour(CdcOpti source, ZonedDateTime jourDebut) {
        Duration interv = source.calculerIntervalle(source.getCdcPas());
        CdcOpti jour = source.recopier().projectCdc(
                jourDebut.plus(interv),
                jourDebut.plusDays(1),
                source.getCdcPas());
        if (jour == null) return Double.NEGATIVE_INFINITY;
        double max = Double.NEGATIVE_INFINITY;
        for (double v : jour.getCdcPuissances()) if (!CdcOpti.isMissing(v)) max = Math.max(max, v);
        return max;
    }

    /** Vrai si {@code d} est le dernier dimanche de mars (jour de passage heure été). */
    public static boolean isMarsDebutEte(ZonedDateTime d) {
        return d.getMonthValue() == 3
                && d.getDayOfWeek() == DayOfWeek.SUNDAY
                && d.plusDays(7).getMonthValue() == 4;
    }

    /** Vrai si {@code d} est le dernier dimanche d'octobre (jour de passage heure hiver). */
    public static boolean isOctobreFinEte(ZonedDateTime d) {
        return d.getMonthValue() == 10
                && d.getDayOfWeek() == DayOfWeek.SUNDAY
                && d.plusDays(7).getMonthValue() == 11;
    }


    public static boolean isMissing(Double v) { return v == null || Double.isNaN(v); }

    public static boolean isMissing(double v) { return Double.isNaN(v); }

    /** Compte le nombre de points appartenant au même jour que dates[startIdx]. */
    public static int countPointsInDay(CdcOpti cdcOpti, int startIdx) {
        if (startIdx >= cdcOpti.cdcDates.size()) return 0;
        LocalDate jour = cdcOpti.cdcDates.get(startIdx).minus(cdcOpti.calculerIntervalle(cdcOpti.cdcPas)).toLocalDate();
        int count = 0;
        for (int i = startIdx; i < cdcOpti.cdcDates.size(); i++) {
            if (cdcOpti.cdcDates.get(i).minus(cdcOpti.calculerIntervalle(cdcOpti.cdcPas)).toLocalDate().equals(jour)) count++;
            else break;
        }
        return count;
    }

    // ── Corriger les valeurs manquantes ──────────────────────────────────────

    public void corrigerValeursNulles(boolean inclureValeurZero) {
        Duration interv = this.calculerIntervalle(this.cdcPas);
        for (int i = 0; i < this.cdcDates.size(); i++) {
            if (isMqt(i, inclureValeurZero)) {
                if (!isFerie(this.cdcDates.get(i).toLocalDateTime().minus(interv))) {
                    this.cdcPuissances[i] = corrigerValeurManquante(i, inclureValeurZero);
                } else {
                    this.cdcPuissances[i] = corrigerValeurManquanteFerie(i, inclureValeurZero);
                }
            }
        }
    }

    public void corrigerJourFerieValeursNulles(boolean inclureValeurZero) {
        Duration interv = this.calculerIntervalle(this.cdcPas);
        for (int i = 0; i < this.cdcDates.size(); i++) {
            if (isMqt(i, inclureValeurZero)) {
                if (isFerie(this.cdcDates.get(i).toLocalDateTime().minus(interv))) {
                    this.cdcPuissances[i] = corrigerValeurManquanteFerie(i, inclureValeurZero);
                }
            }
        }
    }

    private double corrigerValeurManquante(int idx, boolean inclureZero) {
        boolean ok = false, stop = false;
        LocalDateTime d1 = this.cdcDates.get(idx).toLocalDateTime(), d2 = this.cdcDates.get(idx).toLocalDateTime();

        while (!ok && !stop) {
            d1 = d1.minusDays(7);
            d2 = d2.plusDays(7);
            int ind1 = testIndex(ZonedDateTime.of(d1, currentZoneId));
            int ind2 = testIndex(ZonedDateTime.of(d2, currentZoneId));

            if (isValide(ind1) && !isMqt(ind1, inclureZero) && !isFerie(d1.minus(this.calculerIntervalle(this.cdcPas)))) {
                return this.cdcPuissances[ind1];
            } else if (isValide(ind2) && !isMqt(ind2, inclureZero) && !isFerie(d2.minus(this.calculerIntervalle(this.cdcPas)))) {
                return this.cdcPuissances[ind2];
            }
            stop = !(isValide(ind1) || isValide(ind2));
        }
        return 0.0;
    }

    private double corrigerValeurManquanteFerie(int idx, boolean inclureZero) {
        LocalDate[] jf = joursFeries(this.getCdcDates().get(idx).getYear());
        int cpt = 0;

        // Convention fin-d'intervalle : on garde l'heure-du-jour de this.getCdcDates().get(idx)
        // et on décale uniquement la date — équivalent C# CdcDates[i].AddDays(N).
        long dayOfIdx = this.getCdcDates().get(idx).toLocalDate().toEpochDay();

        // Compter les fériés avec valeur valide
        for (LocalDate f : jf) {
            ZonedDateTime target = this.getCdcDates().get(idx).plusDays(f.toEpochDay() - dayOfIdx);
            int ind = testIndex(target);
            if (!isMqt(ind, inclureZero)) cpt++;
        }

        double[] valeurs = new double[cpt];
        LocalDate[] feriesOK = new LocalDate[cpt];
        int k = 0;
        for (LocalDate f : jf) {
            ZonedDateTime target = this.getCdcDates().get(idx).plusDays(f.toEpochDay() - dayOfIdx);
            int ind = testIndex(target);
            if (!isMqt(ind, inclureZero)) {
                valeurs[k] = this.getCdcPuissances()[ind];
                feriesOK[k] = f;
                k++;
            }
        }

        if (cpt == 0) return 0.0;
        int best = cpt - 1;
        LocalDate dateBest = feriesOK[cpt - 1];
        for (int j = cpt - 1; j > 0; j--) {
            if (Math.abs(this.getCdcDates().get(idx).toLocalDate().toEpochDay() - feriesOK[j].toEpochDay())
                    < Math.abs(this.getCdcDates().get(idx).toLocalDate().toEpochDay() - dateBest.toEpochDay())) {
                dateBest = feriesOK[j];
                best = j;
            }
        }
        return valeurs[best];
    }

