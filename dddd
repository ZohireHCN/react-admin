```java
private void processInputLine(
        String line,
        Long motifId,
        ReportDto report,
        MeveoUser currentUser) throws BusinessException {

    if (motifId == null) {
        throw new BusinessException("Le paramètre motif est obligatoire.");
    }

    String[] values = line.split(";", -1);

    if (values.length < 2) {
        throw new BusinessException("Format invalide : factures;BORDEREAU attendu");
    }

    String invoiceValue = values[0].trim();
    String bordereauValue = values[1].trim();

    if (!isEmpty(invoiceValue)) {
        processSingleInvoice(Long.valueOf(invoiceValue), motifId, report, false, currentUser);
        report.addNbOK();
        return;
    }

    if (!isEmpty(bordereauValue)) {
        processSingleBordereau(Long.valueOf(bordereauValue), motifId, report, currentUser);
        report.addNbOK();
        return;
    }

    throw new BusinessException("Aucune facture ou bordereau renseigné");
}
