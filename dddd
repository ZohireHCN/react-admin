    public static void calculateCurveTotals(Curve inpCurve){
        if(inpCurve == null || inpCurve.getCurveType() != CurveTypeEnum.CDC) {
            return;
        }

        CdcOpti cdcOpti = new CdcOpti(inpCurve);

        inpCurve.setTotalVolume(cdcOpti.getSum()/calculerNbPtsParHeure(cdcOpti.getCdcPas()));
        inpCurve.setAnnualVolume(cdcOpti.getSumLastYear()/calculerNbPtsParHeure(cdcOpti.getCdcPas()));
    }

