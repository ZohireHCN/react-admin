public class InvoiceSansRevalorisationScriptV1 extends Script {

    private final CustomTableService customTableService = (CustomTableService) getServiceInterface("CustomTableService");
    private final InvoiceService invoiceService = (InvoiceService) getServiceInterface(InvoiceService.class.getSimpleName());
    private final RatedTransactionService ratedTransactionService = (RatedTransactionService) getServiceInterface(RatedTransactionService.class.getSimpleName());
    private final ProviderService providerService = (ProviderService) getServiceInterface(ProviderService.class.getSimpleName());
    private final TaxMappingService taxMappingService = (TaxMappingService) getServiceInterface(TaxMappingService.class.getSimpleName()) ;
    private final UserAccountService userAccountService = (UserAccountService) getServiceInterface(UserAccountService.class.getSimpleName());

    private static final String QUERY_FIND_INVOICE_BY_ID = "SELECT i FROM Invoice i WHERE i.id = :id";
    private static final String QUERY_FIND_INVOICE_BY_BRD_ID = "SELECT invoice_id FROM ct_bordereau_invoice WHERE bordereau_id = :id";
    private static final String QUERY_FIND_BRD_BY_BRD_ID = "SELECT id,cancelled,rebilled FROM ct_bordereaux ctb WHERE ctb.id =:id";
    private static final String QUERY_IS_IN_BR_BY_ID = "SELECT COUNT(*) FROM ct_bordereau_invoice cbi WHERE cbi.invoice_id = :id";
    private static final String QUERY_CANCELLED_BR_BY_ID = "UPDATE ct_bordereaux SET  rebilled=TRUE WHERE id=:id";

    private static final String INVOICES_ID_JOB_PARAM = "factures";
    private static final String BORDEREAUX_ID_JOB_PARAM = "bordereaux";
    private static final String IMPORTS_DIR = "imports";
    private static final String INVOICES_DIR = "invoices";
    private static final String AVOIRS_DIR = "refac_sans_revalo";
    private static final String INPUT_SUBDIR = "input";
    private static final String OUTPUT_SUBDIR = "output";
    private static final String REJECT_SUBDIR = "reject";
    private static final String ARCHIVE_SUBDIR = "archive";

    private static final String INVOICE_CF_CANCELLED_KEY = "cf_inv_cancelled";
    public static final String CF_INV_REBILLED = "cf_inv_rebilled";
    public static final String N_EST_PAS_ÉLIGIBILE_À_LA_REFACTURATION = " n'est pas éligibile à la refacturation";
    public static final String ERREUR_TRAITEMENT_FICHIER = "Erreur traitement fichier ";
    private static final String MSG_INIT_DIRECTORIES = "Initialisation des dossiers effectuée";
    private static final String MSG_DIRECTORIES_ALREADY_EXIST = "Les dossiers existent déjà";
    private static final String MSG_FACTURE_NI_BORDEREAU_A_TRAITER = "Pas de facture ni bordereau à traiter";
    private static final String MSG_FAIT_PARTIE_D_UN_BORDEREAU = " fait partie d’un bordereau";
    private static final String MSG_FAIT_PARTIE_D_UN_BORDEREAU1 = " fait partie d’un bordereau";

    @Override
    public void execute(Map<String, Object> context) throws BusinessException {
        ReportDto report = new ReportDto();
        String invoicesParam = getStringParam(context, INVOICES_ID_JOB_PARAM);
        String bordereauxParam = getStringParam(context, BORDEREAUX_ID_JOB_PARAM);
        MeveoUser currentUser = (MeveoUser) context.get(Script.CONTEXT_CURRENT_USER);
        try {
            if (isEmpty(invoicesParam) && isEmpty(bordereauxParam)) {
                if (Files.notExists(getInputDirectoryPath())) {
                    initializeDirectoriesIfNeeded(report);
                    return;
                }
                if (hasInputFiles()) processInputFiles(report, currentUser);
                else report.addReport(MSG_FACTURE_NI_BORDEREAU_A_TRAITER);
                return;
            }
            if (!isEmpty(invoicesParam)) processInvoices(parseIds(invoicesParam),report,currentUser);
            if (!isEmpty(bordereauxParam)) processBordereaux(parseIds(bordereauxParam), report,currentUser);

        } catch (Exception e) {
            report.addReport(e.getMessage());
        } finally {
            flushReportInContext(context, report);
        }
    }

    private boolean hasInputFiles() throws IOException {
        try (Stream<Path> files = Files.list(getInputDirectoryPath())) {
            return files.anyMatch(Files::isRegularFile);
        }
    }

    private void processInputFiles(ReportDto report, MeveoUser currentUser) throws IOException {
        try (Stream<Path> files = Files.list(getInputDirectoryPath())) {
            files.filter(Files::isRegularFile)
                    .forEach(file -> {
                        try {
                            processSingleInputFile(file, report, currentUser);
                        } catch (Exception e) {
                            report.addReport(ERREUR_TRAITEMENT_FICHIER + file.getFileName() + " : " + e.getMessage());
                        }
                    });
        }
    }
    private void processSingleInputFile(Path inputFile, ReportDto report, MeveoUser currentUser) throws Exception {
        List<String> lines = Files.readAllLines(inputFile,StandardCharsets.UTF_8);
        if (lines.isEmpty()) return;
        List<String> outputLines = new ArrayList<>();
        List<String> rejectLines = new ArrayList<>();
        if (!isEmpty(lines.get(0))) {
            String[] invoices = lines.get(0).split(";");
            for (String invoice : invoices) {
                try {
                    Long invoiceId = Long.valueOf(invoice.trim());
                    processSingleInvoice(invoiceId,report,false,currentUser);
                    report.addNbOK();
                    outputLines.add("FACTURE;" + invoiceId);
                } catch (Exception e) {
                    report.addNbKO();
                    rejectLines.add("FACTURE;"+ invoice+ ";"+ e.getMessage());
                }
            }
        }
        if (!isEmpty(lines.get(1))) {
            String[] bordereaux = lines.get(1).split(";");
            for (String bordereau : bordereaux) {
                try {
                    Long bordereauId = Long.valueOf(bordereau.trim());
                    processSingleBordereau(bordereauId,report,currentUser);
                    report.addNbOK();
                    outputLines.add("BORDEREAU;" + bordereauId);
                } catch (Exception e) {
                    report.addNbKO();
                    rejectLines.add("BORDEREAU;"+ bordereau+ ";"+ e.getMessage());
                }
            }
        }
        writeOutputFile(inputFile, outputLines);
        writeRejectFile(inputFile, rejectLines);
        moveFileToArchive(inputFile);
    }

    private void processInvoices(List<Long> invoiceIds, ReportDto report, MeveoUser currentUser) {
        for (Long invoiceId : invoiceIds) {
            try {
                processSingleInvoice(invoiceId, report, false,currentUser);
            } catch (Exception e) {
                report.addReport("\n" + e.getMessage());
                report.addNbKO();
            }
        }
    }

    @TransactionAttribute(TransactionAttributeType.REQUIRED)
    private void processSingleInvoice(Long invoiceId,ReportDto report,boolean fromBordereau,MeveoUser currentUser) throws BusinessException {
        Invoice invoice = findInvoiceById(invoiceId);
        if (invoice == null)  throw new BusinessException("Facture ID " + invoiceId + MSG_FAIT_PARTIE_D_UN_BORDEREAU);
        if (!fromBordereau && isInvoiceAttachedToBordereau(invoiceId)) throw new BusinessException("Facture ID " + invoiceId + MSG_FAIT_PARTIE_D_UN_BORDEREAU1);
        if(!isEligibleRefacturation(invoice)) throw new BusinessException("Facture ID " + invoiceId + N_EST_PAS_ÉLIGIBILE_À_LA_REFACTURATION);
        duplcateBillingRatedTransaction(invoice);
        updateInvoiceRebillid(invoice);
        if (fromBordereau) report.addNbWARN();
        else report.addNbOK();
    }

    private void updateInvoiceRebillid(Invoice invoice) {
        CustomFieldValues invoiceCfValues = invoice.getCfValues();
        invoiceCfValues.setValue(CF_INV_REBILLED, true);
        invoice.setCfValues(invoiceCfValues);
        invoiceService.update(invoice);
    }

    private void duplcateBillingRatedTransaction(Invoice invoice) {
        List<RatedTransaction> ratedTransactions = ratedTransactionService.getRatedTransactionsByInvoice(invoice, true);
        UserAccount userAccount = this.userAccountService.retrieveIfNotManaged(invoice.getBillingAccount().getUsersAccounts().get(0));
        for (RatedTransaction ratedTransaction : ratedTransactions) {
            TaxMappingService.TaxInfo taxInfo = null;
            if (ratedTransaction.getTaxClass() != null) {
                taxInfo = taxMappingService.determineTax(ratedTransaction.getTaxClass(),ratedTransaction.getSeller(),invoice.getBillingAccount(),userAccount, invoice.getInvoiceDate(), true, false);
            }
            RatedTransaction newRT = new RatedTransaction(ratedTransaction.getUsageDate(), ratedTransaction.getUnitAmountWithoutTax(), ratedTransaction.getUnitAmountWithTax(), ratedTransaction.getUnitAmountTax(), ratedTransaction.getQuantity(), ratedTransaction.getAmountWithoutTax(),
                    ratedTransaction.getAmountWithTax(), ratedTransaction.getAmountTax(), RatedTransactionStatusEnum.OPEN, userAccount.getWallet(), invoice.getBillingAccount(), userAccount, ratedTransaction.getInvoiceSubCategory(), ratedTransaction.getParameter1(), ratedTransaction.getParameter2(),
                    ratedTransaction.getParameter3(), null, ratedTransaction.getOrderNumber(), null, ratedTransaction.getUnityDescription(), ratedTransaction.getRatingUnitDescription(), null, null, null, ratedTransaction.getCode(), ratedTransaction.getDescription(), ratedTransaction.getStartDate(),
                    ratedTransaction.getEndDate(), ratedTransaction.getSeller(), taxInfo != null ? taxInfo.tax : ratedTransaction.getTax(), taxInfo != null ? taxInfo.tax.getPercent() : ratedTransaction.getTax().getPercent(), null,
                    taxInfo != null ? taxInfo.taxClass : null, null);
            newRT.setInvoice(null);
            newRT.setBillingRun(null);
            newRT.setInvoiceAgregateF(null);
            this.ratedTransactionService.create(newRT);
        }
    }

    private Boolean isEligibleRefacturation(Invoice invoice) {
        CustomFieldValues invoiceCfValues = invoice.getCfValues();
        Boolean cancelled = (Boolean) invoiceCfValues.getValue(INVOICE_CF_CANCELLED_KEY);
        Boolean rebilled = (Boolean) invoiceCfValues.getValue(CF_INV_REBILLED);
        return Boolean.TRUE.equals(cancelled) && !Boolean.TRUE.equals(rebilled);
    }

    private void processBordereaux(List<Long> bordereauIds, ReportDto report, MeveoUser currentUser) {
        for (Long bordereauId : bordereauIds) {
            try {
                processSingleBordereau(bordereauId, report,currentUser);
                report.addNbOK();
            } catch (Exception e) {
                report.addReport("\r\n " + e.getMessage());
                report.addNbKO();
            }
        }
    }

    @TransactionAttribute(TransactionAttributeType.REQUIRED)
    private void processSingleBordereau(Long bordereauId, ReportDto report, MeveoUser currentUser) throws BusinessException {
        BordereauDto bordereau = findBordereauById(bordereauId);
        if (!idBRElegible(bordereau)) {
            throw new BusinessException("Bordereau "+bordereauId+" non élégible");
        }
        List<Long> invoiceIds = findInvoiceIdsByBordereauId(bordereauId);
        for (Long invoiceId : invoiceIds) {
            processSingleInvoice(invoiceId, report, true,currentUser);
        }
        updateBordereauAsRebilled(bordereauId);
    }

    private void updateBordereauAsRebilled(Long bordereauId) {
        customTableService.getEntityManager().createNativeQuery(QUERY_CANCELLED_BR_BY_ID).setParameter("id",bordereauId).executeUpdate();
    }

    private boolean idBRElegible(BordereauDto bordereau) {
        Boolean cancelled = bordereau.getCancelled();
        Boolean rebilled = bordereau.getRebilled() != null &&  bordereau.getRebilled();
        return cancelled && !rebilled;
    }

    private Invoice findInvoiceById(Long invoiceId) {
        return this.invoiceService.getEntityManager().createQuery(QUERY_FIND_INVOICE_BY_ID, Invoice.class).setParameter("id", invoiceId).getSingleResult();
    }

    private boolean isInvoiceAttachedToBordereau(Long invoiceId) {
        int nbrInATB= Integer.parseInt(customTableService.getEntityManager().createNativeQuery(QUERY_IS_IN_BR_BY_ID).setParameter("id",invoiceId).getSingleResult().toString());
        return nbrInATB>0;
    }

    private BordereauDto findBordereauById(Long bordereauId) {
        try {
            Object[] obj= (Object[]) customTableService.getEntityManager().createNativeQuery(QUERY_FIND_BRD_BY_BRD_ID).setParameter("id",bordereauId).getSingleResult();
            return new BordereauDto(Long.valueOf(obj[0].toString()) ,(Boolean)  obj[1],(Boolean)  obj[2]);
        } catch (Exception e) {
            throw new BusinessException("ERROR IN FindBordereauById");
        }
    }

    private List<Long> findInvoiceIdsByBordereauId(Long bordereauId) {
        List<?> idbrdStr = this.customTableService.getEntityManager().createNativeQuery(QUERY_FIND_INVOICE_BY_BRD_ID)
                .setParameter("id", bordereauId).getResultList();
        return idbrdStr.stream().map(inv ->((Number) inv).longValue()).collect(Collectors.toList());
    }

    private List<Long> parseIds(String value) {
        return Arrays.stream(value.split(";"))
                .map(String::trim)
                .filter(v -> !v.isEmpty())
                .map(Long::valueOf)
                .collect(Collectors.toList());
    }

    private void initializeDirectoriesIfNeeded(ReportDto report) throws IOException {
        Path inputDirectory = getInputDirectoryPath();
        if (Files.notExists(inputDirectory)) {
            initDirectories();
            report.addReport(MSG_INIT_DIRECTORIES);
        } else {
            report.addReport(MSG_DIRECTORIES_ALREADY_EXIST);
        }
    }

    private void initDirectories() throws IOException {
        Path baseDirectory = getBaseDirectoryPath();
        List<Path> directories = List.of(
                baseDirectory.resolve(INPUT_SUBDIR),
                baseDirectory.resolve(OUTPUT_SUBDIR),
                baseDirectory.resolve(REJECT_SUBDIR),
                baseDirectory.resolve(ARCHIVE_SUBDIR)
        );
        for (Path directory : directories) {
            Files.createDirectories(directory);
        }
    }

    private Path getInputDirectoryPath() {
        return getBaseDirectoryPath().resolve(INPUT_SUBDIR);
    }

    private Path getBaseDirectoryPath() {
        return Path.of(getProviderDir(),IMPORTS_DIR,INVOICES_DIR,AVOIRS_DIR);
    }

    private String getProviderDir() {
        String providerDir = ParamBean.getInstance().getChrootDir(providerService.getProvider().getCode());
        File directory = new File(providerDir);
        if (!directory.exists()) directory.mkdirs();
        return providerDir;
    }

    private String getStringParam(Map<String, Object> context, String key) {
        Object value = context.get(key);
        return value != null ? value.toString().trim() : "";
    }

    private boolean isEmpty(String value) {
        return value == null || value.trim().isEmpty();
    }

    private void flushReportInContext(Map<String, Object> context, ReportDto reportDto) {
        context.put(Script.JOB_RESULT_NB_OK, reportDto.getNbOK());
        context.put(Script.JOB_RESULT_NB_KO, reportDto.getNbKO());
        context.put(Script.JOB_RESULT_NB_WARN, reportDto.getNbWARN());
        if (!reportDto.getReportMessage().isEmpty()) context.put(Script.JOB_RESULT_REPORT, reportDto.getReportMessage());
    }

    private void writeOutputFile(Path inputFile, List<String> lines) throws IOException {
         String fileName =removeExtension(inputFile.getFileName().toString()) + "_output.csv";
         Files.write(getOutputDirectoryPath().resolve(fileName),lines,StandardCharsets.UTF_8,StandardOpenOption.CREATE,StandardOpenOption.TRUNCATE_EXISTING);
    }
    private void writeRejectFile( Path inputFile, List<String> lines) throws IOException {
         if (lines.size() <= 1) return;
         String fileName = removeExtension(inputFile.getFileName().toString()) + "_reject.csv";
         Files.write(getRejectDirectoryPath().resolve(fileName),lines,StandardCharsets.UTF_8,StandardOpenOption.CREATE,StandardOpenOption.TRUNCATE_EXISTING);
    }

    private void moveFileToArchive( Path inputFile ) throws IOException {
         Files.move( inputFile, getArchiveDirectoryPath().resolve(inputFile.getFileName()), StandardCopyOption.REPLACE_EXISTING);
    }

    private Path getOutputDirectoryPath() {
        return getBaseDirectoryPath().resolve(OUTPUT_SUBDIR);
    }

    private Path getRejectDirectoryPath() {
        return getBaseDirectoryPath().resolve(REJECT_SUBDIR);
    }

    private Path getArchiveDirectoryPath() {
        return getBaseDirectoryPath().resolve(ARCHIVE_SUBDIR);
    }

    private String removeExtension(String fileName) {
        int pos = fileName.lastIndexOf('.');
        if (pos > 0)  return fileName.substring(0, pos);
        return fileName;
    }

    private static class BordereauDto {
        private Long id;
        private Boolean cancelled;
        private Boolean rebilled;
        BordereauDto(Long id, Boolean cancelled, Boolean rebilled) { this.id = id;  this.cancelled = cancelled; this.rebilled = rebilled;}
        public Long getId() { return id; }
        public Boolean getCancelled() { return cancelled; }
        public Boolean getRebilled() { return rebilled; }
    }

    private static class ReportDto {
        private int nbOK;
        private int nbKO;
        private int nbWARN;
        private final StringBuilder reportBuilder = new StringBuilder();
        public int getNbWARN() { return nbWARN; }
        public int getNbOK() { return nbOK; }
        public int getNbKO() { return nbKO; }
        public String getReportMessage() { return reportBuilder.toString(); }
        public void addNbOK() { this.nbOK++; }
        public void addNbKO() { this.nbKO++; }
        public void addNbWARN() { this.nbWARN++; }
        public void addReport(String message) {
            if (reportBuilder.length() > 0) reportBuilder.append(System.lineSeparator());
            reportBuilder.append(message);
        }
    }
}
