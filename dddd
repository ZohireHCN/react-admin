private void updateFeeAsToTreat(EntityManager em, Long operationTraitementId) {
    executeUpdate(em,
            "UPDATE maco_d_fee " +
            "SET id_operation_traitement = CASE " +
            "        WHEN maco_d_processing_operation.operation_type NOT IN ('MES', 'RES', 'FRAIS_SEUL') THEN NULL " +
            "        ELSE maco_d_fee.id_operation_traitement " +
            "    END, " +
            "    operation_start_date = CASE " +
            "        WHEN maco_d_processing_operation.operation_type NOT IN ('MES', 'RES', 'FRAIS_SEUL') THEN NULL " +
            "        ELSE maco_d_fee.operation_start_date " +
            "    END, " +
            "    operation_end_date = CASE " +
            "        WHEN maco_d_processing_operation.operation_type NOT IN ('MES', 'RES', 'FRAIS_SEUL') THEN NULL " +
            "        ELSE maco_d_fee.operation_end_date " +
            "    END, " +
            "    operation_type = CASE " +
            "        WHEN maco_d_processing_operation.operation_type NOT IN ('MES', 'RES', 'FRAIS_SEUL') THEN NULL " +
            "        ELSE maco_d_fee.operation_type " +
            "    END, " +
            "    status_code = 'TO_TREAT' " +
            "FROM maco_d_processing_operation " +
            "WHERE id_operation_traitement = maco_d_processing_operation.id " +
            "AND id_operation_traitement = :operationTraitementId",
            operationTraitementId
    );
}

