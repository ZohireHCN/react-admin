    private void saveCurves(Prm prm, Map<String, CdcOptimized> cdcMap, String targetClassCat) {
        Map<String, BilledCurve> bcMap = billedCurveService.getEntityManager()
                .createQuery("select bc from BilledCurve bc " +
                                "join fetch bc.curve c " +
                                "join fetch c.binaryCurve " +   // ← élimine les lazy loads
                                "where bc.prm = :prm and bc.curve.curveTypeId = :getC5lisse",
                        BilledCurve.class)
                .setParameter("prm",        prm)
                .setParameter("getC5lisse", getCurveTypeEnum().getId())
                .getResultList().stream()
                .collect(Collectors.toMap(BilledCurve::getTemporalClass, bc -> bc));
        for (Map.Entry<String, CdcOptimized> entry : cdcMap.entrySet()) {
            String       tc  = entry.getKey();
            CdcOptimized cdc = entry.getValue();
            if (bcMap.get(tc) != null && getTemporalCat(tc).equals(targetClassCat)) {
                BilledCurve bc = bcMap.get(tc);
                Curve curveToUpdate = bc.getCurve();
                // existing est construit sur curveToUpdate → mergeCdcAndIgnoreDiscontinuity
                // modifie les puissances, recalcule les dates
                CdcOptimized existing = new CdcOptimized(curveToUpdate);
                existing.mergeCdcAndIgnoreDiscontinuity(cdc);
                // Met à jour directement les données binaires sur la curve originale
                curveToUpdate.getBinaryCurve().setData(CdcOptimized.convertDoublesToBytes(existing.getCdcPuissances()));
                curveToUpdate.setStartDate(existing.getCdcDateDebut());
                curveToUpdate.setEndDate(existing.getCdcDateFin());
                curveToUpdate.setAnnualVolume(existing.getSumLastYear() / CdcOptimized.calculerNbPtsParHeure(existing.getCdcPas()));
                curveToUpdate.setTotalVolume(existing.getSum() / CdcOptimized.calculerNbPtsParHeure(existing.getCdcPas()));
                bc.setHistoricalAnnualEnergyVolume(existing.calculateHistoricalAnnualEnergyVolume());
                billedCurveService.update(bc, jobUser);
            } else {
                if (bcMap.get(tc) != null) billedCurveService.deletePrmCurveByTC(prm, tc);
                BilledCurve bc = new BilledCurve();
                bc.setPrm(prm);
                bc.setTemporalClass(tc);
                cdc.getCurve().getBinaryCurve().setData(CdcOptimized.convertDoublesToBytes(cdc.getCdcPuissances()));
                bc.setHistoricalAnnualEnergyVolume(cdc.calculateHistoricalAnnualEnergyVolume());
                curveService.create(cdc.getCurve(), jobUser);
                bc.setCurve(cdc.getCurve());
                billedCurveService.create(bc, jobUser);
            }
        }
        bcMap.forEach((k, v) -> { if (!cdcMap.containsKey(k)) billedCurveService.deletePrmCurveByTC(prm, k); });
        bcMap.clear();
    }

