    public void mergeCdc(Cdc cdc, boolean overwrite) {
        List<Double> newCoeffs = cdc.getCdcPuissances();
        List<Double> existingCoeffs = this.cdcPuissances;
        List<ZonedDateTime> newDates = cdc.getCdcDates();
        List<ZonedDateTime> existingDates = this.cdcDates;

        if (!Objects.equals(cdcPas.getId(), cdc.getCdcPas().getId())) {
            unifyStep(this, cdc);
            // Refresh newCoeffs and existingCoeffs after unifying steps
            newCoeffs = cdc.getCdcPuissances();
            existingCoeffs = this.cdcPuissances;
            newDates = cdc.getCdcDates();
            existingDates = this.cdcDates;
        }

        if (!datesAreContinuous(cdc)) {
            throw new BusinessException("Discontinuous dates detected.");
        }

        List<Double> mergedCoeffs = new ArrayList<>();
        List<ZonedDateTime> mergedDates = new ArrayList<>();
        int newIndex = 0;
        int existingIndex = 0;

        while (newIndex < newDates.size() && existingIndex < existingDates.size()) {
            ZonedDateTime newDate = newDates.get(newIndex);
            ZonedDateTime existingDate = existingDates.get(existingIndex);

            if (newDate.isBefore(existingDate)) {
                mergedDates.add(newDate);
                mergedCoeffs.add(newCoeffs.get(newIndex));
                newIndex++;
            } else if (newDate.isAfter(existingDate)) {
                mergedDates.add(existingDate);
                mergedCoeffs.add(existingCoeffs.get(existingIndex));
                existingIndex++;
            } else {
                mergedDates.add(newDate);
                if((overwrite && newCoeffs.get(newIndex) != null) || existingCoeffs.get(existingIndex) == null) {
                    mergedCoeffs.add(newCoeffs.get(newIndex));
                } else {
                    mergedCoeffs.add(existingCoeffs.get(existingIndex));
                }
                newIndex++;
                existingIndex++;
            }
        }

        // Add remaining elements from newDates
        while (newIndex < newDates.size()) {
            mergedDates.add(newDates.get(newIndex));
            mergedCoeffs.add(newCoeffs.get(newIndex));
            newIndex++;
        }

        // Add remaining elements from existingDates
        while (existingIndex < existingDates.size()) {
            mergedDates.add(existingDates.get(existingIndex));
            mergedCoeffs.add(existingCoeffs.get(existingIndex));
            existingIndex++;
        }

        this.cdcDates = mergedDates;
        this.cdcPuissances = mergedCoeffs;
        this.curve.getBinaryCurve().setData(convertDoublesToBytes(mergedCoeffs));
        setStartEndDates();
        reconstruireDates();
        this.cdcPuissances = mergedCoeffs;
        calculateCurveTotals();
    }

