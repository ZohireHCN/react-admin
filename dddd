    private synchronized void checkMemoryConsumption() {
        long memoryUsed = (Runtime.getRuntime().totalMemory() - Runtime.getRuntime().freeMemory())/1000000000;

        if (memoryUsed > memoryLimit) {
            if(gcLaunchTime == 0 || (System.currentTimeMillis() - gcLaunchTime) > GC_INTERVAL * 1000) {
                log.info("Memory usage is high: {} Gb used out of {} Gb ... Forcing garbage collection", memoryUsed, MAX_MEMORY);
                forceGarbageCollection();
                gcLaunchTime = System.currentTimeMillis();
            } else {
                log.info("Garbage collection already launched in the last {} seconds", GC_INTERVAL);
            }
        }
    }

    private void forceGarbageCollection() {
        System.gc();
        System.runFinalization();
        System.gc();
    }

