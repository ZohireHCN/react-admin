private void applyInvoiceRebillingWithRevalorisation(Invoice invoice) throws BusinessException {
    String otId = getOtForInvoice(invoice);

    if (StringUtils.isNotBlank(otId)) {
        processReouvertureOpeTrait(otId);
    }

    updateInvoiceRebilled(invoice);
}

private String getOtForInvoice(Invoice invoice) {
    List<RatedTransaction> ratedTransactions =
            ratedTransactionService.getRatedTransactionsByInvoice(invoice, true);

    return ratedTransactions.stream()
            .map(RatedTransaction::getParameter2)
            .filter(StringUtils::isNotBlank)
            .map(String::trim)
            .findFirst()
            .orElse(null);
}

private void processReouvertureOpeTrait(String otId) {
    Long operationTraitementId = parseOperationTraitementId(otId);
    EntityManager em = customTableService.getEntityManager();

    updateCdrAsAbandoned(em, operationTraitementId);

    deleteBillableConsumption(em, operationTraitementId);

    updatePodMaco(em, operationTraitementId);

    deleteBillableSubscription(em, operationTraitementId);

    deleteBillableFee(em, operationTraitementId);

    updatePreviousConsumptionIfNeeded(em, operationTraitementId);

    updateMeterReadingHeader(em, operationTraitementId);

    updateDailyMeterReadingHeader(em, operationTraitementId);

    updateProcessingOperationAsToTreat(em, operationTraitementId);

    updateFeeAsToTreat(em, operationTraitementId);

    deleteCustomTableOperationTraitement(em, operationTraitementId);

    deleteCustomTableLignesFacturables(em, operationTraitementId);
}

private Long parseOperationTraitementId(String otId) {
    if (StringUtils.isBlank(otId)) {
        throw new BusinessException("Identifiant opération traitement vide");
    }

    try {
        return Long.valueOf(otId.trim());
    } catch (NumberFormatException e) {
        throw new BusinessException("Identifiant opération traitement invalide : " + otId);
    }
}

private void updateCdrAsAbandoned(EntityManager em, Long operationTraitementId) {
    executeUpdate(em,
            "UPDATE maco_d_cdr " +
            "SET status = 'ABANDONED' " +
            "WHERE status = 'SENT' " +
            "AND parameter_5 = :operationTraitementId",
            operationTraitementId
    );
}

