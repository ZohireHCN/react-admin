    /**
     * Entry point of the profiling script.
     * <p>
     * Recognized parameters in {@code context}:
     * <ul>
     *   <li>{@code prmRefs}: semicolon-separated PRM references list (PRM mode)</li>
     *   <li>{@code rfpIds}: semicolon-separated RFP IDs list (RFP mode)</li>
     *   <li>{@code threadCount}: optional custom parallelism level</li>
     *   <li>{@code memoryLimit}: optional memory limit ratio</li>
     * </ul>
     * </p>
     * @param context Job execution context and parameters.
     * @throws BusinessException If configuration or processing fails.
     */
    @Override
    public void execute(Map<String, Object> context) throws BusinessException {
        log.info("Executing CurveProfilingScript with method {}", context);
        jobUser = ((MeveoUser) context.getOrDefault(CONTEXT_CURRENT_USER, "")).getUserName();
        automaticJobLaunch = isJobLaunchAutomatic(context);

        try {
            validateParams(context);
            retrieveConfiguration();
        } catch (BusinessException e) {
            koCounter.incrementAndGet();
            report.rep(e.getMessage());
            setJobReportData(context);
            return;
        }

        try {
            switch (profilingType) {
                case PRM:
                    prmProfiling();
                    break;
                case RFP:
                    rfpProfiling();
                    break;
                case DEFAULT:
                    defaultProfiling();
            }

            if(!prmIdsList.isEmpty()){
                prmService.selectPrmsAndupdateLoadCurveIntegration(prmIdsList, "rfd_reconstitution_status_id", RfpStatusEnum.TREATED.getId().intValue(), jobUser);
                prmService.selectPrmsAndupdateLoadCurveIntegration(prmIdsList, "rfd_average_reconstitution_status_id", RfpStatusEnum.TO_TREAT.getId().intValue(), jobUser);
            }

            updatePrmPostes();
        } catch (Exception e) {
            log.info("Error while processing curves", e);
            throw e;
        }

        setJobReportData(context);
        curveService.getEntityManager().flush();
    }

    /**
     * Persists computed PRM {@code poste} grouping in bulk for all processed PRMs.
     * Uses a single update per poste value.
     */
    private void updatePrmPostes() {
        for(Map.Entry<String, List<Long>> entry : prmIdsByPoste.entrySet()) {
            try {
                prmService.getEntityManager().createQuery("update Prm prm set prm.poste = :poste where prm.id in :prmIds")
                        .setParameter("poste", entry.getKey())
                        .setParameter("prmIds", entry.getValue())
                        .executeUpdate();
            } catch (Exception e) {
                throw new BusinessException("Error while updating prm postes {}" + e.getMessage(), e);
            }
        }
    }


    /**
     * Profiles the list of PRMs provided via the {@code prmRefs} parameter.
     * Each PRM is processed independently; counters and reports are updated accordingly.
     */
    private void prmProfiling() {
        for (String prmRef : prmRefs) {
            try {
                processPrm(prmRef);
            } catch (NoMeasuresFoundException e) {
                log.info(e.getMessage());
                koCounter.incrementAndGet();
                noMeasuresFoundPrms.add(prmRef);
            } catch (ObjectNotFoundException e) {
                log.info(e.getMessage());
                notFoundPrms.add(prmRef);
                koCounter.incrementAndGet();
            } catch (ProfileCoeffNotFound e) {
                log.info(e.getMessage());
                koCounter.incrementAndGet();
                noProfileCoeffFoundPrms.add(prmRef);
            } catch (BusinessException e) {
                log.info(e.getMessage());
                koCounter.incrementAndGet();
            } finally {
                checkMemoryConsumption();
            }
        }
    }

    /**
     * Profiles all PRMs attached to the provided RFP IDs.
     * Errors for individual RFPs are collected without stopping the entire batch.
     */
    private void rfpProfiling() {
        for (Long rfpId : rfpIds) {
            try {
                processRfp(rfpId);
            } catch (ObjectNotFoundException e) {
                log.info(e.getMessage());
                notFoundRfps.add(rfpId);
                koCounter.incrementAndGet();
            } catch (BusinessException e) {
                log.info(e.getMessage());
                koCounter.incrementAndGet();
            }
        }
    }

    /**
     * Performs profiling for a default selection of PRMs that are eligible based on
     * contractual segment, statuses and measure properties.
     * @throws BusinessException On query or processing failures.
     */
    private void defaultProfiling() throws BusinessException {
        try {
            List<Prm> prms = rfpDetailService.getEntityManager().createQuery("select distinct rfd.prm " +
                            "from RfpDetail rfd inner join EnedisContractualData ecd on ecd.prm.id = rfd.prm.id " +
                                    "inner join ContractualSituation cos on cos.enedisContractualData.id = ecd.id " +
                                    "inner join BilledMeterReading bmr on bmr.prm.id = rfd.prm.id " +
                            "where rfd.archived != true and rfd.prm.archived != true and cos.segment = :segment " +
                                    "and rfd.reconstitutionStatusId = :status " +
                                    "and bmr.calendar = :calendar and bmr.measureName != :estimated "
                            , Prm.class)
                    .setParameter("status", RfpStatusEnum.TO_TREAT.getId())
                    .setParameter("segment", "C5")
                    .setParameter("calendar", DEFAULT_CALENDAR)
                    .setParameter("estimated", "Estimé")
                    .getResultList();

            processPrms(prms);
        } catch (BusinessException e) {
            report.rep(e.getMessage());
        }
    }

    /**
     * Processes a list of PRMs in parallel using a ForkJoinPool.
     * Manages lifecycle of the thread pool and aggregates results and errors.
     *
     * @param prms PRMs to process.
     * @throws BusinessException If execution of parallel tasks fails.
     */
    private void processPrms(List<Prm> prms) throws BusinessException {
        AtomicInteger counter = new AtomicInteger(0);

        ForkJoinPool customThreadPool = new ForkJoinPool(threadCount);
        try {
            customThreadPool.submit(() ->
                    prms.parallelStream().forEach(prm -> {
                        try {
                            log.info("Processing PRM {}/{} with ref : {}",
                                    counter.incrementAndGet(), prms.size(), prm.getReference());
                            processPrm(prm);
                        } catch (NoMeasuresFoundException e) {
                            koCounter.incrementAndGet();
                            noMeasuresFoundPrms.add(prm.getReference());
                        } catch (ProfileCoeffNotFound e) {
                            koCounter.incrementAndGet();
                            noProfileCoeffFoundPrms.add(prm.getReference());
                        } catch (BusinessException e) {
                            koCounter.incrementAndGet();
                            report.rep(e.getMessage());
                        } finally {
                            checkMemoryConsumption();
                        }
                    })
            ).get();
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
            throw new BusinessException("Processing was interrupted", e);
        } catch (ExecutionException e) {
            Throwable cause = e.getCause();
            if (cause instanceof BusinessException) {
                throw (BusinessException) cause;
            }
            throw new BusinessException("Processing failed", cause);
        } finally {
            customThreadPool.shutdown();
            try {
                // Wait for existing tasks to terminate
                if (!customThreadPool.awaitTermination(6, TimeUnit.HOURS)) {
                    log.warn("Thread pool didn't terminate gracefully, forcing shutdown");
                    customThreadPool.shutdownNow();
                    // Wait a bit more for tasks to respond to being cancelled
                    if (!customThreadPool.awaitTermination(10, TimeUnit.SECONDS)) {
                        log.error("Thread pool didn't terminate after forced shutdown");
                    }
                }
            } catch (InterruptedException e) {
                log.warn("Interrupted while waiting for thread pool shutdown");
                customThreadPool.shutdownNow();
                Thread.currentThread().interrupt();
            }
        }
    }

    /**
     * Loads a PRM by reference and processes it.
     *
     * @param prmRef PRM reference.
     * @throws BusinessException On processing errors.
     * @throws ObjectNotFoundException If the PRM cannot be found.
     * @throws NoMeasuresFoundException If no eligible measures are found for the PRM.
     */
    private void processPrm(String prmRef) throws BusinessException, ObjectNotFoundException, NoMeasuresFoundException {
        Prm prm;

        try {
            prm = prmService.getEntityManager().createQuery("select prm from Prm prm where reference = :reference", Prm.class)
                    .setParameter("reference", prmRef)
                    .getSingleResult();
        } catch (Exception e) {
            throw new ObjectNotFoundException("PRM non trouvé : " + prmRef);
        }

        processPrm(prm);
    }


    /**
     * Processes a single PRM: reads measures, determines temporal class target,
     * builds curves and persists results.
     *
     * @param prm PRM entity.
     * @throws BusinessException On processing errors or data inconsistencies.
     * @throws NoMeasuresFoundException If the PRM has no eligible billed measures.
     */
    private void processPrm(Prm prm) throws BusinessException, NoMeasuresFoundException {
        Map<String, Cdc> profileMap = new HashMap<>();
        List<BilledMeterReading> bmrList = getBilledMeterReadings(prm);
     //        report.rep("[1] début traitement de " + bmrList.size() + " relèves distributeur non estimé pour PRM " + prm.getReference());

        if (bmrList.isEmpty()) {
            throw new NoMeasuresFoundException("Aucune relève trouvée pour le PRM " + prm.getReference());
        }

        bmrList.forEach(bmr -> {
            String tClass = bmr.getTemporalClass();
            if (tClass.equals("HCB")) {
                bmr.setTemporalClass("HCE");
            } else if (tClass.equals("HPB")) {
                bmr.setTemporalClass("HPE");
            }
        });

        getFuds(prm, bmrList);

        MeterReadingList meterReadingList = new MeterReadingList();
        if(C5_LISSE_DISABLED.equals(getC5Lisse)){
            bmrList.forEach(meterReadingList::add);
        } else {
            bmrList.forEach(meterReadingList::addDailySplit);
        }

   /*     report.rep("[2] équivalent de " + meterReadingList.getList().size() + " meterReading pour PRM " + prm.getReference());
        meterReadingList.getList().forEach(mr -> {
            report.rep("MeterReading [" + mr.getStartDate().toLocalDate() + " -> " + mr.getEndDate().toLocalDate() + "]");
            for (Map.Entry<String, BilledMeterReading> e : mr.getBmrList().entrySet()) {
                if(!"BASE".equals(e.getKey()) && e.getValue().getMeasure() > 0D){
                    report.rep("   " + e.getKey() + " => " + e.getValue());
                }
            }
        }); */

        String fournisseurTemporalCat = getLastFournisseurMeasureTemporalClass(prm);
        addPrmToPosteMap(prm.getId(), getPrmPoste(prm));

        Map<String, Cdc> cdcMap = new HashMap<>();
        String targetClassCat = getPrmTargetClass(prm, fournisseurTemporalCat);
        // report.rep("[3] la classe temp de la dernière relève est : " + targetClassCat + " pour prm " + prm.getReference() + " contenant " + bmrList.size() + " relèves.");
        handleMeterReadingList(prm, targetClassCat, cdcMap, profileMap, meterReadingList);
        // Save curves
        saveCurves(prm, cdcMap, targetClassCat);
        prmIdsList.add(prm.getId());
        okCounter.incrementAndGet();
        profileMap.clear();
    }

    /**
     * Adds a PRM ID to the internal map keyed by poste in a thread-safe manner.
     * @param prmId PRM identifier.
     * @param poste Poste value resolved for the PRM.
     */
    private synchronized void addPrmToPosteMap(Long prmId, String poste){
        prmIdsByPoste.computeIfAbsent(poste, k -> new ArrayList<>()).add(prmId);
    }

    /**
     * Resolves the poste for a PRM, using its sub-profile or deducing it from the latest
     * temporal class and the mapping rules.
     * @param prm PRM entity.
     * @return Poste value.
     * @throws BusinessException If poste cannot be determined.
     */
    private String getPrmPoste(Prm prm) {
        String subProfile;

        if(prm.getSubProfile() == null || prm.getSubProfile().isBlank()) {
            String tempClass = getPosteTemporalClass(prm);
            if("PRO5_BASE_TEMPORAL_CLASS".equals(tempClass)) {
                subProfile = "PRO5_BASE";
            }else {
                subProfile = getSubProfileMapping(tempClass);
            }
        } else {
            subProfile = prm.getSubProfile();
        }

        int underscoreIndex = subProfile.indexOf('_');
        if(underscoreIndex == -1) {
            throw new BusinessException("Unable to identify poste for prm "+ prm.getReference());
        }
        return subProfile.substring(0, underscoreIndex);
    }

    /**
     * Retrieves the most recent temporal class observed for a PRM, across calendars,
     * with precedence rules :
     * 1) (Fournisseur && temporalClass = BASE && usageContext in ('UPIN', 'ECPU')
     * 2) (Fournisseur over Distributeur, Réel over Estimé).
     * @param prm PRM entity.
     * @return Temporal class string or empty when unavailable.
     */
    private String getPosteTemporalClass(Prm prm) {
        try {
            String temporalClass = bmrService.getEntityManager().createQuery("select temporalClass from BilledMeterReading " +
                    "where calendar = 'Fournisseur' and prm.id = :prmId order by endDate desc", String.class)
                    .setParameter("prmId", prm.getId())
                    .setMaxResults(1)
                    .getSingleResult();

            if("BASE".equals(temporalClass)){
                ContractualSituation contractualSituation = contractualSituationService.getEntityManager()
                        .createQuery("select cs from ContractualSituation cs " +
                                "where cs.enedisContractualData.prm.id = :prmId " +
                                "and cs.usageContext in ('UPIN', 'ECPU')", ContractualSituation.class)
                        .setParameter("prmId", prm.getId())
                        .setMaxResults(1)
                        .getSingleResult();

                if(contractualSituation != null){
                    return "PRO5_BASE_TEMPORAL_CLASS";
                }
                return getTemporalClassOfLastBilledMeterReading(prm);
            }
            return getTemporalClassOfLastBilledMeterReading(prm);

        } catch (Exception e) {
            return getTemporalClassOfLastBilledMeterReading(prm);
        }
    }


    private String getTemporalClassOfLastBilledMeterReading(Prm prm) {
        try {
            return bmrService.getEntityManager().createQuery("select temporalClass from BilledMeterReading " +
                    "where prm.id = :prmId order by endDate desc, case when calendar = 'Fournisseur' then 1 " +
                    "when calendar = 'Distributeur' then 2 else 3 end, " +
                    "case when measureName = 'Réel' then 1 when measureName = 'Estimé' then 2 else 3 end", String.class)
                    .setParameter("prmId", prm.getId())
                    .setMaxResults(1)
                    .getSingleResult();
        } catch (Exception e) {
            log.info("Unable to find temporal class for PRM {} : {}", prm.getReference(), e.getMessage(), e);
            return EMPTY_STRING;
        }
    }

    /**
     * Retrieves the temporal class of the latest Fournisseur measure for a PRM.
     * @param prm PRM entity.
     * @return Temporal class string.
     * @throws BusinessException If no Fournisseur measure is available.
     */
    private String getLastFournisseurMeasureTemporalClass(Prm prm) {
        String result = bmrService.getEntityManager().createQuery("select bmr.temporalClass from BilledMeterReading bmr " +
                "where bmr.prm.id = :prmId and bmr.calendar = :calendar and bmr.measureName != :estimated " +
                        "order by bmr.endDate desc", String.class)
                .setParameter("prmId", prm.getId())
                .setParameter("calendar", "Fournisseur")
                .setParameter("estimated", "Estimé")
                .getResultStream().findFirst().orElse(null);

        if(result == null) {
            throw new BusinessException("Unable to find last measure for prm "+ prm.getReference());
        }

        if(result.equals("HCB") || result.equals("HCE") || result.equals("HPB") || result.equals("HPE")) {
            result = result.replace("B", "E");
        }

        return result;
    }

    private String getPrmTargetClass(Prm prm, String defaultTemporalClass) {
        if(prm.getSubProfile() == null || prm.getSubProfile().isBlank()) {
          return MeterReading.getTemporalCat(defaultTemporalClass);
        } else if(prm.getSubProfile().endsWith("BASE")){
            return "BASE";
        } else if (prm.getSubProfile().endsWith("HP") || prm.getSubProfile().endsWith("HC")) {
            return "HPHC";
        } else if (prm.getSubProfile().contains("HP") || prm.getSubProfile().contains("HC")) {
            return "SAISON";
        } else {
            throw new BusinessException("Not-supported sub-profile "+prm.getSubProfile()+" for "+prm.getReference());
        }
    }

    private Double getPrmPS(Prm prm) {
        try {
            EnedisContractualData enedisContractualData = enedisContractualDataService.getEntityManager()
                    .createQuery(
                            "select ecd from EnedisContractualData ecd " +
                                    "left join fetch ecd.contractualSituations " +
                                    "where ecd.prm.id = :prmId",
                            EnedisContractualData.class)
                    .setParameter("prmId", prm.getId())
                    .setMaxResults(1)
                    .getSingleResult();

            List<ContractualSituation> situations = enedisContractualData.getContractualSituations();
            if (!situations.isEmpty()) {
                double ps = situations.get(0).getSubscribedPowerValue();
                if (situations.get(0).getSubscribedPowerUnit().equalsIgnoreCase("kVA")) {
                    return ps / 1000;
                }
            }

            return null;
        } catch (NoResultException e) {
            log.info("No contractual data found for PRM with ID: {}", prm.getId());
            return null;
        } catch (Exception e) {
            log.info("No subscribed power found for PRM with ID: {} ({})", prm.getId(), e.getMessage());
            return null;
        }
    }

    private void getFuds(Prm prm, List<BilledMeterReading> bmrList) {
        List<BilledMeterReading> filteredBmrList = bmrList.stream()
                .filter(bmr -> bmr != null && Boolean.TRUE.equals(bmr.getOverwriteMeasure()))
                .collect(Collectors.toList());

        if(filteredBmrList.isEmpty()) {
            return;
        }

        Double ps = getPrmPS(prm);

        if (ps == null) {
            return;
        }

        filteredBmrList.forEach(bmr -> {
            String subProfile = getSubProfile(prm, bmr.getTemporalClass());
            Double theta = THETA_VALUES.get(subProfile);
            if (theta == null) {
                log.info("Theta value not found for sub-profile {}, prm {}", subProfile, prm.getReference());
                warnCounter.incrementAndGet();
                report.rep(String.format("Valeur de theta non trouvée pour le sous-profil %s, prm %s", subProfile, prm.getReference()));
                return;
            }
            bmr.setFudMeasure(BigDecimal.valueOf(ps).multiply(BigDecimal.valueOf(theta)).doubleValue());
            bmrService.update(bmr, jobUser);
        });

        filteredBmrList.clear();
    }

