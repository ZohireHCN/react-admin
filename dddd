    public StepEnum getStepFromDatesAndValues(ZonedDateTime start, ZonedDateTime end, double[] values) {
        try {
            if (start.isAfter(end)) {
                throw new BusinessException("Start date is after end date");
            }

            long minutesDiff = ChronoUnit.MINUTES.between(start, end);
            float minutesDuration = Math.round(minutesDiff / (float) values.length);

            try {
                return StepEnum.fromDurationInMinutes((int) minutesDuration);
            } catch (Exception e) {
                return null;
            }
        } catch (BusinessException e) {
            return null;
        }
    }

    public CdcOpti(Curve curve, List<Double> puissances) {
        this(curve, toPrimitiveArray(puissances));
    }

    public CdcOpti(Curve curve, double[] puissances) {
        StepEnum decuctedStep = getStepFromDatesAndValues(curve.getStartDate(), curve.getEndDate(), puissances);
        if(decuctedStep != null && decuctedStep != curve.getStep()) {
            this.cdcPas = decuctedStep;
            curve.setStep(decuctedStep);
        }
        remplirCdc(curve.getStep(), curve.getStartDate(), curve.getEndDate());
        this.curve = curve;
        cdcPuissances = Arrays.copyOf(puissances, puissances.length);
    }

    public CdcOpti(StepEnum pas, ZonedDateTime debut, ZonedDateTime fin) {
        if (debut.isAfter(fin) || (debut.isEqual(fin) && (pas != StepEnum.Journalier))) {
            return;
        }
        remplirCdc(pas, debut, fin);
    }

