package com.masociete.maven;

import org.apache.maven.plugin.AbstractMojo;
import org.apache.maven.plugin.MojoExecutionException;
import org.apache.maven.plugins.annotations.Mojo;
import org.apache.maven.plugins.annotations.Parameter;

import java.io.File;
import java.io.IOException;
import java.nio.charset.StandardCharsets;
import java.nio.file.*;
import java.util.Comparator;
import java.util.stream.Stream;

@Mojo(name = "buildprod")
public class BuildProdMojo extends AbstractMojo {

    @Parameter(property = "prodVersion", required = true)
    private String prodVersion;

    @Parameter(property = "withGeneric", defaultValue = "false")
    private boolean withGeneric;

    @Parameter(defaultValue = "${project.basedir}", readonly = true)
    private File basedir;

    @Override
    public void execute() throws MojoExecutionException {
        try {
            Path base = basedir.toPath();
            Path src = base.resolve("src");
            Path release = src.resolve("release");

            validateVersion(prodVersion);

            if (withGeneric) {
                generateReleaseFiles(
                        src.resolve("generic"),
                        release.resolve("generic"),
                        "generic"
                );
            }

            generateReleaseFiles(
                    release.resolve(prodVersion),
                    release.resolve(prodVersion),
                    prodVersion
            );

            getLog().info("Génération terminée avec succès.");

        } catch (Exception e) {
            throw new MojoExecutionException("Erreur pendant la génération des fichiers release", e);
        }
    }

    private void validateVersion(String version) throws MojoExecutionException {
        if (version == null || version.trim().isEmpty()) {
            throw new MojoExecutionException("Le paramètre prodVersion est obligatoire.");
        }

        if (!version.matches("\\d{2}\\.\\d{2}\\.\\d+")) {
            throw new MojoExecutionException(
                    "Version invalide : " + version + ". Exemple attendu : 26.06.5"
            );
        }
    }

    private void generateReleaseFiles(Path inputRoot, Path outputRoot, String releaseName)
            throws IOException, MojoExecutionException {

        if (!Files.exists(inputRoot)) {
            throw new MojoExecutionException("Dossier introuvable : " + inputRoot);
        }

        Files.createDirectories(outputRoot);

        mergeSqlFolder(
                inputRoot.resolve("sql-data"),
                outputRoot.resolve("release-" + releaseName + "-data.sql")
        );

        mergeSqlFolder(
                inputRoot.resolve("sql-struct"),
                outputRoot.resolve("release-" + releaseName + "-struct.sql")
        );
    }

    private void mergeSqlFolder(Path inputFolder, Path outputFile)
            throws IOException {

        if (!Files.exists(inputFolder)) {
            getLog().warn("Dossier ignoré car introuvable : " + inputFolder);
            return;
        }

        StringBuilder result = new StringBuilder();

        try (Stream<Path> files = Files.list(inputFolder)) {
            files
                    .filter(Files::isRegularFile)
                    .filter(path -> path.toString().toLowerCase().endsWith(".sql"))
                    .sorted(Comparator.comparing(path -> path.getFileName().toString()))
                    .forEach(path -> appendSqlFile(result, path));
        }

        Files.writeString(
                outputFile,
                result.toString(),
                StandardCharsets.UTF_8,
                StandardOpenOption.CREATE,
                StandardOpenOption.TRUNCATE_EXISTING
        );

        getLog().info("Fichier créé : " + outputFile);
    }

    private void appendSqlFile(StringBuilder result, Path path) {
        try {
            String fileName = path.getFileName().toString();

            result.append(System.lineSeparator());
            result.append("-- =============================================").append(System.lineSeparator());
            result.append("-- FILE : ").append(fileName).append(System.lineSeparator());
            result.append("-- =============================================").append(System.lineSeparator());
            result.append(System.lineSeparator());

            result.append(Files.readString(path, StandardCharsets.UTF_8));

            result.append(System.lineSeparator());
            result.append(System.lineSeparator());

        } catch (IOException e) {
            throw new RuntimeException("Erreur lecture fichier SQL : " + path, e);
        }
    }
}

