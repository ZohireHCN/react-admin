    /**
     * Étend (ou restreint) la courbe à une nouvelle plage temporelle.
     * Si avecNaN=true, les zones sans données sont remplies de NaN.
     * Port fidèle de EtendreCourbe(debut, fin, pas, avecMinValue) C#.
     */
    public CdcOpti projectCdc(ZonedDateTime debut, ZonedDateTime fin, StepEnum targetPas, boolean avecNaN) {
        if (debut == null || fin == null) return this;

        if (this.cdcPas == targetPas && debut.equals(this.cdcDateDebut) && fin.equals(this.cdcDateFin)) {
            return recopier();
        }

        CdcOpti retour = new CdcOpti(targetPas, debut, fin, avecNaN);
        if (retour == null || retour.cdcDates == null) return null;

        int i = 0, j = 0;
        while (i < retour.cdcDates.size() && retour.cdcDates.get(i).isBefore(this.cdcDateDebut)) {
            i++;
        }
        while (j < this.cdcDates.size() && i < retour.cdcDates.size()
                && this.cdcDates.get(j).isBefore(retour.cdcDates.get(i))) {
            j++;
        }
        while (i < retour.cdcPuissances.length && j < this.cdcPuissances.length) {
            retour.cdcPuissances[i] = this.cdcPuissances[j];
            j++;
            i++;
        }
        return retour;
    }

    public void extendCdc(ZonedDateTime debut, ZonedDateTime fin, Double defaultValue) {
        if(debut.isEqual(cdcDateDebut) && fin.isEqual(cdcDateFin)) {
            return;
        }

        ZonedDateTime startDate = cdcDateDebut.isBefore(debut) || cdcDateDebut.isEqual(debut) ? cdcDateDebut : debut;
        ZonedDateTime endDate = cdcDateFin.isAfter(fin) || cdcDateFin.isEqual(fin) ? cdcDateFin : fin;

        List<ZonedDateTime> newDates = new ArrayList<>();
        int stepDurationInMin = cdcPas.getDurationInMinutes();
        double defaultPrimitive = toPrimitive(defaultValue);

        int prefixSize = 0;
        ZonedDateTime currentDate = startDate;
        while (currentDate.isBefore(cdcDateDebut)) {
            newDates.add(currentDate);
            prefixSize++;
            currentDate = cdcPas == StepEnum.Journalier
                    ? currentDate.plusDays(1)
                    : currentDate.plusMinutes(stepDurationInMin);
        }

        newDates.addAll(cdcDates);

        int suffixSize = 0;
        currentDate = cdcPas == StepEnum.Journalier
                ? cdcDateFin.plusDays(1)
                : cdcDateFin.plusMinutes(stepDurationInMin);
        while (!currentDate.isAfter(endDate)) {
            newDates.add(currentDate);
            suffixSize++;
            currentDate = cdcPas == StepEnum.Journalier
                    ? currentDate.plusDays(1)
                    : currentDate.plusMinutes(stepDurationInMin);
        }

        double[] newValues = new double[prefixSize + cdcPuissances.length + suffixSize];
        Arrays.fill(newValues, 0, prefixSize, defaultPrimitive);
        System.arraycopy(cdcPuissances, 0, newValues, prefixSize, cdcPuissances.length);
        Arrays.fill(newValues, prefixSize + cdcPuissances.length, newValues.length, defaultPrimitive);

        cdcDates = newDates;
        cdcPuissances = newValues;
        setStartEndDates();
    }

    private void remplirCdc(StepEnum pas, ZonedDateTime debut, ZonedDateTime fin) {
        remplirCdc(pas, debut, fin, 0D);
    }

    public CdcOpti getReducedCdc(ZonedDateTime start, ZonedDateTime end) {
        CdcOpti reducedCdcOpti = new CdcOpti();
        int startIndex = getReducedStartDateIndex(start);
        int endIndex = getReducedEndDateIndex(end);

        reducedCdcOpti.curve = new Curve();
        reducedCdcOpti.curve.setStartDate(start);
        reducedCdcOpti.curve.setEndDate(end);
        reducedCdcOpti.curve.setStep(cdcPas);
        reducedCdcOpti.curve.setBinaryCurve(new BinaryCurve());
        reducedCdcOpti.curve.getBinaryCurve().setCurve(reducedCdcOpti.curve);

        reducedCdcOpti.cdcDates = new ArrayList<>(cdcDates.subList(startIndex, endIndex + 1));
        reducedCdcOpti.cdcPuissances = slice(cdcPuissances, startIndex, endIndex);
        reducedCdcOpti.curve.getBinaryCurve().setData(convertDoublesToBytes(reducedCdcOpti.cdcPuissances));
        reducedCdcOpti.cdcDateDebut = start;
        reducedCdcOpti.cdcDateFin = end;
        reducedCdcOpti.cdcPas = cdcPas;

        return reducedCdcOpti;
    }

    public CoverageStatus getCoverageStatus(ZonedDateTime start, ZonedDateTime end) {

        int startIndex = getReducedStartDateIndex(start);
        int endIndex   = getReducedEndDateIndex(end);

        long expectedPoints = Duration.between(start, end).toMinutes() / cdcPas.getDurationInMinutes() + 1;

        if (startIndex < 0 || endIndex < startIndex) {
            return CoverageStatus.NONE;
        }

        boolean hasAtLeastOne = false;
        boolean allCovered = (endIndex - startIndex + 1) == expectedPoints;

        for (int i = startIndex; i <= endIndex; i++) {
            boolean present = !isMissing(cdcPuissances[i]);
            hasAtLeastOne |= present;
            allCovered &= present;
        }

        if (!hasAtLeastOne) {
            return CoverageStatus.NONE;
        }

        return allCovered ? CoverageStatus.FULL : CoverageStatus.PARTIAL;
    }


    public enum CoverageStatus {
        NONE,
        PARTIAL,
        FULL
    }

