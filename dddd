    private List<String> getTargetClasses(String targetClassCat) {
        switch (targetClassCat) {
            case "HPHC":
                return MeterReading.HPHC_CLASSES;
            case "SAISON":
                return MeterReading.SAISON_CLASSES;
            default:
                return List.of("BASE");
        }
    }

    private String getSubProfile(Prm prm, String temporalClass) {
        if (prm.getSubProfile() != null && !prm.getSubProfile().isBlank() && prm.getSubProfile().contains("BASE")) {
            return prm.getSubProfile();
        }

        List<Long> pro5 = prmIdsByPoste.get("PRO5");
        if(temporalClass.equals("BASE") && pro5 != null && pro5.contains(prm.getId())){
            return "PRO5_BASE";
        }

        String mrType = temporalClass.length() == 3 && temporalClass.endsWith("B") ?
                temporalClass.substring(0, 2) + "E" : temporalClass;

        return getSubProfileMapping(mrType);
    }

    private String getSubProfileMapping(String meterReadingType) {
        final String mrType = meterReadingType.length() == 3 && meterReadingType.endsWith("B") ?
                meterReadingType.substring(0, 2) + "E" : meterReadingType;

        return correlationTable.stream()
                .filter(correlation -> correlation.getMeterReadingType().equals(mrType))
                .map(CorrelationTable::getSubProfile)
                .findFirst()
                .orElseThrow(() -> new BusinessException("Mapping non trouvé pour le type de relève " + mrType));
    }

    private void validateParams(Map<String, Object> methodContext) {
        String prmRefsParam = methodContext.getOrDefault(PRM_REFS_PARAM, "").toString().trim();
        String rfpIdsParam = methodContext.getOrDefault(RFP_IDS_PARAM, "").toString().trim();
        String threadCountParam = methodContext.getOrDefault(THREAD_COUNT_PARAM, "").toString().trim();
        String memoryLimitParam = methodContext.getOrDefault(MEMORY_LIMIT_PARAM, "").toString().trim();
        getC5Lisse = methodContext.getOrDefault(C5_LISSE, C5_LISSE_DISABLED).toString().trim();
        if(!threadCountParam.isBlank()){
            try {
                threadCount = Integer.parseInt(threadCountParam);
                if (threadCount <= 0) {
                    throw new BusinessException("Le nombre de threads doit être supérieur à 0");
                }
            } catch (NumberFormatException e) {
                throw new BusinessException("Le paramètre 'threadCount' doit être un entier valide");
            }
        }

        if(!memoryLimitParam.isBlank()){
            try {
                memoryLimit = Double.parseDouble(memoryLimitParam);
                if (memoryLimit <= 0) {
                    throw new BusinessException("Le paramètre 'memoryLimit' doit être un nombre positif");
                }
            } catch (NumberFormatException e) {
                throw new BusinessException("Le paramètre 'memoryLimit' doit être un nombre valide");
            }
        }

        if(automaticJobLaunch) {
            profilingType = ProfilingTypeEnum.DEFAULT;
            return;
        }

        if (!prmRefsParam.isBlank() && !rfpIdsParam.isBlank()) {
            throw new BusinessException("Sélectionner un unique champ PRM ou AO");
        }

        if (!prmRefsParam.isBlank()) {
            prmRefs = getStringList(prmRefsParam);
            profilingType = ProfilingTypeEnum.PRM;
        }

        if (!rfpIdsParam.isBlank()) {
            rfpIds = getLongList(rfpIdsParam);
            profilingType = ProfilingTypeEnum.RFP;
        }
    }

    private List<String> getStringList(String curveIds) {
        return Stream.of(curveIds.split(SEMI_COLON)).collect(Collectors.toList());
    }

    private List<Long> getLongList(String curveIds) {
        return Stream.of(curveIds.split(SEMI_COLON))
                .map(strCurveId -> {
                    try {
                        return Long.parseLong(strCurveId);
                    } catch (NumberFormatException e) {
                        throw new BusinessException("ID invalide " + strCurveId);
                    }
                })
                .collect(Collectors.toList());
    }

    private synchronized void checkMemoryConsumption() {
        long memoryUsed = (Runtime.getRuntime().totalMemory() - Runtime.getRuntime().freeMemory())/1000000000;

        if (memoryUsed > memoryLimit) {
            if(gcLaunchTime == 0 || (System.currentTimeMillis() - gcLaunchTime) > GC_INTERVAL * 1000) {
                log.info("Memory usage is high: {} Gb used out of {} Gb ... Forcing garbage collection", memoryUsed, MAX_MEMORY);
                forceGarbageCollection();
                gcLaunchTime = System.currentTimeMillis();
            } else {
                log.info("Garbage collection already launched in the last {} seconds", GC_INTERVAL);
            }
        }
    }

    private void forceGarbageCollection() {
        System.gc();
        System.runFinalization();
        System.gc();
    }

    private void setJobReportData(Map<String, Object> methodContext) {
        if (!notFoundPrms.isEmpty()) {
            report.rep("PRM non trouvés et pour lesquels la reconstitution n'a pas été faite : \n" + String.join(", ", notFoundPrms));
        }

        if (!notFoundRfps.isEmpty()) {
            report.rep("AO non trouvés et pour lesquels la reconstitution n'a pas été faite : \n" + notFoundRfps);
        }

        if (!noMeasuresFoundPrms.isEmpty()) {
            report.rep("PRM pour lesquels aucune mesure n'a été trouvée : \n" + String.join(", ", noMeasuresFoundPrms));
        }

        if (!noProfileCoeffFoundPrms.isEmpty()) {
            report.rep("PRM pour lesquels les coefficients de profile n'ont pas été trouvés : \n" + String.join(", ", noProfileCoeffFoundPrms));
        }

        methodContext.put(JOB_RESULT_NB_WARN, warnCounter.get());
        methodContext.put(JOB_RESULT_REPORT, report.getReportBuilder().toString());
        methodContext.put(JOB_RESULT_NB_OK, okCounter.get());
        methodContext.put(JOB_RESULT_NB_KO, koCounter.get());
    }

