     * builds curves and persists results.
     *
     * @param prm PRM entity.
     * @throws BusinessException On processing errors or data inconsistencies.
     * @throws NoMeasuresFoundException If the PRM has no eligible billed measures.
     */
    private void processPrm(Prm prm) throws BusinessException, NoMeasuresFoundException {
        Map<String, Cdc> profileMap = new HashMap<>();
        List<BilledMeterReading> bmrList = getBilledMeterReadings(prm);
        //        report.rep("[1] début traitement de " + bmrList.size() + " relèves distributeur non estimé pour PRM " + prm.getReference());

        if (bmrList.isEmpty()) {
            throw new NoMeasuresFoundException("Aucune relève trouvée pour le PRM " + prm.getReference());
        }

        bmrList.forEach(bmr -> {
            String tClass = bmr.getTemporalClass();
            if (tClass.equals("HCB")) {
                bmr.setTemporalClass("HCE");
            } else if (tClass.equals("HPB")) {
                bmr.setTemporalClass("HPE");
            }
        });

        getFuds(prm, bmrList);

        MeterReadingList meterReadingList = new MeterReadingList();
        if(C5_LISSE_DISABLED.equals(getC5Lisse)){
            bmrList.forEach(meterReadingList::add);
        } else {
            bmrList.forEach(meterReadingList::addDailySplit);
        }

   /*     report.rep("[2] équivalent de " + meterReadingList.getList().size() + " meterReading pour PRM " + prm.getReference());
        meterReadingList.getList().forEach(mr -> {
            report.rep("MeterReading [" + mr.getStartDate().toLocalDate() + " -> " + mr.getEndDate().toLocalDate() + "]");
            for (Map.Entry<String, BilledMeterReading> e : mr.getBmrList().entrySet()) {
                if(!"BASE".equals(e.getKey()) && e.getValue().getMeasure() > 0D){
                    report.rep("   " + e.getKey() + " => " + e.getValue());
                }
            }
        }); */

        String fournisseurTemporalCat = getLastFournisseurMeasureTemporalClass(prm);
        addPrmToPosteMap(prm.getId(), getPrmPoste(prm));

        Map<String, CdcOptimized> cdcMap = new HashMap<>();
        String targetClassCat = getPrmTargetClass(prm, fournisseurTemporalCat);
        // report.rep("[3] la classe temp de la dernière relève est : " + targetClassCat + " pour prm " + prm.getReference() + " contenant " + bmrList.size() + " relèves.");
        // Note : profileMap supprimée — le cache de templates (templateCache) joue ce rôle
        // au niveau du job entier, partagé entre tous les PRMs et tous les threads.
        handleMeterReadingList(prm, targetClassCat, cdcMap, meterReadingList);
        // Save curves
        saveCurves(prm, cdcMap, targetClassCat);
        prmIdsList.add(prm.getId());
        okCounter.incrementAndGet();
    }

