    public Double getPeakAverage(boolean ignoreNulls) {
        double sum = 0D;
        int count = 0;
        for (int i = 0; i < cdcPuissances.length; i++) {
            if ((!ignoreNulls || !isMissing(cdcPuissances[i])) && isPeakHour(cdcDates.get(i))) {
                if (!isMissing(cdcPuissances[i])) {
                    sum += cdcPuissances[i];
                    count++;
                }
            }
        }
        return count == 0 ? 0D : sum / count;
    }

    public Double getPeakAverage() {
        return getPeakAverage(true);
    }

    public Double getOffPeakAverage(boolean ignoreNulls) {
        double sum = 0D;
        int count = 0;
        for (int i = 0; i < cdcPuissances.length; i++) {
            if ((!ignoreNulls || !isMissing(cdcPuissances[i])) && !isPeakHour(cdcDates.get(i))) {
                if (!isMissing(cdcPuissances[i])) {
                    sum += cdcPuissances[i];
                    count++;
                }
            }
        }
        if (count == 0) {
            throw new BusinessException("No off-peak data found");
        }
        return sum / count;
    }

    public Double getOffPeakAverage() {
        return getOffPeakAverage(true);
    }

    public static boolean isPeakHour(ZonedDateTime date) {
        int hour = date.withZoneSameInstant(currentZoneId).getHour();
        int dayOfWeek = date.withZoneSameInstant(currentZoneId).getDayOfWeek().getValue();
        return (hour >= 8 && hour < 20 && dayOfWeek >= 1 && dayOfWeek <= 5);
    }

    public void divideByCdc(CdcOpti cdcOpti){
        cdcOpti.extendCdc(cdcDateDebut, cdcDateFin, null);

        double[] divisor = cdcOpti.cdcPuissances;
        for(int i = 0; i < cdcPuissances.length; i++) {
            if(!isMissing(cdcPuissances[i]) && !isMissing(divisor[i]) && divisor[i] != 0D) {
                cdcPuissances[i] = cdcPuissances[i] / divisor[i];
            } else {
                cdcPuissances[i] = Double.NaN;
            }
        }
    }

    public void multiplyBy(Double factor) {
        double primitiveFactor = toPrimitive(factor);
        for (int i = 0; i < cdcPuissances.length; i++) {
            if (!isMissing(cdcPuissances[i])) {
                cdcPuissances[i] *= primitiveFactor;
            }
        }
    }

    private void remplirCdc(StepEnum pas, ZonedDateTime debut, ZonedDateTime fin, Double defaultValue) {
        try {
            int nbPoints = calculerNbPoints(pas, debut, fin);

            if (nbPoints > 0) {
                cdcDates = new ArrayList<>(nbPoints);
                cdcPuissances = new double[nbPoints];
                Arrays.fill(cdcPuissances, toPrimitive(defaultValue));
                cdcDateDebut = debut.withZoneSameInstant(currentZoneId);
                cdcDateFin = fin.withZoneSameInstant(currentZoneId);
                cdcPas = pas;
                reconstruireDates(nbPoints);
            }
            initCurve();
        } catch (Exception e) {
            throw new BusinessException(e);
        }
    }

    public Duration calculerIntervalle(StepEnum pas) {
        Duration interval = null;
        switch (pas) {
            case Horaire:
                interval = Duration.ofHours(1);
                break;
            case SemiHoraire:
                interval = Duration.ofMinutes(30);
                break;
            case DixMinutes:
                interval = Duration.ofMinutes(10);
                break;
            case CinqMinutes:
                interval = Duration.ofMinutes(5);
                break;
            case Journalier:
                interval = Duration.ofDays(1);
                break;
            // TODO : add monthly step
//            case Mensuel:
//                interval = Duration.ofDays(31);
//                break;
        }
        return interval;
    }

    public static int calculerNbPtsParHeure(StepEnum pas) {
        int n = 0;
        switch (pas) {
            case Horaire:
            case Journalier:
                // TODO : add monthly step
//            case Mensuel:
                n = 1;
                break;
            case SemiHoraire:
                n = 2;
                break;
            case QuinzeMinutes:
                n = 4;
                break;
            case CinqMinutes:
                n = 12;
                break;
            case DixMinutes:
                n = 6;
                break;
        }
        return n;
    }

    // set dates of cdcDates as the first value is the start date and the last one in end date
    // and the rest are calculated based on the step
    // handle also the case of the daylight saving time
    public void reconstruireDates(){
        StepEnum pas = cdcPas;
        ZonedDateTime dateCourante = cdcDateDebut;
        cdcDates = new ArrayList<>();
        while (dateCourante.isBefore(cdcDateFin) || dateCourante.isEqual(cdcDateFin)) {
            cdcDates.add(dateCourante);

            if(pas != StepEnum.Journalier) {
                dateCourante = dateCourante.plusMinutes(pas.getDurationInMinutes());
            } else {
                dateCourante = dateCourante.plusDays(1).withHour(0).withMinute(0);
            }
        }
    }

    public void reconstruireDates(int n){
        cdcDates = IntStream.range(0, n).parallel()
                .mapToObj(i -> {
                    if(cdcPas != StepEnum.Journalier) {
                        return cdcDateDebut.plusMinutes((long) i * cdcPas.getDurationInMinutes());
                    } else {
                        return cdcDateDebut.plusDays(i).withHour(0).withMinute(0);
                    }
                })
                .collect(Collectors.toCollection(() -> new ArrayList<>(n)));

        cdcDateFin = cdcDates.get(cdcDates.size() - 1);
        if(curve != null) {
            curve.setEndDate(cdcDateFin);
        }
    }

    public int calculerNbPoints(StepEnum pas, ZonedDateTime debut, ZonedDateTime fin) {
        int division = 0;
        int nbPoints;
        int i = 0;
        ZonedDateTime datecourante = debut;
        switch (pas) {
            case Horaire:
                division = 24;
                break;
            case SemiHoraire:
                division = 48;
                break;
            case QuinzeMinutes:
                division = 96;
                break;
            case DixMinutes:
                division = 144;
                break;
            case CinqMinutes:
                division = 288;
                break;
            case Journalier:
                long daysBetween = ChronoUnit.DAYS.between(debut, fin);
                nbPoints = Math.round((float) daysBetween + 1);
                return nbPoints;
        }

        try {
            ZonedDateTime dateDebut = ofNullable(debut).orElseThrow(() -> new BusinessException("Date de début non renseignée pour générer une CDC"));
            ZonedDateTime dateFin = ofNullable(fin).orElseThrow(() -> new BusinessException("Date de fin non renseignée pour générer une CDC"));

            float hours = (float) (dateFin.toEpochSecond()-dateDebut.toEpochSecond()) / 3600;
            nbPoints = Math.round((hours * division) / 24) + 1;
        } catch (Exception e) {

            long differenceInMillis = ChronoUnit.MILLIS.between(debut, fin);
            double differenceInDays = (double) differenceInMillis / (1000 * 60 * 60 * 24);
            nbPoints = (int) Math.round(differenceInDays * division) + 1;

            // On recherche le nombre d'heure à supprimer et à ajouter
            while (datecourante.isBefore(fin)) {
                if (isChgtHeureMars(datecourante))
                    i--;
                else if (isChgtHeureOctobre(datecourante))
                    i++;
                datecourante = datecourante.plusHours(1);
            }
            nbPoints += i * (division / 24);
        }

        return nbPoints;
    }

    private boolean isChgtHeureMars(ZonedDateTime date) {
        return date.getDayOfWeek().getValue() == 7 && date.getMonth().getValue() == 3 && date.getDayOfMonth() > 24;
    }

    private boolean isChgtHeureOctobre(ZonedDateTime date) {
        return date.getDayOfWeek().getValue() == 7 && date.getMonth().getValue() == 10 && date.getDayOfMonth() > 24;
    }

    private OffsetDateTime calculerDateDebutOffset(ZonedDateTime date, Duration offset, ZoneId timezone) {
        date = date.minus(offset);
        // Winter time
        if (isChgtHeureOctobre(date.plus(offset)))
            return OffsetDateTime.of(date.toLocalDateTime(), ZoneOffset.ofHours(2));
            // Summer time
        else if (isChgtHeureMars(date.plus(offset)))
            return OffsetDateTime.of(date.toLocalDateTime(), ZoneOffset.ofHours(1));
        return OffsetDateTime.of(date.toLocalDateTime(), ZoneId.systemDefault().getRules().getOffset(date.toLocalDateTime()));
    }

    private OffsetDateTime calculerDateFinOffset(ZonedDateTime date, Duration offset, ZoneId timezone) {
        date = date.minus(offset);
        // Winter time
        if (isChgtHeureOctobre(date.plus(offset)))
            return OffsetDateTime.of(date.toLocalDateTime(), ZoneOffset.ofHours(1));
            // Summer time
        else if (isChgtHeureMars(date.plus(offset)))
            return OffsetDateTime.of(date.toLocalDateTime().minusMinutes(date.getMinute()).minus(offset), ZoneOffset.ofHours(1));
        return OffsetDateTime.of(date.toLocalDateTime(), ZoneId.systemDefault().getRules().getOffset(date.toLocalDateTime()));
    }

    public static byte[] convertDoublesToBytes(double[] values) {
        byte[] bytes = new byte[values.length * Double.BYTES];
        for (int i = 0; i < values.length; i++) {
            long value = Double.doubleToLongBits(values[i]);
            for (int j = 0; j < Double.BYTES; j++) {
                bytes[i * Double.BYTES + j] = (byte) ((value >> (j * 8)) & 0xFF);
            }
        }
        return bytes;
    }

    public static double[] convertBytesToDoubles(byte[] bytes) {
        double[] values = new double[bytes.length / Double.BYTES];
        for (int i = 0; i < values.length; i++) {
            long value = 0L;
            for (int j = 0; j < Double.BYTES; j++) {
                value |= ((long) bytes[i * Double.BYTES + j] & 0xFF) << (j * 8);
            }
            values[i] = Double.longBitsToDouble(value);
        }
        return values;
    }

    private StepEnum getStepEnum(ZonedDateTime start, ZonedDateTime end) {
        long diff = start.toLocalDateTime().toInstant(OffsetTime.now().getOffset()).toEpochMilli()
                - end.toLocalDateTime().toInstant(OffsetTime.now().getOffset()).toEpochMilli();

        if (diff == 3600000) {
            return StepEnum.Horaire;
        } else if (diff == 1800000) {
            return StepEnum.SemiHoraire;
        } else if (diff == 600000) {
            return StepEnum.DixMinutes;
        } else if (diff == 900000) {
            return StepEnum.QuinzeMinutes;
        } else if (diff == 86400000) {
            return StepEnum.Journalier;
        } else {
            throw new BusinessException("Invalid step");
        }
    }

    public static void unifyStep(CdcOpti cdcOpti1, CdcOpti cdcOpti2){
        // unify the step of the two cdc in order to have  the step with lowest duration
        StepEnum step1 = cdcOpti1.getCdcPas();
        StepEnum step2 = cdcOpti2.getCdcPas();
        if(step1.getDurationInMinutes() < step2.getDurationInMinutes()){
            changerPas(cdcOpti2, step1);
        } else {
            changerPas(cdcOpti1, step2);
        }
    }

    public static CdcOpti changerPas(CdcOpti cdcOpti, StepEnum stepEnum) {
        StepEnum oldStep = cdcOpti.getCdcPas();

        if ((oldStep == StepEnum.QuinzeMinutes && stepEnum == StepEnum.DixMinutes) ||
                (oldStep == StepEnum.DixMinutes && stepEnum == StepEnum.QuinzeMinutes)) {
            cdcOpti = changerPas(cdcOpti, StepEnum.CinqMinutes);
            oldStep = StepEnum.CinqMinutes;
        }

        if(oldStep == StepEnum.Journalier || stepEnum == StepEnum.Journalier) {
            return changerPasJournalier(cdcOpti, stepEnum);
        }
        int oldPNumber = CdcOpti.calculerNbPtsParHeure(oldStep);
        int newPNumber = CdcOpti.calculerNbPtsParHeure(stepEnum);

        if(cdcOpti.getCurve()!= null) cdcOpti.getCurve().setStep(stepEnum);
        cdcOpti.setCdcPas(stepEnum);

        double[] puissances = cdcOpti.getCdcPuissances();

        long totalMinutes = ChronoUnit.MINUTES.between(cdcOpti.getCdcDateDebut(), cdcOpti.getCdcDateFin());
        int newPointCount = (int) (totalMinutes / stepEnum.getDurationInMinutes()) + 1;
        double[] newPuissances = new double[newPointCount];
        Arrays.fill(newPuissances, Double.NaN);

        if (newPNumber < oldPNumber) {
            int conversionFactor = oldPNumber / newPNumber;
            int out = 0;
            for (int i = 0; i < puissances.length && out < newPointCount; i += conversionFactor) {
                double sum = 0;
                int count = 0;
                for (int j = 0; j < conversionFactor && (i + j) < puissances.length; j++) {
                    if (!isMissing(puissances[i + j])) {
                        sum += puissances[i + j];
                        count++;
                    }
                }
                newPuissances[out++] = count == 0 ? Double.NaN : sum / count;
            }
        } else if (newPNumber > oldPNumber) {
            int conversionFactor = newPNumber / oldPNumber;
            int out = 0;
            for (double value : puissances) {
                for (int j = 0; j < conversionFactor && out < newPointCount; j++) {
                    newPuissances[out++] = value;
                }
            }
        } else {
            System.arraycopy(puissances, 0, newPuissances, 0, Math.min(puissances.length, newPointCount));
            if (puissances.length < newPointCount && puissances.length > 0) {
                Arrays.fill(newPuissances, puissances.length, newPointCount, puissances[puissances.length - 1]);
            }
        }

        cdcOpti.setCdcPuissances(newPuissances);
        cdcOpti.reconstruireDates(newPuissances.length);

        if(cdcOpti.getCurve() != null && cdcOpti.getCurve().getBinaryCurve() != null){
            cdcOpti.getCurve().getBinaryCurve().setData(convertDoublesToBytes(newPuissances));
            cdcOpti.getCurve().setStartDate(cdcOpti.getCdcDateDebut());
            cdcOpti.getCurve().setEndDate(cdcOpti.getCdcDateFin());
        }

        return cdcOpti;
    }

    private static CdcOpti changerPasJournalier(CdcOpti cdcOpti, StepEnum newStep) {
        StepEnum oldStep = cdcOpti.getCdcPas();
        double[] puissances = cdcOpti.getCdcPuissances();
        List<Double> newPuissancesList = new ArrayList<>();

        ZonedDateTime indexStartDate;
        ZonedDateTime indexEndDate;

        if(cdcOpti.getCurve()!= null) cdcOpti.getCurve().setStep(newStep);
        cdcOpti.setCdcPas(newStep);

        if(newStep == StepEnum.Journalier && oldStep == StepEnum.Journalier) {
            cdcOpti.setCdcPuissances(Arrays.copyOf(puissances, puissances.length));
        } else if(newStep == StepEnum.Journalier) {
            for(int i = 0 ; i < puissances.length; i++) {
                indexStartDate = cdcOpti.getCdcDates().get(i);
                indexEndDate = cdcOpti.getCdcDates().get(i).withHour(23).withMinute(59);
                double sum = 0;
                int count = 0;

                while(i < puissances.length && indexStartDate.isBefore(indexEndDate)) {
                    if(!isMissing(puissances[i])){
                        sum += puissances[i];
                        count++;
                    }

                    if( (i+1) < puissances.length && indexStartDate.plusMinutes(oldStep.getDurationInMinutes()).isBefore(indexEndDate)){
                        indexStartDate = cdcOpti.getCdcDates().get(i+1);
                        i++;
                    } else {
                        indexStartDate = indexStartDate.plusMinutes(oldStep.getDurationInMinutes());
                    }
                }

                newPuissancesList.add(count == 0 ? null : sum/count);
            }
            cdcOpti.setCdcPuissances(toPrimitiveArray(newPuissancesList));
        } else if (oldStep == StepEnum.Journalier) {
            for (int i = 0; i < puissances.length; i++) {
                indexStartDate = cdcOpti.getCdcDates().get(i);
                indexEndDate = cdcOpti.getCdcDates().get(i).plusDays(1);

                while (indexStartDate.isBefore(indexEndDate)) {
                    newPuissancesList.add(toWrapper(puissances[i]));
                    indexStartDate = indexStartDate.plusMinutes(newStep.getDurationInMinutes());
                }
            }
            cdcOpti.setCdcDateFin(cdcOpti.getCdcDateFin().plusDays(1).minusMinutes(newStep.getDurationInMinutes()));
            cdcOpti.setCdcPuissances(toPrimitiveArray(newPuissancesList));
        }

        cdcOpti.reconstruireDates();

        return cdcOpti;
    }

    public boolean datesAreContinuous(CdcOpti cdcOpti) {

        if (cdcDates.isEmpty() || cdcOpti.getCdcDates().isEmpty()) {
            return true;
        }

        ZonedDateTime startDate1 = cdcDates.get(0);
        ZonedDateTime endDate1 = cdcDates.get(cdcDates.size() - 1);
        ZonedDateTime startDate2 = cdcOpti.getCdcDates().get(0);
        ZonedDateTime endDate2 = cdcOpti.getCdcDates().get(cdcOpti.getCdcDates().size() - 1);

        int minimumDuration = Math.min(cdcPas.getDurationInMinutes(), cdcOpti.getCdcPas().getDurationInMinutes());
        Duration stepDuration = Duration.ofMinutes(minimumDuration);

        // Check if periods overlap
        boolean isOverlapping = endDate1.isAfter(startDate2) && startDate1.isBefore(endDate2);

        // Check the gap between the end of one period and the start of the other
        Duration gapAfter = Duration.between(endDate1, startDate2);
        Duration gapBefore = Duration.between(endDate2, startDate1);

        boolean isWithinStepAfter = !gapAfter.isNegative() && gapAfter.compareTo(stepDuration) <= 0;
        boolean isWithinStepBefore = !gapBefore.isNegative() && gapBefore.compareTo(stepDuration) <= 0;

        return isOverlapping || isWithinStepAfter || isWithinStepBefore;

    }

    public void mergeCdcAndIgnoreDiscontinuity(CdcOpti cdcOpti, Double defaultValue){
        extendCdc(cdcOpti.getCdcDateDebut(), cdcOpti.getCdcDateFin(), defaultValue);
        int startIndex = getReducedStartDateIndex(cdcOpti.getCdcDateDebut());
        int lastIndex = getReducedEndDateIndex(cdcOpti.getCdcDateFin());
        double[] otherValues = cdcOpti.getCdcPuissances();
        for (int i = startIndex; i <= lastIndex; i++) {
            double value = otherValues[i - startIndex];
            if (!isMissing(value)) {
                cdcPuissances[i] = value;
            }
        }
        curve.getBinaryCurve().setData(convertDoublesToBytes(cdcPuissances));
