    private String getSubProfile(Prm prm, String temporalClass) {
        if (prm.getSubProfile() != null && !prm.getSubProfile().isBlank() && prm.getSubProfile().contains("BASE")) {
            return prm.getSubProfile();
        }

        List<Long> pro5 = prmIdsByPoste.get("PRO5");
        if("BASE".equals(temporalClass) && pro5 != null && pro5.contains(prm.getId())){
            return "PRO5_BASE";
        }

        String mrType = temporalClass.length() == 3 && temporalClass.endsWith("B") ?
                temporalClass.substring(0, 2) + "E" : temporalClass;

        return getSubProfileMapping(mrType);
    }

    private String getSubProfileMapping(String meterReadingType) {
        final String mrType = meterReadingType.length() == 3 && meterReadingType.endsWith("B") ?
                meterReadingType.substring(0, 2) + "E" : meterReadingType;

        return correlationTable.stream()
                .filter(correlation -> correlation.getMeterReadingType().equals(mrType))
                .map(CorrelationTable::getSubProfile)
                .findFirst()
                .orElseThrow(() -> new BusinessException("Mapping non trouvé pour le type de relève " + mrType));
    }

    private void validateParams(Map<String, Object> methodContext) {
        String prmRefsParam = methodContext.getOrDefault(PRM_REFS_PARAM, "").toString().trim();
        String rfpIdsParam = methodContext.getOrDefault(RFP_IDS_PARAM, "").toString().trim();
        String threadCountParam = methodContext.getOrDefault(THREAD_COUNT_PARAM, "").toString().trim();
        String memoryLimitParam = methodContext.getOrDefault(MEMORY_LIMIT_PARAM, "").toString().trim();
        getC5Lisse = methodContext.getOrDefault(C5_LISSE, C5_LISSE_DISABLED).toString().trim();
        if(!threadCountParam.isBlank()){
            try {
                threadCount = Integer.parseInt(threadCountParam);
                if (threadCount <= 0) {
                    throw new BusinessException("Le nombre de threads doit être supérieur à 0");
                }
            } catch (NumberFormatException e) {
                throw new BusinessException("Le paramètre 'threadCount' doit être un entier valide");
            }
        }

        if(!memoryLimitParam.isBlank()){
            try {
                memoryLimit = Double.parseDouble(memoryLimitParam);
                if (memoryLimit <= 0) {
                    throw new BusinessException("Le paramètre 'memoryLimit' doit être un nombre positif");
                }
            } catch (NumberFormatException e) {
                throw new BusinessException("Le paramètre 'memoryLimit' doit être un nombre valide");
            }
        }

        if(automaticJobLaunch) {
            profilingType = ProfilingTypeEnum.DEFAULT;
            return;
        }

        if (!prmRefsParam.isBlank() && !rfpIdsParam.isBlank()) {
            throw new BusinessException("Sélectionner un unique champ PRM ou AO");
        }

        if (!prmRefsParam.isBlank()) {
            prmRefs = getStringList(prmRefsParam);
            profilingType = ProfilingTypeEnum.PRM;
        }

        if (!rfpIdsParam.isBlank()) {
            rfpIds = getLongList(rfpIdsParam);
            profilingType = ProfilingTypeEnum.RFP;
        }
    }

