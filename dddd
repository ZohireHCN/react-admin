    @Override
    public void execute(Map<String, Object> context) throws BusinessException {
        ReportDto report = new ReportDto();
        String invoicesParam = getStringParam(context, INVOICES_ID_JOB_PARAM);
        String bordereauxParam = getStringParam(context, BORDEREAUX_ID_JOB_PARAM);
        String motifCode = getStringParam(context, MOTIF_ID_JOB_PARAM);
        MeveoUser currentUser = (MeveoUser) context.get(Script.CONTEXT_CURRENT_USER);
        try {
            if (isEmpty(invoicesParam) && isEmpty(bordereauxParam)) {
                if(isEmpty(motifCode)) {
                    initializeDirectoriesIfNeeded(report);
                    return;
                }
                if (hasInputFiles()) processInputFiles(report, currentUser);
                else report.addReport(MSG_FACTURE_NI_BORDEREAU_A_TRAITER);
                return;
            }
            Long motifId = validateMotif(motifCode);
            if (!isEmpty(invoicesParam)) processInvoices(parseIds(invoicesParam), motifId, report,currentUser);
            if (!isEmpty(bordereauxParam)) processBordereaux(parseIds(bordereauxParam), motifId, report,currentUser);

        } catch (Exception e) {
            report.addReport(e.getMessage());
        } finally {
            flushReportInContext(context, report);
        }
    }

    public boolean hasInputFiles() throws IOException {
        try (Stream<Path> files = Files.list(getInputDirectoryPath())) {
            return files.anyMatch(Files::isRegularFile);
        }
    }

    public void processInputFiles(ReportDto report, MeveoUser currentUser) throws IOException {

        try (Stream<Path> files = Files.list(getInputDirectoryPath())) {
            files.filter(Files::isRegularFile)
                    .forEach(file -> {
                        try {
                            processSingleInputFile(file, report, currentUser);
                        } catch (Exception e) {
                            report.addReport(ERREUR_TRAITEMENT_FICHIER + file.getFileName() + " : " + e.getMessage());
                            report.addNbKO();
                        }
                    });
        }
    }

    public void processSingleInputFile(Path inputFile, ReportDto report, MeveoUser currentUser) throws Exception {
        List<String> outputLines = new ArrayList<>();
        List<String> rejectLines = new ArrayList<>();
        List<String> lines = Files.readAllLines(inputFile, StandardCharsets.UTF_8);
        outputLines.add("FACTURE;BORDEREAU;RESULT");
        rejectLines.add("FACTURE;BORDEREAU;ERROR");
        for (int i = 0; i < lines.size(); i++) {
            String line = lines.get(i);
            if (isEmpty(line)) continue;
            try {
                processInputLine(line,report, currentUser);
                outputLines.add(line + ";OK");
            } catch (Exception e) {
                rejectLines.add(line + ";" + e.getMessage());
                report.addNbKO();
            }
        }
        writeOutputFile(inputFile, outputLines);
        writeRejectFile(inputFile, rejectLines);
        moveFileToArchive(inputFile);
    }
    public void processInputLine(String line, ReportDto report, MeveoUser currentUser) throws BusinessException {
        String[] values = line.split(";", -1);
        if (values.length < 3) {
            throw new BusinessException(FORMAT_INVALIDE_FACTURE_BORDEREAU_MOTIF_ATTENDU);
        }
        String invoiceValue = values[0].trim();
        String bordereauValue = values[1].trim();
        Long motifId = validateMotif(values[2].trim());
        if (!isEmpty(invoiceValue)) {
            this.processSingleInvoiceTransac(Long.valueOf(invoiceValue), motifId, report, false, currentUser);
            report.addNbOK();
            return;
        }
        if (!isEmpty(bordereauValue)) {
            this.processSingleBordereau(Long.valueOf(bordereauValue), motifId, report, currentUser);
            report.addNbOK();
            return;
        }
        throw new BusinessException(AUCUNE_FACTURE_OU_BORDEREAU_RENSEIGNÉ);
    }

    public void processInvoices(List<Long> invoiceIds, Long motifId, ReportDto report, MeveoUser currentUser) {
        for (Long invoiceId : invoiceIds) {
            this.processSingleInvoiceTransac(invoiceId, motifId, report, false,currentUser);
        }
    }

    @TransactionAttribute(TransactionAttributeType.REQUIRED)
    public void processSingleInvoiceTransac(Long invoiceId,Long motifId,ReportDto report,boolean fromBordereau,MeveoUser currentUser) throws BusinessException {
        try {
            this.processSingleInvoice(invoiceId, motifId, report, fromBordereau,currentUser);
        } catch (Exception e) {
            report.addReport("\n" + e.getMessage());
            report.addNbKO();
        }
    }

    public void processSingleInvoice(Long invoiceId,Long motifId,ReportDto report,boolean fromBordereau,MeveoUser currentUser) throws BusinessException {
        Invoice invoice = findInvoiceById(invoiceId);
        if (invoice == null)  throw new BusinessException("Facture ID " + invoiceId + MSG_FAIT_PARTIE_D_UN_BORDEREAU);
        if (!fromBordereau && isInvoiceAttachedToBordereau(invoiceId)) throw new BusinessException("Facture ID " + invoiceId + MSG_FAIT_PARTIE_D_UN_BORDEREAU1);
        if (hasAlreadyInternalCreditNote(invoiceId)) throw new BusinessException("Facture ID " + invoiceId + MSG_FAIT_L_OBJET_D_UN_AVOIR_INTERNE);
        Invoice creditNote = unitCancelInvoice(currentUser, invoice);
        updateInitialInvoiceAsCancelled(invoice, motifId);
        createInvoiceCreditNoteMatching(invoice.getBillingAccount().getId(),invoice.getId(),creditNote.getId(),motifId);
        if (fromBordereau) report.addNbWARN();
        else report.addNbOK();
    }

    public Invoice unitCancelInvoice(MeveoUser currentUser, Invoice baseInvoice) {
        Invoice cancelInvoice = new Invoice();
        cancelInvoice.setDueDate(new Date());
        cancelInvoice.setInvoiceDate(new Date());

        /* type */
        InvoiceType cancelInvoiceType = this.invoiceTypeService.getDefaultType(InvoiceCreditNoteScript.INVOICE_DEFAULT_TYPE);
        cancelInvoice.setInvoiceType(cancelInvoiceType);

        /* seller */
        cancelInvoice.setSeller(baseInvoice.getSeller());
        cancelInvoice.setBillingAccount(baseInvoice.getBillingAccount());

        cancelInvoice.setAmountWithoutTax(BigDecimal.ZERO);
        cancelInvoice.setAmountWithTax(BigDecimal.ZERO);
        cancelInvoice.setAmountTax(BigDecimal.ZERO);
        cancelInvoice.setNetToPay(BigDecimal.ZERO);

        /* import rated Data */
        InvoiceAggregateHandler invoiceAggregateHandler = this.importRatedTransaction(baseInvoice, cancelInvoice);

        /* save in BD */
        this.saveInBD(cancelInvoice, baseInvoice, invoiceAggregateHandler,currentUser);
        return cancelInvoice;
    }

    public void saveInBD(Invoice cancelInvoice, Invoice baseInvoice, InvoiceAggregateHandler invoiceAggregateHandler , MeveoUser currentUser) {
        for (Map.Entry<String, TaxInvoiceAgregate> entry : invoiceAggregateHandler.getTaxInvAgregateMap().entrySet()) {
            TaxInvoiceAgregate taxInvAgr = entry.getValue();
            taxInvAgr.setInvoice(cancelInvoice);
            taxInvAgr.updateAudit(currentUser);
        }
        for (Map.Entry<String, CategoryInvoiceAgregate> entry : invoiceAggregateHandler.getCatInvAgregateMap().entrySet()) {
            CategoryInvoiceAgregate catInvAgr = entry.getValue();
            catInvAgr.setInvoice(cancelInvoice);
            catInvAgr.updateAudit(currentUser);
            catInvAgr.setSubCategoryInvoiceAgregates(new HashSet<>());
        }
        List<RatedTransaction> rts = new ArrayList<>();
        for (SubCategoryInvoiceAgregate subCatInvAggr : invoiceAggregateHandler.getSubCatInvAgregateMap().values()) {
            subCatInvAggr.setInvoice(cancelInvoice);
            subCatInvAggr.updateAudit(currentUser);
            for (RatedTransaction rt : subCatInvAggr.getRatedtransactionsToAssociate()) {
                rt.setInvoice(cancelInvoice);
                rt.setInvoiceAgregateF(subCatInvAggr);
                rt.changeStatus(RatedTransactionStatusEnum.BILLED);
                rts.add(rt);
            }
        }
        cancelInvoice.getLinkedInvoices().add(baseInvoice);
        this.invoiceService.create(cancelInvoice);
        for (RatedTransaction rt : rts) {
            if (rt.getId() == null) {
                this.ratedTransactionService.create(rt);
            } else {
                this.ratedTransactionService.update(rt);
            }
        }
        // TODO : à confirmer ?
        /** invoiceService.postCreate(cancelInvoice);

         cancelInvoice = serviceSingleton.assignInvoiceNumberVirtual(cancelInvoice);
         this.invoiceService.generateXmlAndPdfInvoice(cancelInvoice, true);
         **/
    }

    public InvoiceAggregateHandler importRatedTransaction(Invoice baseInvoice, Invoice cancelInvoice) {
        CustomFieldValues baseCfValues = baseInvoice.getCfValuesNullSafe();
        Map<String, List<CustomFieldValue>> newValues = new HashMap<>(baseCfValues.getValuesByCode());
        newValues.remove(INVOICE_CF_SENDING_MAIL_VALUE_CF);
        newValues.remove(CF_INV_NUM_BORDEREAU);
        newValues.remove(CF_INV_FIBU_FILES);
        newValues.remove(INVOICE_CF_VALUE_KEY);
        CustomFieldValues newCfValues = new CustomFieldValues(newValues);
        cancelInvoice.setCfValues(newCfValues);
        cancelInvoice.setDetailedInvoice(baseInvoice.isDetailedInvoice());
        UserAccount userAccount = this.userAccountService.retrieveIfNotManaged(cancelInvoice.getBillingAccount().getUsersAccounts().get(0));
        List<RatedTransaction> ratedTransactions = ratedTransactionService.getRatedTransactionsByInvoice(baseInvoice, true);
        aggregateHandler.reset();
        for (RatedTransaction ratedTransaction: ratedTransactions) {
            if (!DateUtils.isWithinDate(ratedTransaction.getUsageDate(), null, null)) {
                continue;
            }
            TaxMappingService.TaxInfo taxInfo = null;
            if (ratedTransaction.getTaxClass() != null) {
                taxInfo = taxMappingService.determineTax(ratedTransaction.getTaxClass(),ratedTransaction.getSeller(),cancelInvoice.getBillingAccount(),userAccount, cancelInvoice.getInvoiceDate(), true, false);
            }
            RatedTransaction newRT = new RatedTransaction(ratedTransaction.getUsageDate(), ratedTransaction.getUnitAmountWithoutTax(), ratedTransaction.getUnitAmountWithTax(), ratedTransaction.getUnitAmountTax(), ratedTransaction.getQuantity(), ratedTransaction.getAmountWithoutTax(),
                    ratedTransaction.getAmountWithTax(), ratedTransaction.getAmountTax(), RatedTransactionStatusEnum.BILLED, userAccount.getWallet(), cancelInvoice.getBillingAccount(), userAccount, ratedTransaction.getInvoiceSubCategory(), ratedTransaction.getParameter1(), ratedTransaction.getParameter2(),
                    ratedTransaction.getParameter3(), null, ratedTransaction.getOrderNumber(), null, ratedTransaction.getUnityDescription(), ratedTransaction.getRatingUnitDescription(), null, null, null, ratedTransaction.getCode(), ratedTransaction.getDescription(), ratedTransaction.getStartDate(),
                    ratedTransaction.getEndDate(), ratedTransaction.getSeller(), taxInfo != null ? taxInfo.tax : ratedTransaction.getTax(), taxInfo != null ? taxInfo.tax.getPercent() : ratedTransaction.getTax().getPercent(), null,
                    taxInfo != null ? taxInfo.taxClass : null, null);
            newRT.setInvoice(cancelInvoice);
            aggregateHandler.addRT(cancelInvoice.getInvoiceDate(), newRT);
        }
        this.updateAmountsAndLines(aggregateHandler, cancelInvoice);
        return aggregateHandler;
    }

    public void updateAmountsAndLines(InvoiceAggregateHandler invoiceAggregateHandler, Invoice cancelInvoice) throws BusinessException {
        Provider appProvider = this.providerService.getProvider();
        // TODO : à verfier HT, TVA, TTC
        cancelInvoice.setAmountWithoutTax(round(invoiceAggregateHandler.getInvoiceAmountWithoutTax(), appProvider.getInvoiceRounding(), appProvider.getInvoiceRoundingMode()).negate());
        cancelInvoice.setAmountTax(round(invoiceAggregateHandler.getInvoiceAmountTax(), appProvider.getInvoiceRounding(), appProvider.getInvoiceRoundingMode()).negate());
        cancelInvoice.setAmountWithTax(round(invoiceAggregateHandler.getInvoiceAmountWithTax(), appProvider.getInvoiceRounding(), appProvider.getInvoiceRoundingMode()).negate());
        cancelInvoice.setNetToPay(cancelInvoice.getAmountWithTax().negate());
    }


    public void processBordereaux(List<Long> bordereauIds, Long motif, ReportDto report, MeveoUser currentUser) {
        for (Long bordereauId : bordereauIds) {
            try {
                this.processSingleBordereau(bordereauId, motif, report,currentUser);
                report.addNbOK();
            } catch (Exception e) {
                report.addReport("\r\n " + e.getMessage());
                report.addNbKO();
            }
        }
    }

    @TransactionAttribute(TransactionAttributeType.REQUIRED)
    public void processSingleBordereau(Long bordereauId, Long motifCode, ReportDto report, MeveoUser currentUser) throws BusinessException {
        try {
            BordereauDto bordereau = findBordereauById(bordereauId);

            if (Boolean.TRUE.equals(bordereau.getCancelled())) {
                throw new BusinessException("Bordereau "+bordereauId+" déjà avoirisé");
            }
            updateBordereauAsCancelled(bordereauId, motifCode);
            List<Long> invoiceIds = findInvoiceIdsByBordereauId(bordereauId);
            for (Long invoiceId : invoiceIds) {
                this.processSingleInvoice(invoiceId, motifCode, report, true,currentUser);
            }
        } catch (Exception e) {
            throw new BusinessException("Error Bordereau "+bordereauId);
        }


    }

    private Invoice findInvoiceById(Long invoiceId) {
        return this.invoiceService.getEntityManager().createQuery(QUERY_FIND_INVOICE_BY_ID, Invoice.class).setParameter("id", invoiceId).getSingleResult();
    }

    private boolean isInvoiceAttachedToBordereau(Long invoiceId) {
        int nbrInATB= Integer.parseInt(customTableService.getEntityManager().createNativeQuery(QUERY_IS_IN_BR_BY_ID).setParameter("id",invoiceId).getSingleResult().toString());
        return nbrInATB>0;
    }
    private boolean hasAlreadyInternalCreditNote(Long invoiceId) {
        int nbrAICN= Integer.parseInt(customTableService.getEntityManager().createNativeQuery(QUERY_IS_IN_AI_BY_ID).setParameter("id",invoiceId).getSingleResult().toString());
        return nbrAICN>0;
    }

    private BordereauDto findBordereauById(Long bordereauId) {
        try {
            Object[] obj= (Object[]) customTableService.getEntityManager().createNativeQuery(QUERY_FIND_BRD_BY_BRD_ID).setParameter("id",bordereauId).getSingleResult();
            return new BordereauDto(Long.valueOf(obj[0].toString()) ,(Boolean)  obj[1]);
        } catch (Exception e) {
            throw new BusinessException("ERROR IN FindBordereauById");
        }
    }

    private void updateInitialInvoiceAsCancelled(Invoice invoice, Long motifId) {
        CustomFieldValues invoiceCfValues = invoice.getCfValues();
        invoiceCfValues.setValue(INVOICE_CF_CANCELLED_KEY, true);
        invoiceCfValues.setValue(INVOICE_CF_MOTIF_REJET_KEY, motifId);
        invoiceService.update(invoice);
    }

    private void createInvoiceCreditNoteMatching(Long billingAccountId,Long initialInvoiceId,Long creditNoteId,Long motifId) {
        customTableService.getEntityManager().createNativeQuery(QUERY_INSERT_MATCHING).setParameter("accountId",billingAccountId).setParameter("invoiceId",initialInvoiceId).setParameter("avoireId",creditNoteId).setParameter("motifId",motifId).executeUpdate();
    }

    private void updateBordereauAsCancelled(Long bordereauId,Long motifId) {
        customTableService.getEntityManager().createNativeQuery(QUERY_CANCELLED_BR_BY_ID).setParameter("motif",motifId).setParameter("id",bordereauId).executeUpdate();
    }

    private List<Long> findInvoiceIdsByBordereauId(Long bordereauId) {
        List<?> idbrdStr = this.customTableService.getEntityManager().createNativeQuery(QUERY_FIND_INVOICE_BY_BRD_ID)
                .setParameter("id", bordereauId).getResultList();
        return idbrdStr.stream().map(inv ->((Number) inv).longValue()).collect(Collectors.toList());
    }

    private Long validateMotif(String motif) throws BusinessException {
        try {
            if (isEmpty(motif)) throw new BusinessException(MSG_MOTIF_EST_OBLIGATOIRE);
            String normalizedMotif = motif.trim().toUpperCase();
            Object nbCmrr = customTableService.getEntityManager().createNativeQuery(QUERY_REJETS_REFUS_WHERE_UPPER_CODE_CODE).setParameter("code",normalizedMotif).getSingleResult();
            return Long.valueOf(nbCmrr.toString());
        } catch (Exception e) {
            throw new BusinessException(MSG_REJET_OU_REFUS);
        }
    }

    private List<Long> parseIds(String value) {
        return Arrays.stream(value.split(";"))
                .map(String::trim)
                .filter(v -> !v.isEmpty())
                .map(Long::valueOf)
                .collect(Collectors.toList());
    }

    private void initializeDirectoriesIfNeeded(ReportDto report) throws IOException {
        Path inputDirectory = getInputDirectoryPath();
        if (Files.notExists(inputDirectory)) {
            initDirectories();
            report.addReport(MSG_INIT_DIRECTORIES);
        } else {
            report.addReport(MSG_DIRECTORIES_ALREADY_EXIST);
        }
    }

    private void initDirectories() throws IOException {
        Path baseDirectory = getBaseDirectoryPath();
        List<Path> directories = List.of(
                baseDirectory.resolve(INPUT_SUBDIR),
                baseDirectory.resolve(OUTPUT_SUBDIR),
                baseDirectory.resolve(REJECT_SUBDIR),
                baseDirectory.resolve(ARCHIVE_SUBDIR)
        );
        for (Path directory : directories) {
            Files.createDirectories(directory);
        }
    }

    private Path getInputDirectoryPath() {
        return getBaseDirectoryPath().resolve(INPUT_SUBDIR);
    }

    private Path getBaseDirectoryPath() {
        return Path.of(getProviderDir(),IMPORTS_DIR,INVOICES_DIR,AVOIRS_DIR);
    }

    private String getProviderDir() {
        String providerDir = ParamBean.getInstance().getChrootDir(providerService.getProvider().getCode());
        File directory = new File(providerDir);
        if (!directory.exists()) directory.mkdirs();
        return providerDir;
    }

    private String getStringParam(Map<String, Object> context, String key) {
        Object value = context.get(key);
        return value != null ? value.toString().trim() : "";
    }

    private boolean isEmpty(String value) {
        return value == null || value.trim().isEmpty();
    }

    private void flushReportInContext(Map<String, Object> context, ReportDto reportDto) {
        context.put(Script.JOB_RESULT_NB_OK, reportDto.getNbOK());
        context.put(Script.JOB_RESULT_NB_KO, reportDto.getNbKO());
        context.put(Script.JOB_RESULT_NB_WARN, reportDto.getNbWARN());
        if (!reportDto.getReportMessage().isEmpty()) context.put(Script.JOB_RESULT_REPORT, reportDto.getReportMessage());
    }

    private void writeOutputFile(Path inputFile, List<String> lines) throws IOException {
        String fileName =removeExtension(inputFile.getFileName().toString()) + "_output.csv";
        Files.write(getOutputDirectoryPath().resolve(fileName),lines,StandardCharsets.UTF_8,StandardOpenOption.CREATE,StandardOpenOption.TRUNCATE_EXISTING);
    }
    private void writeRejectFile( Path inputFile, List<String> lines) throws IOException {
        if (lines.size() <= 1) return;
        String fileName = removeExtension(inputFile.getFileName().toString()) + "_reject.csv";
        Files.write(getRejectDirectoryPath().resolve(fileName),lines,StandardCharsets.UTF_8,StandardOpenOption.CREATE,StandardOpenOption.TRUNCATE_EXISTING);
    }

    private void moveFileToArchive( Path inputFile ) throws IOException {
        Files.move( inputFile, getArchiveDirectoryPath().resolve(inputFile.getFileName()), StandardCopyOption.REPLACE_EXISTING);
    }

    private Path getOutputDirectoryPath() {
        return getBaseDirectoryPath().resolve(OUTPUT_SUBDIR);
    }

    private Path getRejectDirectoryPath() {
        return getBaseDirectoryPath().resolve(REJECT_SUBDIR);
    }

    private Path getArchiveDirectoryPath() {
        return getBaseDirectoryPath().resolve(ARCHIVE_SUBDIR);
    }

    private String removeExtension(String fileName) {
        int pos = fileName.lastIndexOf('.');
        if (pos > 0)  return fileName.substring(0, pos);
        return fileName;
    }

