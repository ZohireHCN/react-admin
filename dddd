        public static CdcOptimized sumAndExtendCdcs(List<CdcOptimized> list) {
            ZonedDateTime min = list.stream().map(CdcOptimized::getCdcDateDebut).min(ZonedDateTime::compareTo).orElseThrow(() -> new BusinessException("No start date found"));
            ZonedDateTime max = list.stream().map(CdcOptimized::getCdcDateFin).max(ZonedDateTime::compareTo).orElseThrow(() -> new BusinessException("No end date found"));
            list.forEach(c -> c.extendCdc(min, max, null));
            return sumCdcs(list);
        }

        public void applyMethod(DoubleUnaryOperator method) {
            for (int i = 0; i < puissances.length; i++) if (!isMissing(puissances[i])) puissances[i] = method.applyAsDouble(puissances[i]);
        }

        public void applyMethod(Function<Double, Double> method) {
            for (int i = 0; i < puissances.length; i++) {
                if (!isMissing(puissances[i])) { Double r = method.apply(puissances[i]); puissances[i] = (r == null) ? MISSING : r; }
            }
        }

        public void applyMethod(DoubleBinaryOperator method, CdcOptimized other) {
            if (other.puissances.length != puissances.length) throw new BusinessException("Cdcs have different sizes");
            for (int i = 0; i < puissances.length; i++) { double v1 = puissances[i], v2 = other.puissances[i]; puissances[i] = (isMissing(v1)||isMissing(v2)) ? MISSING : method.applyAsDouble(v1,v2); }
        }

        public void applyMethod(CdcOptimized other, BiFunction<Double, Double, Double> method) {
            if (other.puissances.length != puissances.length) throw new BusinessException("Cdcs have different sizes");
            for (int i = 0; i < puissances.length; i++) { Double v1 = isMissing(puissances[i])?null:puissances[i], v2 = isMissing(other.puissances[i])?null:other.puissances[i]; Double r = method.apply(v1,v2); puissances[i] = (r==null)?MISSING:r; }
        }

        public ZonedDateTime getLastNonNullValueDate() {
            for (int i = puissances.length-1; i >= 0; i--) if (!isMissing(puissances[i])) return cdcDates.get(i).withHour(0).withMinute(0);
            throw new BusinessException("No non-null value found in the CDC");
        }

        public static CdcOptimized sumCdcs(List<CdcOptimized> list) {
            if (list.isEmpty()) throw new BusinessException("No Cdcs to sum");
            CdcOptimized first = list.get(0);
            for (CdcOptimized c : list) {
                if (!first.getCdcDateDebut().isEqual(c.getCdcDateDebut()) || !first.getCdcDateFin().isEqual(c.getCdcDateFin()) || first.getCdcPas() != c.getCdcPas())
                    throw new BusinessException("Cdcs have different start/end dates or steps");
            }
            CdcOptimized sum = new CdcOptimized(first.getCdcPas(), first.getCdcDateDebut(), first.getCdcDateFin(), (Double)null);
            IntStream.range(0, sum.puissances.length).parallel().forEach(idx -> {
                double s = 0;
                for (CdcOptimized c : list) { double v = c.puissances[idx]; if (!isMissing(v)) s += v; }
                sum.puissances[idx] = s;
            });
            return sum;
        }

        public void reduceCdc(ZonedDateTime start, ZonedDateTime end) {
            extendCdc(start, end, null);
            int si = getReducedStartDateIndex(start), ei = getReducedEndDateIndex(end);
            cdcDates = cdcDates.subList(si, ei+1);
            puissances = Arrays.copyOfRange(puissances, si, ei+1);
            setStartEndDates(); cdcDateDebut = start; cdcDateFin = end;
            curve.setStartDate(start); curve.setEndDate(end);
        }

