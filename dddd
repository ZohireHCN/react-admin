    }

    /**
     * Retourne l'index de {@code date} dans dates, ou -1 si hors plage.
     */
    public int testIndex(ZonedDateTime date) {
        List<ZonedDateTime> dates = this.getCdcDates();
        if (dates == null || dates.isEmpty()) return -1;
        if (date.isBefore(this.getCdcDateDebut()) || date.isAfter(this.getCdcDateFin())) return -1;
        int i1 = 0, i2 = dates.size() - 1, i = 0;
        while (i1 + 1 < i2) {
            i = (i1 + i2) / 2;
            if (dates.get(i).isAfter(date)) {
                i2 = i;
            } else {
                i1 = i;
            }
        }
        if (dates.get(i1).equals(date)) return i1;
        return i2;
    }

