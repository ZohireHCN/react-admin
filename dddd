    public Cdc() {
    }

    public Cdc(List<ZonedDateTime> dates, List<Double> puissances) {
        checkDiscontinuity(dates);

        if(dates.size() != puissances.size()) {
            throw new BusinessException("Dates and puissances lists should have the same size");
        }

        remplirCdc(cdcPas, dates.get(0), dates.get(dates.size() - 1));
        cdcDates = dates;
        cdcPuissances = puissances;
        if(curve != null && curve.getBinaryCurve() != null) {
            curve.getBinaryCurve().setData(convertDoublesToBytes(cdcPuissances));
        }
    }

    private void checkDiscontinuity(List<ZonedDateTime> dates) {
        if(dates.size() < 2) {
            throw new BusinessException("Not enough dates to determine step");
        }
        cdcPas = getStepEnum(dates.get(1), dates.get(0));

        if(cdcPas == StepEnum.Journalier) {
            for(int i = 1 ; i < dates.size() ; i++){
                if(!dates.get(i-1).plusDays(1).isEqual(dates.get(i))) {
                    StringBuilder message = new StringBuilder("Discontinuity in dates for the period ")
                            .append(dates.get(0).toLocalDate())
                            .append(" to ")
                            .append(dates.get(dates.size()-1).toLocalDate());
                    if (curve != null && curve.getCurveType() != null) message.append(" for ").append(curve.getCurveType());
                    throw new BusinessException(message.toString());
                }
            }
            return;
        }

        int n = calculerNbPtsParHeure(cdcPas);
        // check if there is a discontinuity in the dates
        for (int i = 1; i < dates.size(); i++) {
            if (ChronoUnit.MINUTES.between(dates.get(i - 1), dates.get(i)) != 60 / n) {
                StringBuilder message = new StringBuilder("Discontinuity in dates for the period ")
                        .append(dates.get(0).toLocalDate())
                        .append(" to ")
                        .append(dates.get(dates.size()-1).toLocalDate());
                if (curve != null && curve.getCurveType() != null) message.append(" for ").append(curve.getCurveType());
                throw new BusinessException(message.toString());
            }
        }
    }

    public Cdc(Curve curve) {
        this(curve, Cdc.convertBytesToDoubles(curve.getBinaryCurve().getData()));
    }

    public StepEnum getStepFromDatesAndValues(ZonedDateTime start, ZonedDateTime end, List<Double> values) {
        try {
            if (start.isAfter(end)) {
                throw new BusinessException("Start date is after end date");
            }

            long minutesDiff = ChronoUnit.MINUTES.between(start, end);
            float minutesDuration = Math.round(minutesDiff / (float) values.size());

            try {
                return StepEnum.fromDurationInMinutes((int) minutesDuration);
            } catch (Exception e) {
                return null;
            }
        } catch (BusinessException e) {
            return null;
        }
    }

    public Cdc(Curve curve, List<Double> puissances) {
        StepEnum decuctedStep = getStepFromDatesAndValues(curve.getStartDate(), curve.getEndDate(), puissances);
        if(decuctedStep != null && decuctedStep != curve.getStep()) {
            this.cdcPas = decuctedStep;
            curve.setStep(decuctedStep);
        }
        remplirCdc(curve.getStep(), curve.getStartDate(), curve.getEndDate());
        this.curve = curve;
        cdcPuissances = puissances;
    }

    public Cdc(StepEnum pas, ZonedDateTime debut, ZonedDateTime fin) {
        if (debut.isAfter(fin) || (debut.isEqual(fin) && (pas != StepEnum.Journalier))) {
            return;
        }
        remplirCdc(pas, debut, fin);
    }

    public Cdc(StepEnum pas, ZonedDateTime debut, ZonedDateTime fin, Double defaultValue) {
        if (debut.isAfter(fin) || (debut.isEqual(fin) && (pas != StepEnum.Journalier))) {
            return;
        }
        remplirCdc(pas, debut, fin, defaultValue);
    }

    /** Remplit avec zéros ou NaN selon {@code avecNaN}. */
    public Cdc(StepEnum pas, ZonedDateTime debut, ZonedDateTime fin, boolean avecNaN) {
        remplirCdc(pas, debut, fin, avecNaN ? null : 0.0);
    }

    public Cdc projectCdc(ZonedDateTime debut, ZonedDateTime fin, StepEnum targetPas) {
        return projectCdc(debut, fin, targetPas, false);
    }

    /**
     * Étend (ou restreint) la courbe à une nouvelle plage temporelle.
     * Si avecNaN=true, les zones sans données sont remplies de NaN.
     * Port fidèle de EtendreCourbe(debut, fin, pas, avecMinValue) C#.
     */
    public Cdc projectCdc(ZonedDateTime debut, ZonedDateTime fin, StepEnum targetPas, boolean avecNaN) {
        if (debut == null || fin == null) return this;

        // Raccourci si aucun changement
        if (this.cdcPas == targetPas && debut.equals(this.cdcDateDebut) && fin.equals(this.cdcDateFin)) {
            return recopier();
        }

        Cdc retour = new Cdc(targetPas, debut, fin, avecNaN);
        if (retour == null || retour.cdcDates == null) return null;

        int i = 0, j = 0;

        // Avancer i jusqu'à ce que retour.cdcDates[i] >= this.cdcDateDebut
        while (i < retour.cdcDates.size() && retour.cdcDates.get(i).isBefore(this.cdcDateDebut)) {
            i++;
        }
        // Avancer j jusqu'à ce que this.cdcDates[j] >= retour.cdcDates[i]
        while (j < this.cdcDates.size() && i < retour.cdcDates.size()
                && this.cdcDates.get(j).isBefore(retour.cdcDates.get(i))) {
            j++;
        }
        // Copier les puissances
        while (i < retour.cdcPuissances.size() && j < this.cdcPuissances.size()) {
            retour.cdcPuissances.set(i, this.cdcPuissances.get(j));
            j++;
            i++;
        }
        return retour;
    }

    public void extendCdc(ZonedDateTime debut, ZonedDateTime fin, Double defaultValue) {
        if(debut.isEqual(cdcDateDebut) && fin.isEqual(cdcDateFin)) {
            return;
        }

        ZonedDateTime startDate = cdcDateDebut.isBefore(debut) || cdcDateDebut.isEqual(debut) ? cdcDateDebut : debut;
        ZonedDateTime endDate = cdcDateFin.isAfter(fin) || cdcDateFin.isEqual(fin) ? cdcDateFin : fin;

        // cdcDates and cdcPuissances are known arraylists the method, should extend these arrays based on the debut and fin parameters
        // so we will have new dates at the begind and/or the end of the cdcDates and the defaultValue in cdcPuissances
        List<ZonedDateTime> newDates = new ArrayList<>();
        List<Double> newValues = new ArrayList<>();
        int stepDurationInMin = cdcPas.getDurationInMinutes();

        // Add entries at the beginning if needed
        if (startDate.isBefore(cdcDateDebut)) {
            // Calculate how many entries needed and preallocate
            ZonedDateTime currentDate = startDate;

            while (currentDate.isBefore(cdcDateDebut)) {
                newDates.add(currentDate);
                newValues.add(defaultValue);
                currentDate = cdcPas == StepEnum.Journalier ?
                         currentDate.plusDays(1) : currentDate.plusMinutes(stepDurationInMin);
            }

            // Efficiently add all existing entries at once
            newDates.addAll(cdcDates);
            newValues.addAll(cdcPuissances);

            // Replace the original lists
            cdcDates = newDates;
            cdcPuissances = newValues;
        } else {
            // If no prepending needed, just prepare for appending
            newDates.addAll(cdcDates);
            newValues.addAll(cdcPuissances);
        }

        // Add entries at the end if needed
        if (endDate.isAfter(cdcDateFin)) {
            // Start from the next hour after the current end
            ZonedDateTime currentDate = cdcPas == StepEnum.Journalier ?
                    cdcDateFin.plusDays(1) : cdcDateFin.plusMinutes(stepDurationInMin);

            while (!currentDate.isAfter(endDate)) {
                newDates.add(currentDate);
                newValues.add(defaultValue);
                currentDate = cdcPas == StepEnum.Journalier ?
                        currentDate.plusDays(1) : currentDate.plusMinutes(stepDurationInMin);
            }
        }

        cdcDates = newDates;
        cdcPuissances = newValues;
        setStartEndDates();
    }

    private void remplirCdc(StepEnum pas, ZonedDateTime debut, ZonedDateTime fin) {
        remplirCdc(pas, debut, fin, 0D);
    }

    public Cdc getReducedCdc(ZonedDateTime start, ZonedDateTime end) {
        Cdc reducedCdc = new Cdc();
        int startIndex = getReducedStartDateIndex(start);
        int endIndex = getReducedEndDateIndex(end);

        reducedCdc.curve = new Curve();
        reducedCdc.curve.setStartDate(start);
        reducedCdc.curve.setEndDate(end);
        reducedCdc.curve.setStep(cdcPas);
        reducedCdc.curve.setBinaryCurve(new BinaryCurve());
        reducedCdc.curve.getBinaryCurve().setCurve(reducedCdc.curve);
        reducedCdc.curve.getBinaryCurve().setData(convertDoublesToBytes(reducedCdc.cdcPuissances));

        reducedCdc.cdcDates = new ArrayList<>(cdcDates.subList(startIndex, endIndex + 1));
        reducedCdc.cdcPuissances = new ArrayList<>(cdcPuissances.subList(startIndex, endIndex + 1));
        reducedCdc.cdcDateDebut = start;
        reducedCdc.cdcDateFin = end;
        reducedCdc.cdcPas = cdcPas;

        return reducedCdc;
    }

    public CoverageStatus getCoverageStatus(ZonedDateTime start, ZonedDateTime end) {

        int startIndex = getReducedStartDateIndex(start);
        int endIndex   = getReducedEndDateIndex(end);

        long expectedPoints = Duration.between(start, end).toMinutes() / cdcPas.getDurationInMinutes() + 1;

        if (startIndex < 0 || endIndex < startIndex) {
            return CoverageStatus.NONE;
        }

        List<Double> slice = cdcPuissances.subList(startIndex, endIndex + 1);

        boolean hasAtLeastOne = slice.stream().anyMatch(v -> v != null);
        if (!hasAtLeastOne) {
            return CoverageStatus.NONE;
        }

        boolean allCovered = slice.stream().allMatch(v -> v != null) && slice.size() == expectedPoints;

        return allCovered ? CoverageStatus.FULL : CoverageStatus.PARTIAL;
    }


    public enum CoverageStatus {
        NONE,
        PARTIAL,
        FULL
    }

    public static Cdc sumCdcs(Cdc... cdcs){
        return sumCdcs(List.of(cdcs));
    }

    public void incrementValue(Double value) {
        cdcPuissances.replaceAll(v -> v != null ? v + value : null);
    }

    public static Cdc sumAndExtendCdcs(List<Cdc> cdcList) {
        ZonedDateTime minStartDate = cdcList.stream().map(Cdc::getCdcDateDebut).min(ZonedDateTime::compareTo).orElseThrow(() -> new BusinessException("No start date found"));
        ZonedDateTime maxEndDate = cdcList.stream().map(Cdc::getCdcDateFin).max(ZonedDateTime::compareTo).orElseThrow(() -> new BusinessException("No end date found"));

        for(Cdc cdc : cdcList) {
            cdc.extendCdc(minStartDate, maxEndDate, null);
        }

        return sumCdcs(cdcList);
    }

    public void applyMethod(Function<Double, Double> method) {
        cdcPuissances.replaceAll(v -> v != null ? method.apply(v) : null);
    }

    public void applyMethod(Cdc cdc, BiFunction<Double, Double, Double> method) {
        if(cdc.getCdcPuissances().size() != cdcPuissances.size()) {
            throw new BusinessException("Cdcs have different sizes, cannot apply method");
        }

        IntStream.range(0, cdcPuissances.size()).forEach(i -> {
            Double v1 = cdcPuissances.get(i);
            Double v2 = cdc.getCdcPuissances().get(i);
            cdcPuissances.set(i, method.apply(v1, v2));
        });
    }

    public ZonedDateTime getLastNonNullValueDate(){
        for(int i = cdcPuissances.size() - 1; i >= 0; i--) {
            if(cdcPuissances.get(i) != null) {
                return cdcDates.get(i).withHour(0).withMinute(0);
            }
        }
        throw new BusinessException("No non-null value found in the CDC");
    }

    public static Cdc sumCdcs(List<Cdc> cdcList){
        if(cdcList.isEmpty()) {
            throw new BusinessException("No Cdcs to sum");
        }

        Cdc firstCdc = cdcList.get(0);
        for(Cdc cdc : cdcList) {
            if(!firstCdc.getCdcDateDebut().isEqual(cdc.getCdcDateDebut()) || !firstCdc.getCdcDateFin().isEqual(cdc.getCdcDateFin()) || firstCdc.getCdcPas() != cdc.getCdcPas()) {
                throw new BusinessException("Cdcs have different start/end dates or steps");
            }
        }

        Cdc sumCdc = new Cdc(firstCdc.getCdcPas(), firstCdc.getCdcDateDebut(), firstCdc.getCdcDateFin(), null);
        IntStream.range(0, sumCdc.getCdcPuissances().size()).parallel().forEach(index -> {
            double sum = 0D;
            for (Cdc cdc : cdcList) {
                sum += ofNullable(cdc.getCdcPuissances().get(index)).orElse(0D);
            }
            sumCdc.getCdcPuissances().set(index, sum);
        });

        return sumCdc;
    }

    public void reduceCdc(ZonedDateTime start, ZonedDateTime end) {
        extendCdc(start, end, null);

        int startIndex = getReducedStartDateIndex(start);
        int endIndex = getReducedEndDateIndex(end);

        cdcDates = cdcDates.subList(startIndex, endIndex + 1);
        cdcPuissances = cdcPuissances.subList(startIndex, endIndex + 1);
        setStartEndDates();
        cdcDateDebut = start;
        cdcDateFin = end;
        curve.setStartDate(start);
        curve.setEndDate(end);
    }

    public int getReducedStartDateIndex(ZonedDateTime start) {
        for(int i = 0; i < cdcDates.size(); i++) {
            if(cdcDates.get(i).isAfter(start) || cdcDates.get(i).isEqual(start)) {
                return i;
            }
        }
        throw new BusinessException(
                "Données non trouvées pour la courbe " + curve.getCurveType()
                + ", date de début: " + start.format(DateTimeFormatter.ofPattern("dd/MM/yyyy HH:mm:ss"))
        );
    }

    public int getReducedEndDateIndex(ZonedDateTime end) {
        for(int i = cdcDates.size() - 1; i >= 0; i--) {
            if(cdcDates.get(i).isBefore(end) || cdcDates.get(i).isEqual(end)) {
                return i;
            }
        }
        throw new BusinessException(
                "Données non trouvées pour la courbe " + curve.getCurveType()
                + ", date de fin: " + end.format(DateTimeFormatter.ofPattern("dd/MM/yyyy HH:mm:ss"))
        );
    }

    public int getDateIndex(ZonedDateTime date) {
        if(!(date.isBefore(cdcDateDebut) || date.isAfter(cdcDateFin))) {
            for(int i = 0; i < cdcDates.size(); i++) {
                if(cdcDates.get(i).isEqual(date)) {
                    return i;
                }
            }
        }
        throw new BusinessException("Date not found in the CDC");
    }

