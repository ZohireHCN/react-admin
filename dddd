    public LocalDate paques(int annee) {
        int a = annee % 19;
        int b = annee / 100;
        int c = annee % 100;
        int d = b / 4;
        int e = b % 4;
        int f = (b + 8) / 25;
        int g = (b - f + 1) / 3;
        int h = (19 * a + b - d - g + 15) % 30;
        int i = c / 4;
        int k = c % 4;
        int L = (32 + 2 * e + 2 * i - h - k) % 7;
        int m = (a + 11 * h + 22 * L) / 451;
        int mois = (h + L - 7 * m + 114) / 31;
        int jour = ((h + L - 7 * m + 114) % 31) + 1;
        return LocalDate.of(annee, mois, jour);
    }

    /** Retourne les 11 jours fériés français pour l'année donnée. */
    public LocalDate[] joursFeries(int annee) {
        LocalDate[] feries = new LocalDate[11];
        feries[0]  = LocalDate.of(annee, 1, 1);
        feries[1]  = LocalDate.of(annee, 5, 1);
        feries[2]  = LocalDate.of(annee, 5, 8);
        feries[3]  = LocalDate.of(annee, 7, 14);
        feries[4]  = LocalDate.of(annee, 8, 15);
        feries[5]  = LocalDate.of(annee, 11, 1);
        feries[6]  = LocalDate.of(annee, 11, 11);
        feries[7]  = LocalDate.of(annee, 12, 25);
        feries[8]  = paques(annee).plusDays(1);    // Lundi de Pâques
        feries[9]  = feries[8].plusDays(38);        // Ascension
        feries[10] = feries[8].plusDays(49);        // Pentecôte
        return feries;
    }

    public boolean isFerie(LocalDateTime dtDate) {
        LocalDate date = dtDate.toLocalDate();
        LocalDate[] feries = joursFeries(date.getYear());
        for (LocalDate f : feries) {
            if (date.equals(f)) return true;
        }
        return false;
    }

