    public Double calculateHistoricalAnnualEnergyVolume(){
        boolean hasEnoughHistory = cdcDateFin.isAfter(cdcDateDebut.plusDays(395));
        if(hasEnoughHistory){
            return getSum(cdcDateFin.minusDays(395).withHour(0).withMinute(0), cdcDateFin.minusDays(30)) / calculerNbPtsParHeure(cdcPas);
        } else {
            double ratio = (double) 365 / ChronoUnit.DAYS.between(cdcDateDebut, cdcDateFin);
            return getSum() / calculerNbPtsParHeure(cdcPas) * ratio;
        }
    }

