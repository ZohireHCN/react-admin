                                    "where ecd.prm.id = :prmId",
                            EnedisContractualData.class)
                    .setParameter("prmId", prm.getId())
                    .setMaxResults(1)
                    .getSingleResult();

            List<ContractualSituation> situations = enedisContractualData.getContractualSituations();
            if (!situations.isEmpty()) {
                double ps = situations.get(0).getSubscribedPowerValue();
                if (situations.get(0).getSubscribedPowerUnit().equalsIgnoreCase("kVA")) {
                    return ps / 1000;
                }
            }

            return null;
        } catch (NoResultException e) {
            log.info("No contractual data found for PRM with ID: {}", prm.getId());
            return null;
        } catch (Exception e) {
            log.info("No subscribed power found for PRM with ID: {} ({})", prm.getId(), e.getMessage());
            return null;
        }
    }

    private void getFuds(Prm prm, List<BilledMeterReading> bmrList) {
        List<BilledMeterReading> filteredBmrList = bmrList.stream()
                .filter(bmr -> bmr != null && Boolean.TRUE.equals(bmr.getOverwriteMeasure()))
                .collect(Collectors.toList());

        if(filteredBmrList.isEmpty()) {
            return;
        }

        Double ps = getPrmPS(prm);

        if (ps == null) {
            return;
        }

        filteredBmrList.forEach(bmr -> {
            String subProfile = getSubProfile(prm, bmr.getTemporalClass());
            Double theta = THETA_VALUES.get(subProfile);
            if (theta == null) {
                log.info("Theta value not found for sub-profile {}, prm {}", subProfile, prm.getReference());
                warnCounter.incrementAndGet();
                report.rep(String.format("Valeur de theta non trouvée pour le sous-profil %s, prm %s", subProfile, prm.getReference()));
                return;
            }
            bmr.setFudMeasure(BigDecimal.valueOf(ps).multiply(BigDecimal.valueOf(theta)).doubleValue());
            bmrService.update(bmr, jobUser);
        });

        filteredBmrList.clear();
    }

