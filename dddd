@SuppressWarnings("unchecked")
private void updatePreviousConsumptionIfNeeded(EntityManager em, Long operationTraitementId) {
    String query =
            "SELECT target.id, COUNT(target.prm_id) " +
            "FROM maco_d_processing_operation orig " +
            "JOIN maco_d_processing_operation target " +
            "  ON orig.prm_id = target.prm_id " +
            " AND target.status_code = 'TREATED' " +
            " AND target.operation_type IN ('PLANIFIEE', 'MES') " +
            " AND (DATE(orig.start_date) - 1 = DATE(target.end_date) " +
            "      OR DATE(orig.start_date) = DATE(target.end_date)) " +
            "WHERE orig.id = :operationTraitementId " +
            "GROUP BY target.id, target.prm_id";

    List<Object[]> rows = em.createNativeQuery(query)
            .setParameter("operationTraitementId", operationTraitementId)
            .getResultList();

    List<Long> idsToUpdate = rows.stream()
            .filter(row -> BigInteger.ONE.equals(row[1]))
            .map(row -> ((BigInteger) row[0]).longValue())
            .collect(Collectors.toList());

    if (CollectionUtils.isEmpty(idsToUpdate)) {
        return;
    }

    executeUpdate(em,
            "UPDATE maco_d_billable_consumption " +
            "SET status_code = 'NOT_DEDUCTED' " +
            "WHERE id_operation_traitement IN (" + StringUtils.join(idsToUpdate, ",") + ") " +
            "AND status_code = 'DEDUCTED'"
    );
}

private void updateMeterReadingHeader(EntityManager em, Long operationTraitementId) {
    executeUpdate(em,
            "UPDATE maco_d_meter_reading_header " +
            "SET id_operation_traitement = CASE " +
            "        WHEN maco_d_processing_operation.operation_type NOT IN ('MES', 'RES') THEN NULL " +
            "        ELSE id_operation_traitement " +
            "    END, " +
            "    status_code = 'TO_TREAT' " +
            "FROM maco_d_processing_operation " +
            "WHERE id_operation_traitement = maco_d_processing_operation.id " +
            "AND id_operation_traitement = :operationTraitementId",
            operationTraitementId
    );
}

