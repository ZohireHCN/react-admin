    /**
     * Lance le traitement de chaque MeterReading de la liste.
     * La {@code profileMap} locale a été supprimée : le cache partagé {@link #templateCache}
     * remplace complètement son rôle.
     */
    private void handleMeterReadingList(Prm prm, String targetClassCat, Map<String, CdcOptimized> cdcMap, MeterReadingList meterReadingList) {
        List<String> targetClasses = getTargetClasses(targetClassCat);

        // report.rep("[4] PRM Reference | Sub-profile | EP | Coeff sum | FU (Ep/coeffSum) | start | end");

        log.debug("PRM Reference | Sub-profile | FU (Ep/coeffSum) | Coeff sum | start | end");
        meterReadingList.getList().forEach(m -> handleUnitMR(prm, cdcMap, m, targetClasses));
    }

    private void handleUnitMR(Prm prm, Map<String, CdcOptimized> cdcMap, MeterReading mr, List<String> targetClasses) {
        if (!validateMeterReading(mr)) {
            warnCounter.incrementAndGet();
            report.rep(String.format("Classes temporelles manquantes pour le prm %s sur la période %s - %s : %s",
                    prm.getReference(),
                    mr.getStartDate().format(DATE_FORMATTER),
                    mr.getEndDate().format(DATE_FORMATTER),
                    getMissingTempClasses(mr, targetClasses)));
            return;
        }
        targetClasses.stream().parallel().forEach(tempClassTarget -> {
            try {
                handleMeterReading(prm, mr, cdcMap, tempClassTarget);
            } catch (ProfileCoeffNotFound e) {
                log.info("Profile not found for PRM {}, temporal class {} and period {} to {}",
                        prm.getReference(), tempClassTarget,
                        mr.getStartDate().format(DATE_FORMATTER), mr.getEndDate().format(DATE_FORMATTER));
            } catch (Exception e) {
                throw e;
            }
        });
    }

    private String getMissingTempClasses(MeterReading mr, List<String> targetClasses) {
        List<String> missingClasses = new ArrayList<>();
        for (String targetClass : targetClasses) {
            if (!mr.getBmrList().containsKey(targetClass)) {
                missingClasses.add(targetClass);
            }
        }
        return String.join(", ", missingClasses);

    }

    private boolean validateMeterReading(MeterReading mr) {
        String classCat = mr.getTemporalCat();

        switch (classCat) {
            case "HPHC":
                return mr.getBmrList().size() == 2;
            case "SAISON":
                return mr.getBmrList().size() == 4;
            default:
                return true;
        }
    }

    // ── Cœur du calcul ────────────────────────────────────────────────────────

    /**
     * Traitement d'une combinaison MeterReading × classe temporelle.
     *
     * <p><strong>Utilisation du cache :</strong></p>
     * <ol>
     *   <li>{@link #getOrLoadTemplate} retourne le {@code double[]} mis en cache (lecture seule)
     *       et les métadonnées associées.</li>
     *   <li>{@link CdcOptimized#getReducedCdc} produit une copie isolée de la tranche temporelle
     *       → seul ce tableau est modifié par {@code multiplyBy(fu)}.</li>
     *   <li>Le tableau du cache n'est jamais touché.</li>
     * </ol>
     */
    private void handleMeterReading(Prm prm, MeterReading mr,
                                    Map<String, CdcOptimized> cdcMap,
                                    String tempClassTarget) throws ProfileCoeffNotFound {
        String subProfile = getSubProfile(prm, tempClassTarget);
        TemplateKey key   = new TemplateKey(subProfile, StepEnum.Horaire);

        // 1. Récupère le double[] en cache (charge depuis DB si absent)
        double[]     templateData = getOrLoadTemplate(key, subProfile);
        TemplateMeta meta         = templateMetaCache.get(key);

        // 2. Construit un CdcOptimized "vue" autour du template (pas de copie ici)
        //    puis demande une slice — getReducedCdc fait Arrays.copyOfRange en interne.
        ZonedDateTime startDate = mr.getStartDate();
        ZonedDateTime endDate   = mr.getStartDate().isEqual(mr.getEndDate())
                ? mr.getEndDate().plusDays(1).minusMinutes(StepEnum.Horaire.getDurationInMinutes())
                : mr.getEndDate().minusMinutes(StepEnum.Horaire.getDurationInMinutes());

        if (startDate.isBefore(meta.startDate) || endDate.isAfter(meta.endDate)) {
            throw new ProfileCoeffNotFound("Date de début ou de fin non trouvée dans le profil");
        }

        // Construit un CdcOptimized léger autour des données cachées (sans copie)
        CdcOptimized templateCdc = buildCdcFromTemplate(templateData, meta, tempClassTarget);

        CdcOptimized profileData;
        try {
            // getReducedCdc produit Arrays.copyOfRange → copie isolée, safe à muter
            profileData = templateCdc.getReducedCdc(startDate, endDate);

            if (profileData.countIf(null) > 0) {
                throw new ProfileCoeffNotFound("Le sous-profil contient des valeurs nulles");
            }
        } catch (ProfileCoeffNotFound e) {
            throw e;
        } catch (Exception e) {
            log.error("Profile coeff not found for sub-profile {}", subProfile, e);
            throw new ProfileCoeffNotFound(e.getMessage());
        }

        CurveTypeEnum curveTypeEnum = getCurveTypeEnum();
        profileData.getCurve().setCurveType(curveTypeEnum);
        profileData.getCurve().setDescription(curveTypeEnum.name());

        Double eP       = mr.getEp(tempClassTarget, subProfileCoefficients);
        Double coeffSum = profileData.getSum();
        Double fu       = coeffSum == 0 ? 0D : eP / coeffSum;

        log.debug("{} | {} | {} | {} | {} | {}",
                prm.getReference(), subProfile, fu, coeffSum, mr.getStartDate(), mr.getEndDate());

        // 3. Modification sur la copie locale — le cache n'est pas impacté
        profileData.multiplyBy(fu);

        CdcOptimized existing = cdcMap.get(tempClassTarget);
        if (existing == null) {
            cdcMap.put(tempClassTarget, profileData);
        } else {
            existing.mergeCdcAndIgnoreDiscontinuity(profileData);
            existing.getCurve().getBinaryCurve().setData(CdcOptimized.convertDoublesToBytes(existing.getCdcPuissances()));
        }
    }

    /**
     * Retourne le {@code double[]} du template depuis le cache, ou le charge depuis la base
     * (lecture, fusion AJUSTE+DYNAMIQUE, normalisation de pas) puis le met en cache.
     *
     * <p>Thread-safe : {@link ConcurrentHashMap#computeIfAbsent} garantit qu'un seul thread
     * exécute le chargement pour une clé donnée.</p>
     *
     * @param key        clé de cache
     * @param subProfile nom du sous-profil (ex. "PRO1_BASE")
     * @return tableau primitif en lecture seule
     * @throws ProfileCoeffNotFound si le sous-profil est absent de la base
     */
    private double[] getOrLoadTemplate(TemplateKey key, String subProfile) throws ProfileCoeffNotFound {
        // computeIfAbsent est atomique sur ConcurrentHashMap : un seul thread charge,
        // les autres attendent puis reçoivent le tableau mis en cache.
        try {
            return templateCache.computeIfAbsent(key, k -> {
                CdcOptimized merged = loadAndMergeSubProfile(subProfile);
                // Stocke les métadonnées séparément
                templateMetaCache.put(k, new TemplateMeta(
                        merged.getCdcPas(),
                        merged.getCdcDateDebut(),
                        merged.getCdcDateFin()));
                // Extrait le double[] interne via le getter public (conversion null→NaN déjà faite)
                return CdcOptimized.fromListToArray(merged.getCdcPuissances());
            });
        } catch (RuntimeException e) {
            // computeIfAbsent propage les RuntimeExceptions wrappées
            Throwable cause = e.getCause() != null ? e.getCause() : e;
            if (cause instanceof ProfileCoeffNotFound) throw (ProfileCoeffNotFound) cause;
            throw new ProfileCoeffNotFound("Profile coeff not found for sub-profile " + subProfile);
        }
    }

    /**
     * Charge depuis la DB les courbes AJUSTE et DYNAMIQUE pour un sous-profil,
     * normalise leur pas à {@link StepEnum#Horaire} puis fusionne les deux.
     */
    private CdcOptimized loadAndMergeSubProfile(String subProfile) {
        List<Curve> curves = curveService.getEntityManager()
/*                .createQuery("select c from Curve c " +
                                "where c.description = :descAjuste or c.description = :descDynamique",
                        Curve.class) */
                .createQuery("select c from Curve c " +
                                "join fetch c.binaryCurve " +   // ← fetch eager
                                "where c.description = :descAjuste or c.description = :descDynamique",
                        Curve.class)
                .setParameter("descAjuste",    subProfile.toUpperCase() + "_COEFF_AJUSTE")
                .setParameter("descDynamique", subProfile.toUpperCase() + "_COEFF_DYNAMIQUE")
                .setMaxResults(2)
                .getResultList();

        CdcOptimized[] adjusted = {null};
        CdcOptimized[] dynamic  = {null};

/*        curves.forEach(curve -> {
            curveService.getEntityManager().detach(curve);
            CdcOptimized cdc = new CdcOptimized(curve.getStep(), curve.getStartDate(), curve.getEndDate(), (Double) null);
            cdc.setCdcPuissances(CdcOptimized.convertBytesToDoubles(curve.getBinaryCurve().getData()));
            cdc = CdcOptimized.changerPas(cdc, StepEnum.Horaire);

            if (curve.getDescription().endsWith("_AJUSTE"))    adjusted[0] = cdc;
            else if (curve.getDescription().endsWith("_DYNAMIQUE")) dynamic[0]  = cdc;
        });*/
        curves.forEach(curve -> {
            // Lire AVANT le detach
            byte[] data      = curve.getBinaryCurve().getData();
            StepEnum step    = curve.getStep();
            ZonedDateTime s  = curve.getStartDate();
            ZonedDateTime e  = curve.getEndDate();
            String desc      = curve.getDescription();

            curveService.getEntityManager().detach(curve);  // ← detach après lecture

            CdcOptimized cdc = new CdcOptimized(step, s, e, (Double) null);
            cdc.setCdcPuissances(CdcOptimized.convertBytesToDoubles(data));
            cdc = CdcOptimized.changerPas(cdc, StepEnum.Horaire);

            if (desc.endsWith("_AJUSTE"))     adjusted[0] = cdc;
            else if (desc.endsWith("_DYNAMIQUE")) dynamic[0] = cdc;
        });

        if (adjusted[0] == null) {
            throw new ProfileCoeffNotFound("Courbe AJUSTE non trouvée pour le sous-profil " + subProfile);
        }
        if (dynamic[0] != null) {
            adjusted[0].mergeCdcAndIgnoreDiscontinuity(dynamic[0]);
        }
        return adjusted[0];
    }

    /**
     * Reconstruit un {@link CdcOptimized} léger autour du {@code double[]} mis en cache.
     *
     * <p>Le tableau {@code templateData} est <strong>partagé</strong> (lecture seule).
     * {@link CdcOptimized#getReducedCdc} produira une copie indépendante via
     * {@link Arrays#copyOfRange}.</p>
     */
    private CdcOptimized buildCdcFromTemplate(double[] templateData, TemplateMeta meta,
                                              String tempClassTarget) {
        // Crée un CdcOptimized vide puis injecte directement le tableau sans copie
        CdcOptimized cdc = new CdcOptimized(meta.step, meta.startDate, meta.endDate, (Double) null);
        cdc.setRawPuissances(templateData); // setter package-friendly qui affecte sans copie
        return cdc;
    }

