    // ── CdcOptimized (inner static class) ────────────────────────────────────

    public static class CdcOptimized {

        private static final ZoneId  currentZoneId = ZoneId.of("Europe/Paris");
        private static final double  MISSING        = Double.NaN;

        private ZonedDateTime       cdcDateDebut;
        private ZonedDateTime       cdcDateFin;
        private StepEnum            cdcPas;
        private List<ZonedDateTime> cdcDates;
        private String              libelle;
        private Boolean             erreurBin;
        private Long                crbId;
        private double[]            puissances = new double[0];
        private Curve               curve;
        private BinaryCurve         binaryCurve;

        // ── Helpers primitifs ────────────────────────────────────────────────

        public static boolean isMissing(double v)  { return Double.isNaN(v); }

        @Deprecated
        public static boolean isMissing(Double v)  { return v == null || Double.isNaN(v); }

        private static double[] allocate(int n, double fill) {
            double[] arr = new double[n];
            Arrays.fill(arr, isMissing(fill) ? MISSING : fill);
            return arr;
        }

        /** Convertit List<Double> (null → NaN) → double[]. */
        static double[] fromListToArray(List<Double> list) {
            double[] arr = new double[list.size()];
            for (int i = 0; i < list.size(); i++) {
                Double v = list.get(i);
                arr[i] = (v == null) ? MISSING : v;
            }
            return arr;
        }

        private static double[] fromList(List<Double> list) { return fromListToArray(list); }

        private static List<Double> toList(double[] arr) {
            List<Double> list = new ArrayList<>(arr.length);
            for (double v : arr) list.add(isMissing(v) ? null : v);
            return list;
        }

        // ── Constructeurs ────────────────────────────────────────────────────

        public CdcOptimized() {}

        public CdcOptimized(List<ZonedDateTime> dates, List<Double> puissancesIn) {
            checkDiscontinuity(dates);
            if (dates.size() != puissancesIn.size())
                throw new BusinessException("Dates and puissances lists should have the same size");
            remplirCdc(cdcPas, dates.get(0), dates.get(dates.size() - 1));
            cdcDates   = dates;
            puissances = fromList(puissancesIn);
            if (curve != null && curve.getBinaryCurve() != null)
                curve.getBinaryCurve().setData(convertDoublesToBytes(puissances));
        }

        private void checkDiscontinuity(List<ZonedDateTime> dates) {
            if (dates.size() < 2) throw new BusinessException("Not enough dates to determine step");
            cdcPas = getStepEnum(dates.get(1), dates.get(0));
            if (cdcPas == StepEnum.Journalier) {
                for (int i = 1; i < dates.size(); i++) {
                    if (!dates.get(i - 1).plusDays(1).isEqual(dates.get(i))) {
                        StringBuilder msg = new StringBuilder("Discontinuity in dates for the period ")
                                .append(dates.get(0).toLocalDate()).append(" to ")
                                .append(dates.get(dates.size() - 1).toLocalDate());
                        if (curve != null && curve.getCurveType() != null) msg.append(" for ").append(curve.getCurveType());
                        throw new BusinessException(msg.toString());
                    }
                }
                return;
            }
            int n = calculerNbPtsParHeure(cdcPas);
            for (int i = 1; i < dates.size(); i++) {
                if (ChronoUnit.MINUTES.between(dates.get(i - 1), dates.get(i)) != 60 / n) {
                    StringBuilder msg = new StringBuilder("Discontinuity in dates for the period ")
                            .append(dates.get(0).toLocalDate()).append(" to ")
                            .append(dates.get(dates.size() - 1).toLocalDate());
                    if (curve != null && curve.getCurveType() != null) msg.append(" for ").append(curve.getCurveType());
                    throw new BusinessException(msg.toString());
                }
            }
        }

        public CdcOptimized(Curve curve) {
            this(curve, CdcOptimized.convertBytesToDoubles(curve.getBinaryCurve().getData()));
        }

        public StepEnum getStepFromDatesAndValues(ZonedDateTime start, ZonedDateTime end, List<Double> values) {
            try {
                if (start.isAfter(end)) throw new BusinessException("Start date is after end date");
                long  diff    = ChronoUnit.MINUTES.between(start, end);
                float durMin  = Math.round(diff / (float) values.size());
                try { return StepEnum.fromDurationInMinutes((int) durMin); } catch (Exception e) { return null; }
            } catch (BusinessException e) { return null; }
        }

        public CdcOptimized(Curve curve, List<Double> puissancesIn) {
            StepEnum deducted = getStepFromDatesAndValues(curve.getStartDate(), curve.getEndDate(), puissancesIn);
            if (deducted != null && deducted != curve.getStep()) { this.cdcPas = deducted; curve.setStep(deducted); }
            remplirCdc(curve.getStep(), curve.getStartDate(), curve.getEndDate());
            this.curve = curve;
            puissances = fromList(puissancesIn);
        }

        public CdcOptimized(StepEnum pas, ZonedDateTime debut, ZonedDateTime fin) {
