    public void incrementValue(Double value) {
        double primitiveValue = toPrimitive(value);
        for (int i = 0; i < cdcPuissances.length; i++) {
            if (!isMissing(cdcPuissances[i])) {
                cdcPuissances[i] += primitiveValue;
            }
        }
    }

    public static CdcOpti sumAndExtendCdcs(List<CdcOpti> cdcOptiList) {
        ZonedDateTime minStartDate = cdcOptiList.stream().map(CdcOpti::getCdcDateDebut).min(ZonedDateTime::compareTo).orElseThrow(() -> new BusinessException("No start date found"));
        ZonedDateTime maxEndDate = cdcOptiList.stream().map(CdcOpti::getCdcDateFin).max(ZonedDateTime::compareTo).orElseThrow(() -> new BusinessException("No end date found"));

        for(CdcOpti cdcOpti : cdcOptiList) {
            cdcOpti.extendCdc(minStartDate, maxEndDate, null);
        }

        return sumCdcs(cdcOptiList);
    }

    public void applyMethod(Function<Double, Double> method) {
        for (int i = 0; i < cdcPuissances.length; i++) {
            if (!isMissing(cdcPuissances[i])) {
                cdcPuissances[i] = toPrimitive(method.apply(cdcPuissances[i]));
            }
        }
    }

    public void applyMethod(CdcOpti cdcOpti, BiFunction<Double, Double, Double> method) {
        if(cdcOpti.getCdcPuissances().length != cdcPuissances.length) {
            throw new BusinessException("Cdcs have different sizes, cannot apply method");
        }

        double[] other = cdcOpti.getCdcPuissances();
        IntStream.range(0, cdcPuissances.length).forEach(i -> {
            Double v1 = toWrapper(cdcPuissances[i]);
            Double v2 = toWrapper(other[i]);
            cdcPuissances[i] = toPrimitive(method.apply(v1, v2));
        });
    }

    public ZonedDateTime getLastNonNullValueDate(){
        for(int i = cdcPuissances.length - 1; i >= 0; i--) {
            if(!isMissing(cdcPuissances[i])) {
                return cdcDates.get(i).withHour(0).withMinute(0);
            }
        }
        throw new BusinessException("No non-null value found in the CDC");
    }

    public static CdcOpti sumCdcs(List<CdcOpti> cdcOptiList){
        if(cdcOptiList.isEmpty()) {
            throw new BusinessException("No Cdcs to sum");
        }

        CdcOpti firstCdcOpti = cdcOptiList.get(0);
        for(CdcOpti cdcOpti : cdcOptiList) {
            if(!firstCdcOpti.getCdcDateDebut().isEqual(cdcOpti.getCdcDateDebut()) || !firstCdcOpti.getCdcDateFin().isEqual(cdcOpti.getCdcDateFin()) || firstCdcOpti.getCdcPas() != cdcOpti.getCdcPas()) {
                throw new BusinessException("Cdcs have different start/end dates or steps");
            }
        }

        CdcOpti sumCdcOpti = new CdcOpti(firstCdcOpti.getCdcPas(), firstCdcOpti.getCdcDateDebut(), firstCdcOpti.getCdcDateFin(), null);
        IntStream.range(0, sumCdcOpti.getCdcPuissances().length).forEach(index -> {
            double sum = 0D;
            for (CdcOpti cdcOpti : cdcOptiList) {
                double value = cdcOpti.getCdcPuissances()[index];
                if (!isMissing(value)) {
                    sum += value;
                }
            }
            sumCdcOpti.getCdcPuissances()[index] = sum;
        });

        return sumCdcOpti;
    }

    public void reduceCdc(ZonedDateTime start, ZonedDateTime end) {
        extendCdc(start, end, null);

        int startIndex = getReducedStartDateIndex(start);
        int endIndex = getReducedEndDateIndex(end);

        cdcDates = new ArrayList<>(cdcDates.subList(startIndex, endIndex + 1));
        cdcPuissances = slice(cdcPuissances, startIndex, endIndex);
        setStartEndDates();
        cdcDateDebut = start;
        cdcDateFin = end;
        curve.setStartDate(start);
        curve.setEndDate(end);
    }

    public int getReducedStartDateIndex(ZonedDateTime start) {
        for(int i = 0; i < cdcDates.size(); i++) {
            if(cdcDates.get(i).isAfter(start) || cdcDates.get(i).isEqual(start)) {
                return i;
            }
        }
        throw new BusinessException(
                "Données non trouvées pour la courbe " + curve.getCurveType()
                        + ", date de début: " + start.format(DateTimeFormatter.ofPattern("dd/MM/yyyy HH:mm:ss"))
        );
    }

    public int getReducedEndDateIndex(ZonedDateTime end) {
        for(int i = cdcDates.size() - 1; i >= 0; i--) {
            if(cdcDates.get(i).isBefore(end) || cdcDates.get(i).isEqual(end)) {
                return i;
            }
        }
        throw new BusinessException(
                "Données non trouvées pour la courbe " + curve.getCurveType()
                        + ", date de fin: " + end.format(DateTimeFormatter.ofPattern("dd/MM/yyyy HH:mm:ss"))
        );
    }

    public int getDateIndex(ZonedDateTime date) {
        if(!(date.isBefore(cdcDateDebut) || date.isAfter(cdcDateFin))) {
            for(int i = 0; i < cdcDates.size(); i++) {
                if(cdcDates.get(i).isEqual(date)) {
                    return i;
                }
            }
        }
        throw new BusinessException("Date not found in the CDC");
    }

