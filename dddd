        public Duration calculerIntervalle(StepEnum pas) {
            switch(pas) { case Horaire: return Duration.ofHours(1); case SemiHoraire: return Duration.ofMinutes(30); case DixMinutes: return Duration.ofMinutes(10); case CinqMinutes: return Duration.ofMinutes(5); case Journalier: return Duration.ofDays(1); default: return null; }
        }

        public static int calculerNbPtsParHeure(StepEnum pas) {
            switch(pas) { case Horaire: case Journalier: return 1; case SemiHoraire: return 2; case QuinzeMinutes: return 4; case CinqMinutes: return 12; case DixMinutes: return 6; default: return 0; }
        }

        public void reconstruireDates() {
            ZonedDateTime cur=cdcDateDebut; cdcDates=new ArrayList<>();
            while (!cur.isAfter(cdcDateFin)) { cdcDates.add(cur); cur=(cdcPas!=StepEnum.Journalier)?cur.plusMinutes(cdcPas.getDurationInMinutes()):cur.plusDays(1).withHour(0).withMinute(0); }
        }

        public void reconstruireDates(int n) {
            cdcDates = IntStream.range(0,n).parallel()
                    .mapToObj(i -> (cdcPas!=StepEnum.Journalier) ? cdcDateDebut.plusMinutes((long)i*cdcPas.getDurationInMinutes()) : cdcDateDebut.plusDays(i).withHour(0).withMinute(0))
                    .collect(Collectors.toCollection(()->new ArrayList<>(n)));
            cdcDateFin=cdcDates.get(cdcDates.size()-1);
            if (curve!=null) curve.setEndDate(cdcDateFin);
        }

        public int calculerNbPoints(StepEnum pas, ZonedDateTime debut, ZonedDateTime fin) {
            if (pas==StepEnum.Journalier) return Math.round((float)ChronoUnit.DAYS.between(debut,fin)+1);
            int div; switch(pas) { case Horaire: div=24; break; case SemiHoraire: div=48; break; case QuinzeMinutes: div=96; break; case DixMinutes: div=144; break; case CinqMinutes: div=288; break; default: div=24; }
            try { float h=(float)(fin.toEpochSecond()-debut.toEpochSecond())/3600; return Math.round((h*div)/24)+1; }
            catch (Exception e) {
                long ms=ChronoUnit.MILLIS.between(debut,fin); double days=(double)ms/(1000.0*60*60*24); int nb=(int)Math.round(days*div)+1;
                int i=0; ZonedDateTime cur=debut;
                while (cur.isBefore(fin)) { if (isChgtHeureMars(cur)) i--; else if (isChgtHeureOctobre(cur)) i++; cur=cur.plusHours(1); }
                return nb+i*(div/24);
            }
        }

        private boolean isChgtHeureMars(ZonedDateTime d)    { return d.getDayOfWeek().getValue()==7 && d.getMonth().getValue()==3  && d.getDayOfMonth()>24; }
        private boolean isChgtHeureOctobre(ZonedDateTime d) { return d.getDayOfWeek().getValue()==7 && d.getMonth().getValue()==10 && d.getDayOfMonth()>24; }

        public static byte[] convertDoublesToBytes(double[] values) {
            byte[] b=new byte[values.length*Double.BYTES];
            for (int i=0;i<values.length;i++) { long bits=isMissing(values[i])?Double.doubleToLongBits(Double.NaN):Double.doubleToLongBits(values[i]); for (int j=0;j<Double.BYTES;j++) b[i*Double.BYTES+j]=(byte)((bits>>(j*8))&0xFF); }
            return b;
        }
        public static byte[] convertDoublesToBytes(List<Double> values) { return convertDoublesToBytes(fromList(values)); }

        public static List<Double> convertBytesToDoubles(byte[] bytes) {
            List<Double> list=new ArrayList<>(bytes.length/Double.BYTES);
            for (int i=0;i<bytes.length;i+=Double.BYTES) { long bits=0L; for (int j=0;j<Double.BYTES;j++) bits|=((long)bytes[i+j]&0xFF)<<(j*8); double v=Double.longBitsToDouble(bits); list.add(Double.isNaN(v)?null:v); }
            return list;
        }

        private StepEnum getStepEnum(ZonedDateTime start, ZonedDateTime end) {
            long d=start.toLocalDateTime().toInstant(OffsetTime.now().getOffset()).toEpochMilli()-end.toLocalDateTime().toInstant(OffsetTime.now().getOffset()).toEpochMilli();
            if (d==3600000) return StepEnum.Horaire; if (d==1800000) return StepEnum.SemiHoraire; if (d==600000) return StepEnum.DixMinutes; if (d==900000) return StepEnum.QuinzeMinutes; if (d==86400000) return StepEnum.Journalier;
            throw new BusinessException("Invalid step");
        }

        public static void unifyStep(CdcOptimized a, CdcOptimized b) {
            if (a.getCdcPas().getDurationInMinutes()<b.getCdcPas().getDurationInMinutes()) changerPas(b,a.getCdcPas()); else changerPas(a,b.getCdcPas());
        }

        public static CdcOptimized changerPas(CdcOptimized cdc, StepEnum step) {
            StepEnum old=cdc.getCdcPas();
            if ((old==StepEnum.QuinzeMinutes&&step==StepEnum.DixMinutes)||(old==StepEnum.DixMinutes&&step==StepEnum.QuinzeMinutes)) { cdc=changerPas(cdc,StepEnum.CinqMinutes); old=StepEnum.CinqMinutes; }
            if (old==StepEnum.Journalier||step==StepEnum.Journalier) return changerPasJournalier(cdc,step);
            int oldN=calculerNbPtsParHeure(old), newN=calculerNbPtsParHeure(step);
            if (cdc.getCurve()!=null) cdc.getCurve().setStep(step);
            cdc.setCdcPas(step);
            double[] o=cdc.puissances; double[] np;
            long totalMin=ChronoUnit.MINUTES.between(cdc.getCdcDateDebut(),cdc.getCdcDateFin()); int newCount=(int)(totalMin/step.getDurationInMinutes())+1;
            if (newN<oldN) { int f=oldN/newN, bk=(o.length+f-1)/f; np=new double[bk]; for (int i=0;i<bk;i++) { double s=0;int c=0; for (int j=0;j<f&&(i*f+j)<o.length;j++) { double v=o[i*f+j]; if (!isMissing(v)){s+=v;c++;} } np[i]=c==0?MISSING:s/c; } }
            else if (newN>oldN) { int f=newN/oldN; np=new double[o.length*f]; for (int i=0;i<o.length;i++) Arrays.fill(np,i*f,i*f+f,o[i]); }
            else { np=Arrays.copyOf(o,o.length); }
            if (np.length>newCount) np=Arrays.copyOf(np,newCount);
            else if (np.length<newCount) { int prev=np.length; np=Arrays.copyOf(np,newCount); Arrays.fill(np,prev,newCount,o.length>0?o[o.length-1]:MISSING); }
            cdc.puissances=np; cdc.reconstruireDates(np.length);
            if (cdc.getCurve()!=null&&cdc.getCurve().getBinaryCurve()!=null) { cdc.getCurve().getBinaryCurve().setData(convertDoublesToBytes(np)); cdc.getCurve().setStartDate(cdc.getCdcDateDebut()); cdc.getCurve().setEndDate(cdc.getCdcDateFin()); }
            return cdc;
        }

        private static CdcOptimized changerPasJournalier(CdcOptimized cdc, StepEnum newStep) {
            StepEnum old=cdc.getCdcPas(); double[] o=cdc.puissances; double[] np;
            if (cdc.getCurve()!=null) cdc.getCurve().setStep(newStep); cdc.setCdcPas(newStep);
            if (newStep==StepEnum.Journalier&&old==StepEnum.Journalier) { np=Arrays.copyOf(o,o.length); }
            else if (newStep==StepEnum.Journalier) {
                List<Double> agg=new ArrayList<>(); int i=0;
                while (i<o.length) { ZonedDateTime ds=cdc.getCdcDates().get(i), de=ds.withHour(23).withMinute(59); double s=0;int c=0; while (i<o.length&&(cdc.getCdcDates().get(i).isBefore(de)||cdc.getCdcDates().get(i).isEqual(de))) { if (!isMissing(o[i])){s+=o[i];c++;} i++; } agg.add(c==0?null:s/c); }
                np=fromList(agg);
            } else {
                List<Double> dup=new ArrayList<>();
                for (int i=0;i<o.length;i++) { ZonedDateTime s=cdc.getCdcDates().get(i), e=s.plusDays(1), cur=s; while (cur.isBefore(e)) { dup.add(isMissing(o[i])?null:o[i]); cur=cur.plusMinutes(newStep.getDurationInMinutes()); } }
                cdc.setCdcDateFin(cdc.getCdcDateFin().plusDays(1).minusMinutes(newStep.getDurationInMinutes())); np=fromList(dup);
            }
            cdc.puissances=np; cdc.reconstruireDates(); return cdc;
        }

        public boolean datesAreContinuous(CdcOptimized other) {
            if (cdcDates.isEmpty()||other.getCdcDates().isEmpty()) return true;
            ZonedDateTime s1=cdcDates.get(0),e1=cdcDates.get(cdcDates.size()-1),s2=other.getCdcDates().get(0),e2=other.getCdcDates().get(other.getCdcDates().size()-1);
            Duration step=Duration.ofMinutes(Math.min(cdcPas.getDurationInMinutes(),other.getCdcPas().getDurationInMinutes()));
            boolean ov=e1.isAfter(s2)&&s1.isBefore(e2); Duration ga=Duration.between(e1,s2),gb=Duration.between(e2,s1);
            return ov||(!ga.isNegative()&&ga.compareTo(step)<=0)||(!gb.isNegative()&&gb.compareTo(step)<=0);
        }

        public void mergeCdcAndIgnoreDiscontinuity(CdcOptimized other, Double defaultValue) {
            extendCdc(other.getCdcDateDebut(),other.getCdcDateFin(),defaultValue);
            int si=getReducedStartDateIndex(other.getCdcDateDebut()), ei=getReducedEndDateIndex(other.getCdcDateFin());
            double[] src=other.puissances;
            IntStream.range(si,ei+1).parallel().forEach(i->{ double v=src[i-si]; if (!isMissing(v)) puissances[i]=v; });
            curve.getBinaryCurve().setData(convertDoublesToBytes(puissances));
        }
        public void mergeCdcAndIgnoreDiscontinuity(CdcOptimized other) { mergeCdcAndIgnoreDiscontinuity(other,null); }
        public void mergeCdc(CdcOptimized other) { mergeCdc(other,true); }

        public void mergeCdc(CdcOptimized other, boolean overwrite) {
            if (!Objects.equals(cdcPas.getId(),other.getCdcPas().getId())) unifyStep(this,other);
            if (!datesAreContinuous(other)) throw new BusinessException("Discontinuous dates detected.");
            List<ZonedDateTime> nd=other.getCdcDates(), ed=this.cdcDates; double[] np=other.puissances, ep=this.puissances;
            List<ZonedDateTime> md=new ArrayList<>(); List<Double> mv=new ArrayList<>(); int ni=0, ei2=0;
            while (ni<nd.size()&&ei2<ed.size()) { ZonedDateTime a=nd.get(ni),b=ed.get(ei2); if (a.isBefore(b)){md.add(a);mv.add(isMissing(np[ni])?null:np[ni]);ni++;} else if (a.isAfter(b)){md.add(b);mv.add(isMissing(ep[ei2])?null:ep[ei2]);ei2++;} else {md.add(a);if((overwrite&&!isMissing(np[ni]))||isMissing(ep[ei2])){mv.add(isMissing(np[ni])?null:np[ni]);}else{mv.add(isMissing(ep[ei2])?null:ep[ei2]);}ni++;ei2++;} }
            while (ni<nd.size()){md.add(nd.get(ni));mv.add(isMissing(np[ni])?null:np[ni]);ni++;}
            while (ei2<ed.size()){md.add(ed.get(ei2));mv.add(isMissing(ep[ei2])?null:ep[ei2]);ei2++;}
            this.cdcDates=md; this.puissances=fromList(mv);
            this.curve.getBinaryCurve().setData(convertDoublesToBytes(this.puissances));
            setStartEndDates(); reconstruireDates(); calculateCurveTotals();
        }

        public void setStartEndDates() { setStartEndDates(cdcDates); }
        public void setStartEndDates(List<ZonedDateTime> dates) {
            if (curve.getStartDate()!=null) curve.setStartDate(dates.get(0).isBefore(curve.getStartDate())?dates.get(0):curve.getStartDate()); else curve.setStartDate(dates.get(0));
            if (curve.getEndDate()!=null) curve.setEndDate(dates.get(dates.size()-1).isAfter(curve.getEndDate())?dates.get(dates.size()-1):curve.getEndDate()); else curve.setEndDate(dates.get(dates.size()-1));
            cdcDateDebut=curve.getStartDate().withZoneSameInstant(currentZoneId); cdcDateFin=curve.getEndDate().withZoneSameInstant(currentZoneId);
        }

        public static void calculateCurveTotals(Curve c) { if (c==null||c.getCurveType()!=CurveTypeEnum.CDC) return; CdcOptimized cdc=new CdcOptimized(c); c.setTotalVolume(cdc.getSum()/calculerNbPtsParHeure(cdc.getCdcPas())); c.setAnnualVolume(cdc.getSumLastYear()/calculerNbPtsParHeure(cdc.getCdcPas())); }
        public void calculateCurveTotals() { if (curve!=null&&curve.getCurveType()==CurveTypeEnum.CDC) { curve.setTotalVolume(getSum()/calculerNbPtsParHeure(cdcPas)); curve.setAnnualVolume(getSumLastYear()/calculerNbPtsParHeure(cdcPas)); } }

        public Double calculateHistoricalAnnualEnergyVolume() {
            boolean e=cdcDateFin.isAfter(cdcDateDebut.plusDays(395));
            if (e) return getSum(cdcDateFin.minusDays(395).withHour(0).withMinute(0),cdcDateFin.minusDays(30))/calculerNbPtsParHeure(cdcPas);
            double r=(double)365/ChronoUnit.DAYS.between(cdcDateDebut,cdcDateFin);
            return getSum()/calculerNbPtsParHeure(cdcPas)*r;
        }

        public CdcOptimized recopier() {
            CdcOptimized c=new CdcOptimized(); c.setCdcPas(this.cdcPas); c.puissances=Arrays.copyOf(this.puissances,this.puissances.length);
            c.setCdcDateDebut(this.cdcDateDebut); c.setCdcDateFin(this.cdcDateFin); c.setCdcDates(new ArrayList<>(this.cdcDates));
            Curve cv=duplicateCurve(this.curve); c.setCurve(cv); c.setBinaryCurve(cv.getBinaryCurve()); return c;
        }
        private Curve duplicateCurve(Curve cv) { Curve c=new Curve(); c.setStartDate(cv.getStartDate()); c.setEndDate(cv.getEndDate()); c.setBinaryCurve(new BinaryCurve()); c.getBinaryCurve().setData(cv.getBinaryCurve().getData()); c.getBinaryCurve().setCurve(c); c.setStep(cv.getStep()); return c; }

        public LocalDate paques(int y) { int a=y%19,b=y/100,c=y%100,d=b/4,e=b%4,f=(b+8)/25,g=(b-f+1)/3,h=(19*a+b-d-g+15)%30,i=c/4,k=c%4,L=(32+2*e+2*i-h-k)%7,m=(a+11*h+22*L)/451,mo=(h+L-7*m+114)/31,j=((h+L-7*m+114)%31)+1; return LocalDate.of(y,mo,j); }
        public LocalDate[] joursFeries(int y) { LocalDate[] f=new LocalDate[11]; f[0]=LocalDate.of(y,1,1);f[1]=LocalDate.of(y,5,1);f[2]=LocalDate.of(y,5,8);f[3]=LocalDate.of(y,7,14);f[4]=LocalDate.of(y,8,15);f[5]=LocalDate.of(y,11,1);f[6]=LocalDate.of(y,11,11);f[7]=LocalDate.of(y,12,25);f[8]=paques(y).plusDays(1);f[9]=f[8].plusDays(38);f[10]=f[8].plusDays(49); return f; }
        public boolean isFerie(LocalDateTime d) { LocalDate ld=d.toLocalDate(); for (LocalDate f:joursFeries(ld.getYear())) if (ld.equals(f)) return true; return false; }
        public boolean isBissextile(int y) { return LocalDate.of(y,1,1).isLeapYear(); }
        public boolean isPaques(LocalDateTime d)    { return d.toLocalDate().equals(joursFeries(d.getYear())[8]); }
        public boolean isAscension(LocalDateTime d) { return d.toLocalDate().equals(joursFeries(d.getYear())[9]); }
        public boolean isPentecote(LocalDateTime d) { return d.toLocalDate().equals(joursFeries(d.getYear())[10]); }

        public int testIndex(ZonedDateTime date) {
            List<ZonedDateTime> dates=this.getCdcDates(); if (dates==null||dates.isEmpty()) return -1; if (date.isBefore(this.cdcDateDebut)||date.isAfter(this.cdcDateFin)) return -1;
            int i1=0,i2=dates.size()-1,i=0; while (i1+1<i2){i=(i1+i2)/2;if(dates.get(i).isAfter(date))i2=i;else i1=i;} return dates.get(i1).equals(date)?i1:i2;
        }
        public int testIndexNew(LocalDateTime date) {
            List<ZonedDateTime> dates=this.getCdcDates(); if (dates==null||dates.isEmpty()) return -1; if (date.isBefore(this.cdcDateDebut.toLocalDateTime())||date.isAfter(this.cdcDateFin.toLocalDateTime())) return -1;
            int i1=0,i2=dates.size()-1,i=0; while (i1+1<i2){i=(i1+i2)/2;if(dates.get(i).toLocalDateTime().isAfter(date))i2=i;else i1=i;} return dates.get(i1).toLocalDateTime().equals(date)?i1:i2;
        }

        public static boolean isPicNoel(CdcOptimized src) { try { int y=src.getCdcDateDebut().getYear(); ZoneId z=src.getCdcDateDebut().getZone(); return isPic(src,ZonedDateTime.of(LocalDate.of(y,12,24).atStartOfDay(),z),ZonedDateTime.of(LocalDate.of(y,12,26).atStartOfDay(),z),ZonedDateTime.of(LocalDate.of(y,12,18).atStartOfDay(),z)); } catch(Exception e){return false;} }
        private static boolean isPic(CdcOptimized src,ZonedDateTime js1,ZonedDateTime js2,ZonedDateTime js3) { try { double m1=maxJour(src,js1),m2=maxJour(src,js2),m3=maxJour(src,js3); if(src.testIndex(js1)<0)m1=m2; if(src.testIndex(js2)<0)m2=m1; return m3>1.5*((m1+m2)/2.0); } catch(Exception e){return false;} }
        public static boolean isPic(CdcOptimized ci,CdcOptimized src,LocalDate jc,Map<LocalDate,LocalDate> cs,boolean jp) { try { LocalDate js=cs.get(jc); return isPic(src,ZonedDateTime.of(js.minusDays(1).atStartOfDay(),currentZoneId),ZonedDateTime.of(js.plusDays(1).atStartOfDay(),currentZoneId),ZonedDateTime.of(src.trouverJourDeRemplacement(ZonedDateTime.of(js.atStartOfDay(),currentZoneId),jp).toLocalDateTime(),currentZoneId)); } catch(Exception e){return false;} }
        public ZonedDateTime trouverJourDeRemplacement(ZonedDateTime jour,boolean jp) { ZonedDateTime ret=jour; boolean ok=false,stop=false; ZonedDateTime d1=jour,d2=jour; while(!ok&&!stop){d1=d1.minusDays(7);d2=d2.plusDays(7);int i1=testIndex(d1),i2=testIndex(d2);Duration iv=this.calculerIntervalle(this.cdcPas); if(jp){if(isValide(i2)&&!isMqt(i2,false)&&!isFerie(d2.toLocalDateTime().minus(iv))){ret=cdcDates.get(i2);ok=true;}else if(isValide(i1)&&!isMqt(i1,false)&&!isFerie(d1.toLocalDateTime().minus(iv))){ret=cdcDates.get(i1);ok=true;}}else{if(isValide(i1)&&!isMqt(i1,false)&&!isFerie(d1.toLocalDateTime().minus(iv))){ret=cdcDates.get(i1);ok=true;}else if(isValide(i2)&&!isMqt(i2,false)&&!isFerie(d2.toLocalDateTime().minus(iv))){ret=cdcDates.get(i2);ok=true;}} stop=!(isValide(i1)||isValide(i2));} return ret; }

        public boolean isValide(int idx) { return idx>=0&&idx<puissances.length; }
        public boolean isMqt(int idx,boolean iz) { if(!isValide(idx))return true; if(iz)return isMissing(puissances[idx])||puissances[idx]==0.0; return isMissing(puissances[idx]); }
        private static double maxJour(CdcOptimized src,ZonedDateTime jd) { Duration iv=src.calculerIntervalle(src.getCdcPas()); CdcOptimized j=src.recopier().projectCdc(jd.plus(iv),jd.plusDays(1),src.getCdcPas()); if(j==null)return Double.NEGATIVE_INFINITY; double m=Double.NEGATIVE_INFINITY; for(double v:j.puissances)if(!isMissing(v))m=Math.max(m,v); return m; }
        public static boolean isMarsDebutEte(ZonedDateTime d) { return d.getMonthValue()==3&&d.getDayOfWeek()==DayOfWeek.SUNDAY&&d.plusDays(7).getMonthValue()==4; }
        public static boolean isOctobreFinEte(ZonedDateTime d) { return d.getMonthValue()==10&&d.getDayOfWeek()==DayOfWeek.SUNDAY&&d.plusDays(7).getMonthValue()==11; }
        public static int countPointsInDay(CdcOptimized cdc,int si) { if(si>=cdc.cdcDates.size())return 0; LocalDate j=cdc.cdcDates.get(si).minus(cdc.calculerIntervalle(cdc.cdcPas)).toLocalDate(); int c=0; for(int i=si;i<cdc.cdcDates.size();i++){if(cdc.cdcDates.get(i).minus(cdc.calculerIntervalle(cdc.cdcPas)).toLocalDate().equals(j))c++;else break;} return c; }

        public void corrigerValeursNulles(boolean iz) { Duration iv=this.calculerIntervalle(this.cdcPas); for(int i=0;i<cdcDates.size();i++){if(isMqt(i,iz)){puissances[i]=isFerie(cdcDates.get(i).toLocalDateTime().minus(iv))?corrigerValeurManquanteFerie(i,iz):corrigerValeurManquante(i,iz);}} }
        public void corrigerJourFerieValeursNulles(boolean iz) { Duration iv=this.calculerIntervalle(this.cdcPas); for(int i=0;i<cdcDates.size();i++){if(isMqt(i,iz)&&isFerie(cdcDates.get(i).toLocalDateTime().minus(iv))){puissances[i]=corrigerValeurManquanteFerie(i,iz);}} }

        private double corrigerValeurManquante(int idx,boolean iz) { boolean ok=false,stop=false; LocalDateTime d1=cdcDates.get(idx).toLocalDateTime(),d2=cdcDates.get(idx).toLocalDateTime(); while(!ok&&!stop){d1=d1.minusDays(7);d2=d2.plusDays(7);int i1=testIndex(ZonedDateTime.of(d1,currentZoneId)),i2=testIndex(ZonedDateTime.of(d2,currentZoneId));Duration iv=this.calculerIntervalle(this.cdcPas);if(isValide(i1)&&!isMqt(i1,iz)&&!isFerie(d1.minus(iv)))return puissances[i1];if(isValide(i2)&&!isMqt(i2,iz)&&!isFerie(d2.minus(iv)))return puissances[i2];stop=!(isValide(i1)||isValide(i2));} return 0.0; }

        private double corrigerValeurManquanteFerie(int idx,boolean iz) {
            LocalDate[] jf=joursFeries(cdcDates.get(idx).getYear()); long di=cdcDates.get(idx).toLocalDate().toEpochDay();
            int cpt=0; for(LocalDate f:jf){ZonedDateTime t=cdcDates.get(idx).plusDays(f.toEpochDay()-di);if(!isMqt(testIndex(t),iz))cpt++;} if(cpt==0)return 0.0;
            double[] vals=new double[cpt]; LocalDate[] fok=new LocalDate[cpt]; int k=0;
            for(LocalDate f:jf){ZonedDateTime t=cdcDates.get(idx).plusDays(f.toEpochDay()-di);int in=testIndex(t);if(!isMqt(in,iz)){vals[k]=puissances[in];fok[k]=f;k++;}}
            int best=cpt-1; LocalDate db=fok[cpt-1]; for(int j=cpt-1;j>0;j--){if(Math.abs(cdcDates.get(idx).toLocalDate().toEpochDay()-fok[j].toEpochDay())<Math.abs(cdcDates.get(idx).toLocalDate().toEpochDay()-db.toEpochDay())){db=fok[j];best=j;}} return vals[best];
        }

