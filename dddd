}

private void updatePodMaco(EntityManager em, Long operationTraitementId) {
    executeUpdate(em,
            "UPDATE maco_d_pod_maco " +
            "SET billing_method_changed = true, " +
            "    echu_oper = true " +
            "WHERE id IN ( " +
            "    SELECT id " +
            "    FROM ( " +
            "        SELECT id, ext_id, validity_end_date, " +
            "               RANK() OVER (PARTITION BY ext_id ORDER BY validity_end_date DESC) AS rownum " +
            "        FROM maco_d_pod_maco " +
            "    ) AS last_validity_sq " +
            "    WHERE rownum = 1 " +
            "    AND ext_id IN ( " +
            "        SELECT DISTINCT prm_id " +
            "        FROM maco_d_processing_operation " +
            "        WHERE id IN ( " +
            "            SELECT DISTINCT echoir.id_operation_traitement " +
            "            FROM maco_d_billable_subscription echoir " +
            "            JOIN maco_d_billable_subscription echu " +
            "              ON echoir.id_operation_traitement = echu.id_operation_traitement " +
            "            WHERE echoir.type_abo = 'A_ECHOIR' " +
            "            AND echu.type_abo = 'ECHU' " +
            "            AND echoir.id_operation_traitement = :operationTraitementId " +
            "            AND echu.id_operation_traitement = :operationTraitementId " +
            "        ) " +
            "    ) " +
            ")",
            operationTraitementId
    );
}

