        public CdcOptimized projectCdc(ZonedDateTime debut, ZonedDateTime fin, StepEnum targetPas) {
            return projectCdc(debut, fin, targetPas, false);
        }

        public CdcOptimized projectCdc(ZonedDateTime debut, ZonedDateTime fin, StepEnum targetPas, boolean avecNaN) {
            if (debut == null || fin == null) return this;
            if (this.cdcPas == targetPas && debut.equals(this.cdcDateDebut) && fin.equals(this.cdcDateFin)) return recopier();
            CdcOptimized retour = new CdcOptimized(targetPas, debut, fin, avecNaN);
            if (retour.cdcDates == null) return null;
            int i = 0, j = 0;
            while (i < retour.cdcDates.size() && retour.cdcDates.get(i).isBefore(this.cdcDateDebut)) i++;
            while (j < this.cdcDates.size() && i < retour.cdcDates.size() && this.cdcDates.get(j).isBefore(retour.cdcDates.get(i))) j++;
            while (i < retour.puissances.length && j < this.puissances.length) { retour.puissances[i] = this.puissances[j]; j++; i++; }
            return retour;
        }

        public void extendCdc(ZonedDateTime debut, ZonedDateTime fin, Double defaultValue) {
            if (debut.isEqual(cdcDateDebut) && fin.isEqual(cdcDateFin)) return;
            double fillVal = (defaultValue == null) ? MISSING : defaultValue;
            ZonedDateTime startDate = cdcDateDebut.isBefore(debut) || cdcDateDebut.isEqual(debut) ? cdcDateDebut : debut;
            ZonedDateTime endDate   = cdcDateFin.isAfter(fin)      || cdcDateFin.isEqual(fin)     ? cdcDateFin   : fin;
            int stepMin = cdcPas.getDurationInMinutes();
            List<ZonedDateTime> newDates  = new ArrayList<>();
            List<double[]>      newChunks = new ArrayList<>();
            if (startDate.isBefore(cdcDateDebut)) {
                ZonedDateTime cur = startDate;
                int cnt = 0;
                while (cur.isBefore(cdcDateDebut)) { newDates.add(cur); cnt++; cur = (cdcPas == StepEnum.Journalier) ? cur.plusDays(1) : cur.plusMinutes(stepMin); }
                newChunks.add(allocate(cnt, fillVal));
                newDates.addAll(cdcDates);
                newChunks.add(puissances);
            } else {
                newDates.addAll(cdcDates);
                newChunks.add(puissances);
            }
            if (endDate.isAfter(cdcDateFin)) {
                ZonedDateTime cur = (cdcPas == StepEnum.Journalier) ? cdcDateFin.plusDays(1) : cdcDateFin.plusMinutes(stepMin);
                List<ZonedDateTime> post = new ArrayList<>();
                while (!cur.isAfter(endDate)) { post.add(cur); cur = (cdcPas == StepEnum.Journalier) ? cur.plusDays(1) : cur.plusMinutes(stepMin); }
                newChunks.add(allocate(post.size(), fillVal));
                newDates.addAll(post);
            }
            int total = newChunks.stream().mapToInt(a -> a.length).sum();
            double[] merged = new double[total];
            int pos = 0;
            for (double[] chunk : newChunks) { System.arraycopy(chunk, 0, merged, pos, chunk.length); pos += chunk.length; }
            cdcDates   = newDates;
            puissances = merged;
            setStartEndDates();
        }

        private void remplirCdc(StepEnum pas, ZonedDateTime debut, ZonedDateTime fin) { remplirCdc(pas, debut, fin, 0.0); }

        private void remplirCdc(StepEnum pas, ZonedDateTime debut, ZonedDateTime fin, double defaultValue) {
            try {
                int n = calculerNbPoints(pas, debut, fin);
                if (n > 0) {
                    cdcDates     = new ArrayList<>(n);
                    puissances   = allocate(n, defaultValue);
                    cdcDateDebut = debut.withZoneSameInstant(currentZoneId);
                    cdcDateFin   = fin.withZoneSameInstant(currentZoneId);
                    cdcPas       = pas;
                    reconstruireDates(n);
                }
                initCurve();
            } catch (Exception e) { throw new BusinessException(e); }
        }

        public CdcOptimized getReducedCdc(ZonedDateTime start, ZonedDateTime end) {
            CdcOptimized r = new CdcOptimized();
            int si = getReducedStartDateIndex(start), ei = getReducedEndDateIndex(end);
            r.curve = new Curve();
            r.curve.setStartDate(start); r.curve.setEndDate(end); r.curve.setStep(cdcPas);
            r.curve.setBinaryCurve(new BinaryCurve());
            r.curve.getBinaryCurve().setCurve(r.curve);
            r.cdcDates    = new ArrayList<>(cdcDates.subList(si, ei + 1));
            r.puissances  = Arrays.copyOfRange(puissances, si, ei + 1);   // copie isolée ← safe à muter
            r.curve.getBinaryCurve().setData(convertDoublesToBytes(r.puissances));
            r.cdcDateDebut = start; r.cdcDateFin = end; r.cdcPas = cdcPas;
            return r;
        }

        public CoverageStatus getCoverageStatus(ZonedDateTime start, ZonedDateTime end) {
            int si = getReducedStartDateIndex(start), ei = getReducedEndDateIndex(end);
            long expected = Duration.between(start, end).toMinutes() / cdcPas.getDurationInMinutes() + 1;
            if (si < 0 || ei < si) return CoverageStatus.NONE;
            boolean hasOne = false, allOk = true; int count = 0;
            for (int i = si; i <= ei; i++) { if (!isMissing(puissances[i])) { hasOne = true; count++; } else allOk = false; }
            if (!hasOne) return CoverageStatus.NONE;
            return (allOk && count == expected) ? CoverageStatus.FULL : CoverageStatus.PARTIAL;
        }

        public enum CoverageStatus { NONE, PARTIAL, FULL }

